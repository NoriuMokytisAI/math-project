  "workedExamples": [
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-exmp-1",
      "title": "Panašių narių sutraukimas",
      "level": "easy",
      "problem": "Supaprastinkite reiškinį: $5x + 3y - 2x + 4y$.",
      "conceptIds": [
        "reiskinys",
        "koeficientas"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Sujungiame narius su x.",
          "latex": "5x - 2x = 3x"
        },
        {
          "text": "Sujungiame narius su y.",
          "latex": "3y + 4y = 7y"
        },
        {
          "text": "Užrašome galutinį reiškinį.",
          "latex": "3x + 7y"
        }
      ],
      "answer": "3x + 7y"
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-exmp-2",
      "title": "Lygties sprendimas (2 žingsniai)",
      "level": "easy",
      "problem": "Išspręskite lygtį: $4x - 7 = 13$.",
      "conceptIds": [
        "lygtis",
        "sprendinys"
      ],
      "formulaIds": [
        "tiesines-lygties-forma"
      ],
      "steps": [
        {
          "text": "Pridedame 7 prie abiejų pusių.",
          "latex": "4x = 13 + 7 = 20"
        },
        {
          "text": "Daliname abi puses iš 4.",
          "latex": "x = 20 : 4 = 5"
        }
      ],
      "answer": "x = 5"
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-exmp-3",
      "title": "Skliaustų atskleidimas",
      "level": "medium",
      "problem": "Supaprastinkite: $2(3x - 5) + 4x$.",
      "conceptIds": [
        "distributyvusis-destymas"
      ],
      "formulaIds": [
        "sklaidos-desnis"
      ],
      "steps": [
        {
          "text": "Dauginame 2 iš skliaustų narių.",
          "latex": "2 \\cdot 3x - 2 \\cdot 5 = 6x - 10"
        },
        {
          "text": "Pridedame likusį narį 4x.",
          "latex": "6x - 10 + 4x"
        },
        {
          "text": "Sutraukiame panašius narius.",
          "latex": "10x - 10"
        }
      ],
      "answer": "10x - 10"
