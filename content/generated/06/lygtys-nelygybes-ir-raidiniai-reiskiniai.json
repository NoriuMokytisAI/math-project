  "theory": [
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-raidiniai-reiskiniai",
      "title": "Nuo skaičių prie raidžių: raidiniai reiškiniai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Iki šiol matematikoje dažniausiai skaičiavome su konkrečiais skaičiais. Tačiau kartais skaičius mums yra nežinomas arba jis gali keistis. Tokiu atveju naudojame raides (dažniausiai $x, y, a, b$). Ši matematikos šaka vadinama algebra."
        },
        {
          "type": "definition",
          "conceptId": "kintamasis",
          "text": "Kintamasis – tai raidė, kuri žymi nežinomą arba kintantį skaičių."
        },
        {
          "type": "definition",
          "conceptId": "koeficientas",
          "text": "Koeficientas – tai skaičius, parašytas prieš raidę (pvz., reiškinyje $5x$, skaičius 5 yra koeficientas)."
        },
        {
          "type": "note",
          "text": "Jei prieš raidę skaičiaus nėra, laikome, kad koeficientas yra 1 (pvz., $x$ yra tas pats, kas $1x$). Jei parašyta $-x$, koeficientas yra $-1$."
        }
      ]
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-sutvarkymas",
      "title": "Reiškinių supaprastinimas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kaip sudėti 3 obuolius ir 2 obuolius? Gausime 5 obuolius. Panašiai veikia ir [[reiskinys|raidiniai reiškiniai]]. Galime sudėti arba atimti tik tuos narius, kurie turi tokias pačias raides. Tai vadinama **panašių narių sutraukimu**."
        },
        {
          "type": "example",
          "text": "Supaprastinkime: $4x + 7 - 2x + 3$. \n1. Sugrupuojame narius su $x$: $4x - 2x = 2x$. \n2. Sugrupuojame skaičius: $7 + 3 = 10$. \n3. Atsakymas: $2x + 10$."
        },
        {
          "type": "warning",
          "text": "Niekada nesudėkite skaičiaus su raide! $2x + 5$ NĖRA lygu $7x$. Tai dažniausia klaida pradedant mokytis algebros."
        }
      ]
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-sklaida",
      "title": "Sklaidos dėsnis (skliaustų atskleidimas)",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Jei turime skaičių prieš skliaustus, privalome jį padauginti iš KIEKVIENO nario, esančio skliaustuose."
        },
        {
          "type": "formula",
          "formulaId": "sklaidos-desnis",
          "latex": "a(b + c) = ab + ac"
        },
        {
          "type": "example",
          "text": "$3(x + 4) = 3 \\cdot x + 3 \\cdot 4 = 3x + 12$."
        },
        {
          "type": "warning",
          "text": "Jei prieš skliaustus yra minuso ženklas, atskleidžiant skliaustus VISI ženklai skliaustų viduje pasikeičia į priešingus: $-(x - 5) = -x + 5$."
        }
      ]
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-lygtis",
      "title": "Kas yra lygtis ir kaip ją spręsti?",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "lygtis",
          "text": "Lygtis – tai lygybė su nežinomuoju ($x$). Išspręsti lygtį reiškia rasti tokią $x$ reikšmę, su kuria lygybė būtų teisinga."
        },
        {
          "type": "paragraph",
          "text": "Į lygtį žiūrėkite kaip į svarstykles. Abi pusės privalo likti pusiausvyroje. Todėl ką darote vienoje pusėje, privalote padaryti ir kitoje."
        },
        {
          "type": "method",
          "text": "Pagrindinės taisyklės:\n1. Prie abiejų lygties pusių galime pridėti arba iš abiejų atimti tą patį skaičių.\n2. Abi lygties puses galime padauginti arba padalyti iš to paties (nelygaus nuliui) skaičiaus."
        }
      ]
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-zingsniai",
      "title": "Lygčių sprendimo žingsniai",
      "blocks": [
        {
          "type": "method",
          "text": "Norėdami išspręsti lygtį (pvz., $3x - 5 = 10$):\n1. „Perkelkite“ narius be $x$ į dešinę pusę (pakeisdami veiksmą į priešingą): $3x = 10 + 5$.\n2. Sutvarkykite puses: $3x = 15$.\n3. Padalykite iš skaičiaus prie $x$: $x = 15 : 3$.\n4. Gaukite atsakymą: $x = 5$."
        },
        {
          "type": "note",
          "text": "Visada pasitikrinkite! Įstatykite gautą $x$ į pradinę lygtį: $3 \\cdot 5 - 5 = 15 - 5 = 10$. Teisinga!"
        }
      ]
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-nelygybes",
      "title": "Įvadas į nelygybes",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kai lyginame du reiškinius ne lygybės, o didumo/mažumo ženklais ($<, >, \\le, \\ge$), gauname [[nelygybe|nelygybę]]."
        },
        {
          "type": "paragraph",
          "text": "Nelygybės sprendžiamos beveik taip pat kaip lygtys, tačiau jos dažniausiai turi ne vieną atsakymą, o ištisą jų rinkinį."
        },
        {
          "type": "warning",
          "text": "Svarbiausia taisyklė: jei abi nelygybės puses dauginate arba dalijate iš NEIGIAMO skaičiaus, nelygybės ženklas privalo apsiversti į priešingą pusę! (Pvz., iš $<$ tampa $>$)."
        }
      ]
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-modeliavimas",
      "title": "Uždavinių modeliavimas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Algebra yra galingas įrankis spręsti „gyvenimiškus“ uždavinius. Reikia tik išmokti tekstą paversti lygčių kalba."
        },
        {
          "type": "method",
          "text": "Kaip modeliuoti:\n1. Nežinomą dydį pažymėkite $x$.\n2. Pagal teksto sąlygas sudarykite reiškinį (pvz., „skaičių padidino 5 kartus“ $\\rightarrow 5x$).\n3. Sudarykite lygtį ir ją išspręskite."
        }
      ]
    },
    {
      "id": "lygtys-nelygybes-ir-raidiniai-reiskiniai-klaidos",
      "title": "Dažnos klaidos",
      "blocks": [
        {
          "type": "warning",
          "text": "Perkeliant narį per lygybės ženklą, jo ženklas PRIVALO pasikeisti. $+5$ tampa $-5$, o daugyba tampa dalyba."
        },
        {
          "type": "warning",
          "text": "Panašių narių sutraukimas: nepameskite raidžių. $3x + x$ yra $4x$, o ne $3$ ar $3x^2$."
        },
        {
          "type": "method",
          "text": "Jei lygtis atrodo sudėtinga su daug skliaustų, pirmiausia juos visus atskleiskite, tada sutraukite panašius narius ir tik tada pradėkite „kilnoti“ narius iš vienos pusės į kitą."
        }
      ]
    }
  ],
