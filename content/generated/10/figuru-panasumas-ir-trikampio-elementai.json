  "theory": [
    {
      "id": "figuru-panasumas-ivadas",
      "title": "Figūrų panašumas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Dvi figūros vadinamos panašiosiomis, jei jų atitinkami kampai yra lygūs, o atitinkamos kraštinės yra proporcingos."
        },
        {
          "type": "definition",
          "conceptId": "panasumo-koeficientas",
          "text": "Skaičius $k$, rodantis, kiek kartų viena figūra yra didesnė už kitą."
        },
        {
          "type": "property",
          "text": "Jei figūrų panašumo koeficientas yra $k$, tai jų perimetrų santykis lygus $k$, o plotų santykis lygus $k^2$."
        }
      ]
    },
    {
      "id": "trikampio-pusiaukrastines",
      "title": "Trikampio pusiaukraštinės",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Trikampio [[pusiaukrastine|pusiaukraštinė]] yra atkarpa, jungianti trikampio viršūnę su prieš ją esančios kraštinės viduriu."
        },
        {
          "type": "theorem",
          "text": "Visos trys trikampio pusiaukraštinės kertasi viename taške, kuris kiekvieną jų dalija santykiu 2:1, skaičiuojant nuo viršūnės."
        }
      ]
    },
    {
      "id": "trikampio-pusiaukampines",
      "title": "Trikampio pusiaukampinės",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Trikampio [[pusiaukampine|pusiaukampinė]] yra atkarpa, kuri dalija trikampio kampą pusiau."
        },
        {
          "type": "property",
          "conceptId": "pusiaukampiniu-savybe",
          "text": "Trikampio pusiaukampinė prieš ją esančią kraštinę dalija į atkarpas, proporcingas kitoms dviem trikampio kraštinėms."
        }
      ]
    }
  ],
