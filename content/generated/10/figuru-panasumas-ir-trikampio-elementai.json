  "workedExamples": [
    {
      "id": "panasumas-example-1",
      "title": "Plotų santykio radimas",
      "level": "easy",
      "problem": "Dviejų panašių trikampių kraštinių santykis yra 2:5. Koks bus jų plotų santykis?",
      "conceptIds": [
        "plotu-santykis"
      ],
      "steps": [
        {
          "text": "Randame panašumo koeficientą k.",
          "latex": "k = \\frac{2}{5}"
        },
        {
          "text": "Plotų santykis lygus $k^2$.",
          "latex": "\\left(\\frac{2}{5}\\right)^2 = \\frac{4}{25}"
        }
      ],
      "answer": "4:25"
    },
    {
      "id": "pusiaukrastine-example-1",
      "title": "Pusiaukraštinių dalių radimas",
      "level": "easy",
      "problem": "Trikampio pusiaukraštinės ilgis yra 12 cm. Raskite jos dalių ilgius iki sankirtos taško.",
      "conceptIds": [
        "pusiaukrastiniu-sankirta"
      ],
      "steps": [
        {
          "text": "Pusiaukraštinė dalijama santykiu 2:1. Iš viso yra 3 dalys.",
          "latex": "12 : 3 = 4 \\text{ cm}"
        },
        {
          "text": "Ilgesnė dalis (prie viršūnės) yra 2 dalys.",
          "latex": "2 \\cdot 4 = 8 \\text{ cm}"
        },
        {
          "text": "Trumpesnė dalis yra 1 dalis.",
          "latex": "1 \\cdot 4 = 4 \\text{ cm}"
        }
      ],
      "answer": "8 cm ir 4 cm"
    },
    {
      "id": "pusiaukampine-example-1",
      "title": "Kraštinės atkarpų radimas",
      "level": "medium",
      "problem": "Trikampio kraštinės yra 6 cm ir 8 cm. Pusiaukampinė iš viršūnės tarp šių kraštinių dalija priešingą kraštinę, kurios ilgis 7 cm, į dvi dalis. Raskite tų dalių ilgius.",
      "conceptIds": [
        "pusiaukampiniu-savybe"
      ],
      "steps": [
        {
          "text": "Tarkime dalys yra x ir 7-x. Pagal savybę:",
          "latex": "\\frac{6}{8} = \\frac{x}{7-x}"
        },
        {
          "text": "Supaprastiname santykį: $\\frac{3}{4} = \\frac{x}{7-x}$."
        },
        {
          "text": "Dauginame kryžmai: $3(7-x) = 4x$.",
          "latex": "21 - 3x = 4x \\implies 7x = 21 \\implies x = 3"
        },
        {
          "text": "Kita dalis: $7 - 3 = 4$."
        }
      ],
      "answer": "3 cm ir 4 cm"
    },
    {
      "id": "panasumas-example-2",
      "title": "Nežinomos kraštinės radimas per plotą",
      "level": "medium",
      "problem": "Panašių daugiakampių plotai yra $20\\text{ cm}^2$ ir $80\\text{ cm}^2$. Jei mažesniojo daugiakampio perimetras yra 15 cm, koks yra didesniojo perimetras?",
      "conceptIds": [
        "plotu-santykis",
        "perimetru-santykis"
      ],
      "steps": [
        {
          "text": "Randame plotų santykį, kuris lygus $k^2$.",
          "latex": "k^2 = \\frac{80}{20} = 4"
        },
        {
          "text": "Randame panašumo koeficientą k.",
          "latex": "k = \\sqrt{4} = 2"
        },
        {
          "text": "Didesniojo perimetras bus k kartų didesnis.",
          "latex": "P = 15 \\cdot 2 = 30 \\text{ cm}"
        }
      ],
      "answer": "30 cm"
    },
    {
      "id": "pusiaukrastine-hard-1",
      "title": "Pusiaukraštinės savybė su kintamaisiais",
      "level": "hard",
      "problem": "Trikampio pusiaukraštinių sankirtos taško atstumas iki viršūnės yra 6 cm didesnis už atstumą iki kraštinės. Koks yra visos pusiaukraštinės ilgis?",
      "conceptIds": [
        "pusiaukrastiniu-sankirta"
      ],
      "steps": [
        {
          "text": "Tarkime trumpesnė dalis yra x, tada ilgesnė yra 2x.",
          "latex": "2x - x = 6 \\implies x = 6"
        },
        {
          "text": "Ilgesnė dalis: $2 \\cdot 6 = 12$."
        },
        {
          "text": "Visa pusiaukraštinė: $12 + 6 = 18$."
        }
      ],
      "answer": "18 cm"
    }
  ],
