  "theory": [
    {
      "id": "racionaliosios-lygtys-ivadas-detalus",
      "title": "1. Kas yra trupmeninė racionalioji lygtis?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Iki šiol sprendėte lygtis, kuriose kintamasis $x$ būdavo „viršuje“ arba dauginamas. Tačiau daugelyje realių situacijų – pavyzdžiui, skaičiuojant laiką, per kurį du darbininkai atliks darbą kartu, arba automobilio greitį prieš srovę – kintamasis atsiranda **vardiklyje**. Tokios lygtys vadinamos trupmeninėmis racionaliosiomis lygtimis."
        },
        {
          "type": "definition",
          "conceptId": "trupmenine-racionalioji-lygtis",
          "text": "[[trupmenine-racionalioji-lygtis|Trupmenine racionaliąja lygtimi]] vadiname lygtį, kurioje bent vienas reiškinys su kintamuoju yra vardiklyje."
        },
        {
          "type": "paragraph",
          "text": "Svarbiausia taisyklė: kadangi vardiklis negali būti lygus nuliui, kiekviena tokia lygtis prasideda nuo „saugumo patikros“ – leistinųjų reikšmių aibės (LRA) nustatymo."
        }
      ]
    },
    {
      "id": "racionaliosios-lygtys-lra",
      "title": "2. LRA ir Pašalinės šaknys",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Išsprendę trupmeninę lygtį, galime gauti skaičių, kuris iš tikrųjų netinka, nes paverčia pradinės lygties vardiklį nuliu. Tokį skaičių vadiname **pašaline šaknimi**."
        },
        {
          "type": "method",
          "title": "Kaip išvengti pašalinių šaknų?",
          "text": "1. Prieš spręsdami lygtį, prilyginkite visus vardiklius nuliui.\n2. Raskite $x$ reikšmes, kurios vardiklį paverčia nuliu.\n3. Užrašykite LRA: $x$ gali būti bet koks, išskyrus tas rastas reikšmes.\n4. Išsprendę lygtį, visada patikrinkite, ar gauti atsakymai priklauso LRA."
        }
      ]
    },
    {
      "id": "racionaliosios-lygtys-algoritmas",
      "title": "3. Sprendimo algoritmas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Yra du pagrindiniai trupmeninių lygčių sprendimo būdai."
        },
        {
          "type": "method",
          "title": "Būdas A: Dauginimas iš MBV",
          "text": "1. Perkelkite visus lygties narius į vieną pusę (kad kitoje liktų nulis).\n2. Raskite bendrąjį vardiklį (MBV).\n3. Padauginkite visą lygtį iš šio vardiklio (taip jį panaikinsite).\n4. Išspręskite gautą sveikąją (dažniausiai tiesinę arba kvadratinę) lygtį.\n5. Atmeskite pašalines šaknis."
        },
        {
          "type": "method",
          "title": "Būdas B: Proporcijos savybė",
          "text": "Jei lygtis turi pavidalą $\\frac{A}{B} = \\frac{C}{D}$, galime taikyti „kryžminę daugybą“: $A \\cdot D = B \\cdot C$."
        },
        {
          "type": "formula",
          "formulaId": "proporcijos-formule",
          "latex": "\\frac{a}{b} = \\frac{c}{d} \\Rightarrow ad = bc \\quad (b, d \\neq 0)"
        }
      ]
    },
    {
      "id": "racionaliosios-lygtys-klaidos",
      "title": "4. Dažnos klaidos",
      "blocks": [
        {
          "type": "warning",
          "text": "Daugindami iš MBV, mokiniai dažnai pamiršta padauginti skaičius, kurie neturi vardiklio (pvz., jei lygybėje yra $+ 1$)."
        },
        {
          "type": "warning",
          "text": "Ženklų klaidos: Jei prieš trupmeną yra minusas, jis pakeičia visų skaitiklio narių ženklus, kai vardiklis panaikinamas."
        },
        {
          "type": "warning",
          "text": "Vardiklio „pametimas“ be LRA: Niekada nepanaikinkite vardiklio, kol neužrašėte, kad jis nelygus nuliui!"
        }
      ]
    }
  ],
  "workedExamples": [
    {
      "id": "rac-lyg-ex-1",
      "title": "Paprasta racionalioji lygtis",
      "level": "easy",
      "problem": "Išspręskite lygtį: $\\frac{x - 3}{x + 5} = 0$.",
      "conceptIds": [
        "trupmenine-racionalioji-lygtis"
      ],
      "formulaIds": [
        "trupmenos-lygybe-nuliui"
      ],
      "steps": [
        {
          "text": "Nustatome LRA: vardiklis nelygus nuliui.",
          "latex": "x + 5 \\neq 0 \\Rightarrow x \\neq -5"
        },
        {
          "text": "Trupmena lygi nuliui, kai jos skaitiklis lygus nuliui.",
          "latex": "x - 3 = 0"
        },
        {
          "text": "Išsprendžiame.",
          "latex": "x = 3"
        },
        {
          "text": "Tikriname LRA: 3 != -5. Atsakymas tinka.",
          "latex": "3 \\in \\text{LRA}"
        }
      ],
      "answer": "3"
    },
    {
      "id": "rac-lyg-ex-2",
      "title": "Proporcijos būdas",
      "level": "easy",
      "problem": "Išspręskite: $\\frac{2}{x} = \\frac{5}{x + 3}$.",
      "conceptIds": [
        "proporcijos-savybe"
      ],
      "formulaIds": [
        "proporcijos-formule"
      ],
      "steps": [
        {
          "text": "LRA: x != 0 ir x != -3.",
          "latex": "x \\in \\mathbb{R} \\setminus \\{0; -3\\}"
        },
        {
          "text": "Taikome proporcijos savybę (dauginame kryžmai).",
          "latex": "2(x + 3) = 5x"
        },
        {
          "text": "Atskliaudžiame ir sutvarkome.",
          "latex": "2x + 6 = 5x \\Rightarrow 3x = 6 \\Rightarrow x = 2"
        },
        {
          "text": "Sprendinys priklauso LRA.",
          "latex": "2 \\in \\text{LRA}"
        }
      ],
      "answer": "2"
    },
    {
      "id": "rac-lyg-ex-3",
      "title": "Dauginimas iš MBV",
      "level": "medium",
      "problem": "Išspręskite: $1 + \\frac{1}{x} = \\frac{2}{x^2}$.",
      "conceptIds": [
        "bendravardiklinimas-lygtyse"
      ],
      "steps": [
        {
          "text": "LRA: x != 0.",
          "latex": "x \\neq 0"
        },
        {
          "text": "Bendras vardiklis yra x² . Dauginame visus narius iš x².",
          "latex": "1 \\cdot x^2 + \\frac{1}{x} \\cdot x^2 = \\frac{2}{x^2} \\cdot x^2"
        },
        {
          "text": "Gauname kvadratinę lygtį.",
          "latex": "x^2 + x = 2 \\Rightarrow x^2 + x - 2 = 0"
        },
        {
          "text": "Randame šaknis pagal Vietą.",
          "latex": "x_1 = 1, \\quad x_2 = -2"
        },
        {
          "text": "Abidvi reikšmės tinka, nes nelygios 0.",
          "latex": "1; -2"
        }
      ],
      "answer": "1; -2"
    },
    {
      "id": "rac-lyg-ex-4",
      "title": "Pašalinė šaknis",
      "level": "medium",
      "problem": "Išspręskite: $\\frac{x^2}{x - 4} = \\frac{16}{x - 4}$.",
      "conceptIds": [
        "pasaline-saknis"
      ],
      "steps": [
        {
          "text": "LRA: x != 4.",
          "latex": "x \\neq 4"
        },
        {
          "text": "Kadangi vardikliai vienodi, sulyginame skaitiklius.",
          "latex": "x^2 = 16"
        },
        {
          "text": "Randame šaknis.",
          "latex": "x_1 = 4, \\quad x_2 = -4"
        },
        {
          "text": "Tikriname su LRA. Reikšmė x = 4 yra pašalinė šaknis.",
          "latex": "x = 4 \\notin \\text{LRA}"
        }
      ],
      "answer": "-4"
    },
    {
      "id": "rac-lyg-ex-5",
      "title": "Sudėtingesnis vardiklis",
      "level": "hard",
      "problem": "Išspręskite: $\\frac{x}{x-2} - \\frac{2}{x+2} = \\frac{8}{x^2-4}$.",
      "conceptIds": [
        "skaidymas-dauginamaisiais"
      ],
      "steps": [
        {
          "text": "Išskaidome vardiklį: x²-4 = (x-2)(x+2). LRA: x != 2, x != -2.",
          "latex": "x \\in \\mathbb{R} \\setminus \\{2; -2\\}"
        },
        {
          "text": "Dauginame iš MBV = (x-2)(x+2).",
          "latex": "x(x+2) - 2(x-2) = 8"
        },
        {
          "text": "Tvarkome lygtį.",
          "latex": "x^2 + 2x - 2x + 4 = 8 \\Rightarrow x^2 + 4 = 8 \\Rightarrow x^2 = 4"
        },
        {
          "text": "Šaknys: x = 2 arba x = -2.",
          "latex": "x = \\pm 2"
        },
        {
          "text": "Palyginame su LRA. Abi reikšmės uždraustos!",
          "latex": "x \\in \\emptyset"
        }
      ],
      "answer": "Sprendinių nėra."
    },
    {
      "id": "rac-lyg-ex-6",
      "title": "Lygtis su laisvuoju nariu",
      "level": "medium",
      "problem": "Išspręskite: $\\frac{6}{x} = x + 1$.",
      "conceptIds": [
        "bendravardiklinimas-lygtyse"
      ],
      "steps": [
        {
          "text": "LRA: x != 0. Dauginame viską iš x.",
          "latex": "6 = x(x + 1)"
        },
        {
          "text": "Sudarome kvadratinę lygtį.",
          "latex": "x^2 + x - 6 = 0"
        },
        {
          "text": "Randame šaknis.",
          "latex": "x_1 = 2, \\quad x_2 = -3"
        }
      ],
      "answer": "2; -3"
    },
    {
      "id": "rac-lyg-ex-7",
      "title": "Darbo uždavinys (Modeliavimas)",
      "level": "hard",
      "problem": "Vienas vamzdis pripildo baseiną 3 valandomis greičiau nei kitas. Abu vamzdžiai kartu baseiną pripildo per 2 valandas. Per kiek laiko pripildytų baseiną pirmasis vamzdis?",
      "conceptIds": [
        "trupmenine-racionalioji-lygtis"
      ],
      "steps": [
        {
          "text": "Tegul pirmas vamzdis užtrunka x valandų, antras - (x+3) valandų. Per 1h pirmas pripildo 1/x dalį, antras 1/(x+3), kartu - 1/2.",
          "latex": "\\frac{1}{x} + \\frac{1}{x+3} = \\frac{1}{2}"
        },
        {
          "text": "LRA: x > 0. Dauginame iš MBV = 2x(x+3).",
          "latex": "2(x+3) + 2x = x(x+3)"
        },
        {
          "text": "Tvarkome: 2x + 6 + 2x = x² + 3x => x² - x - 6 = 0.",
          "latex": "x^2 - x - 6 = 0"
        },
        {
          "text": "Šaknys: x = 3 arba x = -2. Kadangi laikas teigiamas, x = 3.",
          "latex": "x = 3"
        }
      ],
      "answer": "3 valandos."
    },
    {
      "id": "rac-lyg-ex-8",
      "title": "Greičio uždavinys",
      "level": "hard",
      "problem": "Kateris nuplaukė 24 km pasroviui ir grįžo atgal užtrukęs 5 valandas. Upės tėkmės greitis 2 km/h. Raskite katerio greitį stovinčiame vandenyje.",
      "conceptIds": [
        "trupmenine-racionalioji-lygtis"
      ],
      "steps": [
        {
          "text": "Tegul v - katerio greitis. Pasroviui greitis v+2, prieš srovę v-2. Bendras laikas: t1 + t2 = 5.",
          "latex": "\\frac{24}{v+2} + \\frac{24}{v-2} = 5"
        },
        {
          "text": "LRA: v > 2. Dauginame iš (v+2)(v-2).",
          "latex": "24(v-2) + 24(v+2) = 5(v^2 - 4)"
        },
        {
          "text": "24v - 48 + 24v + 48 = 5v² - 20 => 5v² - 48v - 20 = 0.",
          "latex": "5v^2 - 48v - 20 = 0"
        },
        {
          "text": "Diskriminantas: D = 2304 + 400 = 2704. √D = 52. v = (48+52)/10 = 10.",
          "latex": "v = 10"
        }
      ],
      "answer": "10 km/h."
    }
  ],
