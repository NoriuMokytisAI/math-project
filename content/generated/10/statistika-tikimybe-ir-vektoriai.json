  "theory": [
    {
      "id": "statistika-tikimybe-ir-vektoriai-ivadas",
      "title": "Įvadas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Statistika, tikimybė ir duomenų analizė yra tema, kurioje mokomasi atpažinti pagrindinius statistika ir tikimybė modelius ir juos taikyti skaičiavimuose, tekste bei brėžiniuose."
        },
        {
          "type": "paragraph",
          "text": "Šioje temoje svarbiausia nuolat matyti ryšį tarp sąvokų [[duomenys|Duomenys]], [[imtis|Imtis]], [[daznis|Dažnis]] ir uždavinių sprendimo."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-svarbiausios-savokos",
      "title": "Svarbiausios sąvokos",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "duomenys",
          "text": "Stebėjimų arba matavimų rinkinys."
        },
        {
          "type": "definition",
          "conceptId": "imtis",
          "text": "Duomenų dalis, naudojama tiriamam reiškiniui."
        },
        {
          "type": "definition",
          "conceptId": "daznis",
          "text": "Kiek kartų reikšmė pasikartoja."
        },
        {
          "type": "note",
          "text": "Jei sprendžiant kyla abejonė, pirmiausia tikrink, ar aiškiai supranti [[duomenys|Duomenys]] ir [[vidurkis|Vidurkis]]."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-taisyklės",
      "title": "Svarbiausios taisyklės",
      "blocks": [
        {
          "type": "theorem",
          "text": "Statistika, tikimybė ir duomenų analizė sprendimuose visada pirmiausia atskirk duomenis nuo ieškomo dydžio, o tada pasirink tinkamą modelį."
        },
        {
          "type": "property",
          "text": "Jei užduotyje pasirodo [[daznis|Dažnis]] ar [[vidurkis|Vidurkis]], dažnai verta rašyti ryšį simboliais prieš skaičiuojant."
        },
        {
          "type": "formula",
          "formulaId": "vidurkio-formule",
          "latex": "\\bar{x}=\\frac{x_1+\\cdots+x_n}{n}"
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-strategija",
      "title": "Sprendimo strategija",
      "blocks": [
        {
          "type": "method",
          "text": "1. Perskaityk užduotį ir pažymėk, kokie dydžiai žinomi. 2. Nustatyk, kuri sąvoka čia svarbiausia. 3. Užrašyk veiksmus arba ryšį. 4. Patikrink rezultatą kitaip arba atgaliniu skaičiavimu."
        },
        {
          "type": "warning",
          "text": "Dažna klaida yra imti skaičiuoti per anksti ir neįvardyti, ką reiškia gauta reikšmė."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-rysys",
      "title": "Ryšys su kitomis temomis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Ši tema remiasi ankstesnėmis žiniomis iš kitų metų: skaičiavimu, reiškinių pertvarkymu, figūrų savybėmis ar duomenų skaitymu. Ji ruošia kelią tolimesnėms temoms, kuriose reikia daugiau bendro modelio ir tikslesnio argumentavimo."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-gilinimas-prasme",
      "title": "Gilesnis temos vaizdas: ką čia iš tikrųjų mokomės",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Tema „Statistika, tikimybė ir duomenų analizė“ 10 klasės kurse priklauso sričiai „Duomenys ir tikimybės“, todėl jos tikslas nėra vien išmokti vieną taisyklę. Reikia pamatyti, kokį matematinį ryšį ši tema aprašo, kada jį galima taikyti ir kaip atpažinti situacijas, kuriose tas pats ryšys pasirodo kita forma. Mokantis verta pradėti nuo paprasto klausimo: kokie dydžiai čia kinta, kas lieka pastovu ir kokios sąlygos riboja galimus veiksmus? Kai šis klausimas atsakytas, formulės tampa ne atskirais sakiniais, o trumpu ryšių užrašu."
        },
        {
          "type": "note",
          "text": "Šią temą patogu skaityti per tokį objektyvą: duomenų rinkinio struktūra, skaitinės charakteristikos, tikimybės modelis ir išvadų patikimumas. Jei mokinys geba tą patį ryšį paaiškinti žodžiais, parodyti pavyzdyje ir patikrinti skaičiavimu, jis jau turi tvirtą pagrindą pereiti prie įvairesnių uždavinių."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-gilinimas-savokos",
      "title": "Sąvokų ryšiai ir minimalus žinių žemėlapis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Svarbiausios sąvokos: Duomenys, Imtis, Dažnis, Vidurkis, Mediana, Moda ir Sklaida. Mokantis verta prie kiekvienos sąvokos prisirašyti po vieną pavyzdį, vieną ne pavyzdį ir vieną tipinę klaidą; taip žodynas virsta sprendimo įrankiu, o ne atmintinai išmoktu sąrašu."
        },
        {
          "type": "method",
          "text": "Mokantis temos „Statistika, tikimybė ir duomenų analizė“ naudinga susirašyti tris stulpelius: sąvoka, kaip ją atpažįstu uždavinio tekste, ir kokį veiksmą ji dažniausiai leidžia atlikti. Pavyzdžiui, jei sąlygoje atsiranda apribojimas, jis dažnai lemia apibrėžimo sritį, galimus atvejus arba tikrinimo žingsnį. Jei atsiranda santykis, ieškome proporcijos, mastelio, vieneto dalies arba lygiaverčio reiškinio. Toks žemėlapis sumažina spėliojimą ir padeda spręsti net tada, kai uždavinio formuluotė nėra pažįstama."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-gilinimas-metodas",
      "title": "Sprendimo metodas nuo sąlygos iki atsakymo",
      "blocks": [
        {
          "type": "method",
          "text": "Atskirk duomenų aprašymą nuo išvados. Pirmiausia susitvarkyk lentelę ar diagramą, tada skaičiuok vidurkį, medianą, kvartilius, dažnius arba tikimybes. Jei yra imtis, visada paklausk, ką galima teigti apie imtį ir ko dar negalima tvirtai perkelti visai populiacijai."
        },
        {
          "type": "paragraph",
          "text": "Praktikoje tai reiškia, kad pirmas sprendimo veiksmas neturėtų būti aklas skaičiavimas. Pirmiausia perrašyk sąlygą matematiškai: pažymėk nežinomuosius, užrašyk duotus dydžius, išskirk apribojimus ir nuspręsk, kokio tipo atsakymo reikia. Tada rinkis vieną pagrindinį kelią ir jo laikykis iki pat patikros. Jei kelias stringa, neperrašinėk visko iš naujo: grįžk į sąlygą ir paklausk, kuri informacija dar nepanaudota. Dažnai būtent nepanaudota sąlygos dalis parodo trūkstamą žingsnį."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-gilinimas-pavyzdziai",
      "title": "Kaip skaityti pavyzdžius ir perkelti metodą",
      "blocks": [
        {
          "type": "example",
          "text": "Tipinis šios temos uždavinio sakinys gali atrodyti taip: „Rask skaičių 4, 6, 8 vidurkį.“. Skaitydamas tokį sakinį pirmiausia pabrauk duotus duomenis, tada atskirai pasižymėk, ko prašoma. Jeigu uždavinys turi kelis sakinius, paskutinis sakinys dažnai nusako tikslą, o ankstesni sakiniai pateikia sąlygas, kurias reikia paversti lygtimi, brėžiniu, lentele arba atvejų sistema."
        },
        {
          "type": "note",
          "text": "Vienas iš geriausių būdų mokytis yra po išspręsto pavyzdžio pakeisti vieną skaičių, vieną sąlygą arba klausimą ir pabandyti išspręsti dar kartą. Jei metodas sugriūva nuo mažo pakeitimo, vadinasi, buvo įsiminta forma, bet dar ne suprastas ryšys."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-gilinimas-klaidos",
      "title": "Savikontrolė, klaidos ir pasiruošimas pratimams",
      "blocks": [
        {
          "type": "warning",
          "text": "Patikrink matavimo vienetus, bendrą dažnių sumą, tikimybių sumą ir tai, ar pasirinkta charakteristika tikrai atsako į klausimą. Dažna klaida šioje temoje yra praleisti paskutinį patikrinimą, nes tarpiniai veiksmai atrodo logiški. Vis dėlto net teisingas pertvarkymas gali duoti netinkamą atsakymą, jei nepaisyta sąlygos apribojimų arba supainiota, ką reiškia gautas dydis."
        },
        {
          "type": "paragraph",
          "text": "Prieš pereidamas prie sunkių uždavinių, mokinys turėtų gebėti atlikti tris veiksmus: savais žodžiais paaiškinti temą „Statistika, tikimybė ir duomenų analizė“, išspręsti paprastą tiesioginį uždavinį be užuominų ir ištaisyti bent vieną sąmoningai padarytą klaidą. Tik tada verta didinti uždavinių įvairovę, nes įvairovė be pagrindo dažnai sukuria triukšmą, o ne meistriškumą."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-gilinimas-papildomas-praktine-schema-1",
      "title": "Praktinė sprendimo schema",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Temoje „Statistika, tikimybė ir duomenų analizė“ mokymasis tampa tvirtas tada, kai mokinys geba atpažinti tą pačią idėją skirtinguose formatuose: žodiniame uždavinyje, lentelėje, formulėje, brėžinyje arba teste. Jeigu sąlyga skamba taip: „Rask skaičių 4, 6, 8 vidurkį.“, pirmiausia reikia ne skaičiuoti, o nuspręsti, kokią informaciją ji duoda. Tada pasirenkamas metodas: Atskirk duomenų aprašymą nuo išvados. Pirmiausia susitvarkyk lentelę ar diagramą, tada skaičiuok vidurkį, medianą, kvartilius, dažnius arba tikimybes. Jei yra imtis, visada paklausk, ką galima teigti apie imtį ir ko dar negalima tvirtai perkelti visai populiacijai. Galiausiai atsakymas tikrinamas ne iš atminties, o pagal pradinę sąlygą. Taip išvengiama situacijos, kai veiksmai atlikti teisingai, bet sprendžiamas ne tas klausimas."
        },
        {
          "type": "note",
          "text": "Savikontrolė: Patikrink matavimo vienetus, bendrą dažnių sumą, tikimybių sumą ir tai, ar pasirinkta charakteristika tikrai atsako į klausimą."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-gilinimas-papildomas-klaidu-diagnostika-2",
      "title": "Klaidų diagnostika ir taisymas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Jei šioje temoje atsakymas nesutampa, klaidą verta ieškoti tvarkingai. Pirmas žingsnis yra patikrinti sąvokas: Duomenys, Imtis, Dažnis, Vidurkis, Mediana. Antras žingsnis yra patikrinti apribojimus ir vienetus. Trečias žingsnis yra peržiūrėti, ar kiekvienas pertvarkymas tikrai leistinas. Temai „Statistika, tikimybė ir duomenų analizė“ ypač naudinga po kiekvieno neteisingo bandymo parašyti vieną sakinį: „Suklydau todėl, kad...“. Toks sakinys vėliau gali tapti SRS kortele ir padeda nebekartoti tos pačios klaidos naujame uždavinyje."
        },
        {
          "type": "note",
          "text": "Savikontrolė: Patikrink matavimo vienetus, bendrą dažnių sumą, tikimybių sumą ir tai, ar pasirinkta charakteristika tikrai atsako į klausimą."
        }
      ]
    },
    {
      "id": "statistika-tikimybe-ir-vektoriai-gilinimas-papildomas-perkelimas-3",
      "title": "Metodo perkėlimas į naujus uždavinius",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Vienas iš brandžios temos požymių yra gebėjimas sukurti naują pavyzdį. Išsprendus uždavinį iš temos „Statistika, tikimybė ir duomenų analizė“, pakeisk vieną duomenį, vieną apribojimą arba klausimą ir stebėk, kas pasikeičia. Jei sprendimo struktūra išlieka, vadinasi, supratai metodą. Jei viskas sugriūva, verta grįžti prie sąvokų ir paklausti, kuri jų buvo būtina. Šitaip teorija natūraliai pereina į didelį kiekį įvairių pratimų: ne mechaniškai, o remiantis aiškiu žinių žemėlapiu."
        },
        {
          "type": "note",
          "text": "Savikontrolė: Patikrink matavimo vienetus, bendrą dažnių sumą, tikimybių sumą ir tai, ar pasirinkta charakteristika tikrai atsako į klausimą."
        }
      ]
    }
  ],
