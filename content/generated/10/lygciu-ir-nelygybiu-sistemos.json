      "title": "Tiesė ir Parabolė (2 taškai)",
      "level": "easy",
      "problem": "Išspręskite sistemą: $\\begin{cases} y = x^2 - 4 \\\\ y = x + 2 \\end{cases}$",
      "conceptIds": [
        "nelinearine-lygciu-sistema"
      ],
      "steps": [
        {
          "text": "Sulyginame y išraiškas.",
          "latex": "x^2 - 4 = x + 2"
        },
        {
          "text": "Perkeliame viską į kairę pusę.",
          "latex": "x^2 - x - 6 = 0"
        },
        {
          "text": "Randame šaknis (pagal Vietą).",
          "latex": "x_1 = 3, \\quad x_2 = -2"
        },
        {
          "text": "Apskaičiuojame y įstatydami į tiesės lygtį.",
          "latex": "y_1 = 3 + 2 = 5; \\quad y_2 = -2 + 2 = 0"
        }
      ],
      "answer": "(3; 5) ir (-2; 0)"
    },
    {
      "id": "sistemos-exmp-2",
      "title": "Sistemos liestinė (1 taškas)",
      "level": "medium",
      "problem": "Išspręskite: $\\begin{cases} y = x^2 + 1 \\\\ y = 2x \\end{cases}$",
      "conceptIds": [
        "nelinearine-lygciu-sistema"
      ],
      "steps": [
        {
          "text": "Sulyginame.",
          "latex": "x^2 + 1 = 2x \\Rightarrow x^2 - 2x + 1 = 0"
        },
        {
          "text": "Atpažįstame pilną kvadratą.",
          "latex": "(x - 1)^2 = 0 \\Rightarrow x = 1"
        },
        {
          "text": "Randame y.",
          "latex": "y = 2(1) = 2"
        }
      ],
      "answer": "(1; 2)"
    },
    {
