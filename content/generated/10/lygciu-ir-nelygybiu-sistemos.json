  "theory": [
    {
      "id": "lygciu-ir-nelygybiu-sistemos-ivadas",
      "title": "Įvadas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Lygčių ir nelygybių sistemos yra tema, kurioje mokomasi atpažinti pagrindinius sistemos ir modeliavimas modelius ir juos taikyti skaičiavimuose, tekste bei brėžiniuose."
        },
        {
          "type": "paragraph",
          "text": "Šioje temoje svarbiausia nuolat matyti ryšį tarp sąvokų [[lygtis|Lygtis]], [[nelygybe|Nelygybė]], [[sprendinys|Sprendinys]] ir uždavinių sprendimo."
        }
      ]
    },
    {
      "id": "lygciu-ir-nelygybiu-sistemos-svarbiausios-savokos",
      "title": "Svarbiausios sąvokos",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "lygtis",
          "text": "Lygybė su nežinomuoju."
        },
        {
          "type": "definition",
          "conceptId": "nelygybe",
          "text": "Ryšys su <, >, <= arba >=."
        },
        {
          "type": "definition",
          "conceptId": "sprendinys",
          "text": "Reikšmė, tenkinanti lygtį."
        },
        {
          "type": "note",
          "text": "Jei sprendžiant kyla abejonė, pirmiausia tikrink, ar aiškiai supranti [[lygtis|Lygtis]] ir [[sistema|Sistema]]."
        }
      ]
    },
    {
      "id": "lygciu-ir-nelygybiu-sistemos-taisyklės",
      "title": "Svarbiausios taisyklės",
      "blocks": [
        {
          "type": "theorem",
          "text": "Lygčių ir nelygybių sistemos sprendimuose visada pirmiausia atskirk duomenis nuo ieškomo dydžio, o tada pasirink tinkamą modelį."
        },
        {
          "type": "property",
          "text": "Jei užduotyje pasirodo [[sprendinys|Sprendinys]] ar [[sistema|Sistema]], dažnai verta rašyti ryšį simboliais prieš skaičiuojant."
        },
        {
          "type": "formula",
          "formulaId": "tiesines-sistemos-bendrumas",
          "latex": "\\begin{cases} ax+by=c \\\\ dx+ey=f \\end{cases}"
        }
      ]
    },
    {
      "id": "lygciu-ir-nelygybiu-sistemos-strategija",
      "title": "Sprendimo strategija",
      "blocks": [
        {
          "type": "method",
          "text": "1. Perskaityk užduotį ir pažymėk, kokie dydžiai žinomi. 2. Nustatyk, kuri sąvoka čia svarbiausia. 3. Užrašyk veiksmus arba ryšį. 4. Patikrink rezultatą kitaip arba atgaliniu skaičiavimu."
        },
        {
          "type": "warning",
          "text": "Dažna klaida yra imti skaičiuoti per anksti ir neįvardyti, ką reiškia gauta reikšmė."
        }
      ]
    },
    {
      "id": "lygciu-ir-nelygybiu-sistemos-rysys",
      "title": "Ryšys su kitomis temomis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Ši tema remiasi ankstesnėmis žiniomis iš kitų metų: skaičiavimu, reiškinių pertvarkymu, figūrų savybėmis ar duomenų skaitymu. Ji ruošia kelią tolimesnėms temoms, kuriose reikia daugiau bendro modelio ir tikslesnio argumentavimo."
        }
      ]
    }
  ],
