      "title": "Apskritimas ir tiesė",
      "level": "hard",
      "problem": "Išspręskite: $\\begin{cases} x^2 + y^2 = 25 \\\\ y = x - 7 \\end{cases}$",
      "conceptIds": [
        "nelinearine-lygciu-sistema"
      ],
      "steps": [
        {
          "text": "Įstatome y išraišką į pirmą lygtį.",
          "latex": "x^2 + (x - 7)^2 = 25"
        },
        {
          "text": "Atskliaudžiame.",
          "latex": "x^2 + x^2 - 14x + 49 = 25"
        },
        {
          "text": "Sutvarkome lygtį.",
          "latex": "2x^2 - 14x + 24 = 0 \\Rightarrow x^2 - 7x + 12 = 0"
        },
        {
          "text": "Šaknys: x1 = 3, x2 = 4.",
          "latex": "y_1 = 3 - 7 = -4; \\quad y_2 = 4 - 7 = -3"
        }
      ],
      "answer": "(3; -4) ir (4; -3)"
    },
