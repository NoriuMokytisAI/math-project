      "statement": "Kokia yra tiksli $\\frac{1}{\\phi}$ reikšmė?",
      "answer": {
        "kind": "choice",
        "choices": [
          {
            "id": "a",
            "text": "$\\phi + 1$"
          },
          {
            "id": "b",
            "text": "$\\phi - 1$"
          },
          {
            "id": "c",
            "text": "$\\phi$"
          },
          {
            "id": "d",
            "text": "$1 - \\phi$"
          }
        ],
        "correctChoiceIds": [
          "b"
        ]
      },
      "hints": [
        {
          "order": 1,
          "text": "Naudokite $\\phi^2 = \\phi + 1$. Padalinkite iš $\\phi$.",
          "penalty": 0.1
        }
      ],
      "solutionSteps": [
        {
          "text": "$\\phi^2 = \\phi + 1 \\implies \\phi = 1 + \\frac{1}{\\phi} \\implies \\frac{1}{\\phi} = \\phi - 1$."
        }
      ],
      "conceptIds": [],
      "estimatedSeconds": 60,
      "answerText": "Correct choice"
