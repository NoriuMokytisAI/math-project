  "theory": [
    {
      "id": "fibonacio-seka-ivadas",
      "title": "Fibonačio seka",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Fibonačio seka yra viena garsiausių matematinių sekų, kurioje kiekvienas narys (nuo trečiojo) yra lygus dviejų prieš jį einančių narių sumai."
        },
        {
          "type": "definition",
          "conceptId": "fibonacio-seka",
          "text": "Seka $1, 1, 2, 3, 5, 8, 13, 21, ...$, kurioje $F_1=1$, $F_2=1$ ir $F_n = F_{n-1} + F_{n-2}$."
        },
        {
          "type": "note",
          "text": "Kartais seka pradedama nuo 0, bet mokyklinėje programoje dažniausiai nuo 1."
        }
      ]
    },
    {
      "id": "aukso-pjuvis-ivadas",
      "title": "Aukso pjūvis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Aukso pjūvis (arba dieviškoji proporcija) yra toks atkarpos padalijimas į dvi dalis, kai ilgesnės dalies santykis su trumpesne yra lygus visos atkarpos santykiui su ilgesne dalimi."
        },
        {
          "type": "formula",
          "formulaId": "aukso-pjuvio-reiksme",
          "latex": "\\phi = \\frac{1 + \\sqrt{5}}{2} \\approx 1,618"
        },
        {
          "type": "paragraph",
          "text": "Šis skaičius žymimas graikiška raide $\\phi$ (fi)."
        }
      ]
    },
    {
      "id": "fibonacio-ir-aukso-pjuvio-rysys",
      "title": "Fibonačio sekos ir Aukso pjūvio ryšys",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Didėjant narių skaičiui, dviejų gretimų Fibonačio sekos narių santykis $\\frac{F_{n+1}}{F_n}$ artėja prie aukso pjūvio reikšmės $\\phi$."
        },
        {
          "type": "method",
          "text": "Aukso pjūvio seką sudaro laipsniai: $\\phi, \\phi^2, \\phi^3, ...$, kur kiekvienas narys taip pat tenkina sąryšį $\\phi^n = \\phi^{n-1} + \\phi^{n-2}$."
        }
      ]
    },
    {
      "id": "proporcingoji-dalyba",
      "title": "Proporcingoji dalyba",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Dažnai uždaviniuose reikia padalinti skaičių ar dydį į dalis, kurios būtų proporcingos tam tikriems skaičiams."
        },
        {
          "type": "definition",
          "conceptId": "proporcingoji-dalyba",
          "text": "Dydžio padalijimas į dalis pagal santykį $a:b:c$."
        }
      ]
    }
  ],
