  "theory": [
    {
      "title": "Aukštesnioji liekanų teorija",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Skaičių teorijoje 10 klasėje gilinamės į liekanų savybes, naudodami Mažąją Fermo teoremą ir Oilerio teoremą. Jos leidžia efektyviai skaičiuoti didelių laipsnių liekanas."
        },
        {
          "type": "method",
          "text": "Naudokite Kinų liekanų teoremą (CRT), kai reikia rasti skaičių, tenkinantį kelis palyginimus skirtingais moduliais."
        }
      ]
    },
    {
      "title": "Diofanto lygtys ir specialios struktūros",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Diofanto lygtys yra lygtys, kurių sprendinių ieškome sveikųjų skaičių aibėje. Klasikinis pavyzdys yra Pelio lygtis $x^2 - Dy^2 = 1$."
        },
        {
          "type": "paragraph",
          "text": "Gauso sveikieji skaičiai $\\mathbb{Z}[i]$ leidžia spręsti uždavinius apie kvadratų sumas naudojant faktoriavimo metodus."
        }
      ]
    }
  ],
  "concepts": [
    {
      "id": "olimpiada-10-concept-quad-reciprocity",
      "title": "Kvadratinio abipusiškumo dėsnis",
      "type": "concept",
      "shortDefinition": "Ryšys tarp dviejų skirtingų nelyginių pirminių skaičių kvadratinių liekanų savybių.",
      "intuition": "Parodo, ar skaičius yra kvadratinė liekana moduliu $p$ per ryšį su kitu pirminiu skaičiumi $q$.",
      "formal": "Jei $p$ ir $q$ yra skirtingi nelyginiai pirminiai skaičiai, tai $\\left(\\frac{p}{q}\\right)\\left(\\frac{q}{p}\\right) = (-1)^{\\frac{p-1}{2}\\frac{q-1}{2}}$.",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-10-concept-gaussian-integers",
      "title": "Gauso sveikieji skaičiai",
      "type": "concept",
      "shortDefinition": "Kompleksiniai skaičiai, kurių realioji ir tariamoji dalys yra sveikieji skaičiai.",
      "intuition": "Kompleksinių skaičių aibė $\\mathbb{Z}[i]$, kurioje galima atlikti dalybą su liekana ir skaidyti pirminiais daugtuviais.",
      "formal": "Aibė $\\mathbb{Z}[i] = \\{a + bi \\mid a, b \\in \\mathbb{Z}\\}$, kur $i^2 = -1$.",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-10-concept-fermat-little",
      "title": "Mažoji Fermo teorema",
      "type": "concept",
      "shortDefinition": "Nurodo pirminio skaičiaus laipsnio liekaną.",
      "intuition": "Jei $p$ yra pirminis, tai $a^p$ turi tą pačią liekaną kaip $a$ moduliu $p$.",
      "formal": "$a^p \\equiv a \\pmod p$ bet kuriam sveikajam $a$ ir pirminiam $p$.",
      "relatedConceptIds": [
        "olimpiada-10-concept-euler-theorem"
      ]
    },
    {
      "id": "olimpiada-10-concept-euler-theorem",
      "title": "Oilerio teorema",
      "type": "concept",
      "shortDefinition": "Mažosios Fermo teoremos apibendrinimas bet kuriam moduliui.",
      "intuition": "Laipsnis, keliamas funkcijos $\\phi(n)$ reikšme, duoda 1 moduliu $n$.",
      "formal": "Jei $\\text{gcd}(a, n) = 1$, tai $a^{\\phi(n)} \\equiv 1 \\pmod n$.",
      "relatedConceptIds": [
        "olimpiada-10-concept-fermat-little"
      ]
    },
    {
      "id": "olimpiada-10-concept-crt",
      "title": "Kinų liekanų teorema",
      "type": "concept",
      "shortDefinition": "Sprendinių egzistavimo sąlyga palyginimų sistemoms.",
      "intuition": "Jei turime liekanas pagal tarpusavyje pirminius modulius, galime vienareikšmiškai rasti skaičių.",
      "formal": "Sistemai $x \\equiv a_i \\pmod{m_i}$ egzistuoja vienintelis sprendinys moduliu $M = \\prod m_i$, jei visi $m_i$ yra poromis pirminiai.",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-10-concept-diophantine",
      "title": "Diofanto lygtys",
      "type": "concept",
      "shortDefinition": "Lygtys su sveikaisiais kintamaisiais.",
      "intuition": "Lygtys, kurių sprendiniai turi būti sveikieji skaičiai.",
      "formal": "Lygtis $f(x_1, \\dots, x_n) = 0$, kur $x_i \\in \\mathbb{Z}$.",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-10-concept-pell",
      "title": "Pelio lygtis",
      "type": "concept",
      "shortDefinition": "Kvadratinė Diofanto lygtis $x^2 - Dy^2 = 1$.",
      "intuition": "Susijusi su $\\sqrt{D}$ artiniais.",
      "formal": "$x^2 - Dy^2 = 1$, kur $D$ nėra tikslusis kvadratas.",
      "relatedConceptIds": [
        "olimpiada-10-concept-continued-fractions"
      ]
    },
    {
      "id": "olimpiada-10-concept-arithmetic-functions",
      "title": "Aritmetinės funkcijos",
      "type": "concept",
      "shortDefinition": "Funkcijos apibrėžtos natūraliuose skaičiuose.",
      "intuition": "Savybės kaip daliklių skaičius $\\tau(n)$ arba daliklių suma $\\sigma(n)$.",
      "formal": "Funkcija $f: \\mathbb{N} \\to \\mathbb{C}$. Dažnai multiplikatyvi.",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-10-concept-continued-fractions",
      "title": "Grandininės trupmenos",
      "type": "concept",
      "shortDefinition": "Skaičiaus išraiška per sveikųjų dalių seką.",
      "intuition": "Būdas gauti geriausius racionaliuosius artinius realiam skaičiui.",
      "formal": "$a_0 + 1/(a_1 + 1/(a_2 + \\dots))$.",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-10-concept-lte",
      "title": "Lifting the Exponent (LTE) lema",
      "type": "concept",
      "shortDefinition": "Pirminio skaičiaus laipsnio radimas reiškiniuose $a^n - b^n$.",
      "intuition": "Leidžia tiksliai pasakyti, kiek kartu pirminis $p$ įeina į $a^n - b^n$ skaidinį.",
      "formal": "$v_p(a^n - b^n) = v_p(a-b) + v_p(n)$ tam tikromis sąlygomis.",
      "relatedConceptIds": []
    }
  ],
