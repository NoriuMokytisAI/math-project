  "theory": [
    {
      "id": "daugiakampiai-ivadas",
      "title": "Įbrėžtiniai ir apibrėžtiniai daugiakampiai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Daugiakampis vadinamas [[ibreztinis-daugiakampis|įbrėžtiniu]] į apskritimą, jei visos jo viršūnės priklauso apskritimui. Daugiakampis vadinamas [[apibreztinis-daugiakampis|apibrėžtiniu]] apie apskritimą, jei visos jo kraštinės liečia apskritimą."
        },
        {
          "type": "note",
          "text": "Apie kiekvieną trikampį galima apibrėžti apskritimą ir į kiekvieną trikampį galima įbrėžti apskritimą."
        }
      ]
    },
    {
      "id": "trikampio-apskritimu-centrai",
      "title": "Apskritimų centrai",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "ibreztinio-apskritimo-centras",
          "text": "Į trikampį įbrėžto apskritimo centras yra jo [[pusiaukampine|pusiaukampinių]] susikirtimo taškas."
        },
        {
          "type": "definition",
          "conceptId": "apibreztinio-apskritimo-centras",
          "text": "Apie trikampį apibrėžto apskritimo centras yra jo kraštinių vidurio statmenų susikirtimo taškas."
        }
      ]
    },
    {
      "id": "keturkampiu-savybes",
      "title": "Įbrėžtiniai ir apibrėžtiniai keturkampiai",
      "blocks": [
        {
          "type": "property",
          "conceptId": "ibreztinis-keturkampis",
          "text": "Keturkampį galima įbrėžti į apskritimą tada ir tik tada, kai jo priešingų kampų suma lygi $180^\\circ$."
        },
        {
          "type": "property",
          "conceptId": "apibreztinis-keturkampis",
          "text": "Keturkampį galima apibrėžti apie apskritimą tada ir tik tada, kai jo priešingų kraštinių ilgių sumos yra lygios."
        }
      ]
    },
    {
      "id": "ploto-formules-su-spinduliais",
      "title": "Ploto formulės su spinduliais",
      "blocks": [
        {
          "type": "formula",
          "formulaId": "trikampio-ploto-r-formule",
          "latex": "S = p \\cdot r",
          "text": "Čia $p$ yra pusperimetris, $r$ – įbrėžtinio apskritimo spindulys."
        },
        {
          "type": "formula",
          "formulaId": "trikampio-ploto-R-formule",
          "latex": "S = \\frac{abc}{4R}",
          "text": "Čia $a, b, c$ – kraštinės, $R$ – apibrėžtinio apskritimo spindulys."
        }
      ]
    }
  ],
