      "id": "trikampis-r-example-1",
      "title": "Įbrėžtinio spindulio radimas",
      "level": "easy",
      "problem": "Trikampio kraštinės yra 3, 4, 5. Raskite įbrėžtinio apskritimo spindulį.",
      "conceptIds": [
        "ibreztinis-apskritimas",
        "trikampio-ploto-r-formule"
      ],
      "steps": [
        {
          "text": "Trikampis yra status, nes $3^2 + 4^2 = 5^2$.",
          "latex": "S = \\frac{3 \\cdot 4}{2} = 6"
        },
        {
          "text": "Randame pusperimetrį p.",
          "latex": "p = \\frac{3+4+5}{2} = 6"
        },
        {
          "text": "Naudojame formulę S = p * r.",
          "latex": "6 = 6 \\cdot r \\implies r = 1"
        }
      ],
      "answer": "1"
    },
