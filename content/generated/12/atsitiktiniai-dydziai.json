  "formulas": [
    {
      "id": "matematines-vilties-formule",
      "title": "Matematinės vilties formulė",
      "latex": "E(X) = x_1 p_1 + x_2 p_2 + \\dots + x_n p_n",
      "conditions": [
        "X yra diskretusis atsitiktinis dydis"
      ],
      "variables": {
        "xi": "galimos reikšmės",
        "pi": "reikšmių tikimybės"
      },
      "explanation": "Sudauginame kiekvieną reikšmę su jos tikimybe ir viską sudedame.",
      "relatedConceptIds": [
        "matematine-viltis"
      ],
      "defaultSrs": true
    },
    {
      "id": "dispersijos-formule",
      "title": "Dispersijos formulė",
      "latex": "Var(X) = E(X^2) - (E(X))^2",
      "conditions": [
        "E(X) jau žinoma"
      ],
      "variables": {
        "E(X^2)": "reikšmių kvadratų matematinė viltis"
      },
      "explanation": "Patogiausia formulė dispersijai skaičiuoti praktikoje.",
      "relatedConceptIds": [
        "dispersija"
      ],
      "defaultSrs": true
    },
    {
      "id": "standartinio-nuokrypio-formule",
      "title": "Standartinio nuokrypio formulė",
      "latex": "\\sigma = \\sqrt{Var(X)}",
      "conditions": [
        "Var(X) >= 0"
      ],
      "variables": {
        "\\sigma": "standartinis nuokrypis"
      },
      "explanation": "Paverčia dispersiją į pradinį matavimo vienetą.",
      "relatedConceptIds": [
        "standartinis-nuokrypis"
      ],
      "defaultSrs": true
    },
    {
      "id": "bernulio-formule",
      "title": "Bernulio formulė",
      "latex": "P_n(k) = C_n^k p^k (1-p)^{n-k}",
      "conditions": [
        "p yra sėkmės tikimybė",
        "bandymai nepriklausomi"
      ],
      "variables": {
        "n": "bandymų skaičius",
        "k": "sėkmių skaičius"
      },
      "explanation": "Skaičiuoja tikimybę gauti k sėkmių per n bandymų.",
      "relatedConceptIds": [
        "bernulio-bandymai"
      ],
      "defaultSrs": true
    }
  ],
