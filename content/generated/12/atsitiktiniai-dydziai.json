  "theory": [
    {
      "id": "atsitiktinio-dydžio-savoka",
      "title": "Atsitiktinis dydis ir jo skirstinys",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[atsitiktinis-dydis|Atsitiktinis dydis]] yra dydis, kuris bandymo metu įgyja vieną (iš anksto nežinomą) reikšmę priklausomai nuo atsitiktinumo."
        },
        {
          "type": "definition",
          "conceptId": "diskretusis-atsitiktinis-dydis",
          "text": "Diskretusis atsitiktinis dydis – tai dydis, kurio galimų reikšmių aibė yra baigtinė arba suskaičiuojama (pavyzdžiui, iškritusių akučių skaičius)."
        },
        {
          "type": "paragraph",
          "text": "Ryšys tarp atsitiktinio dydžio reikšmių ir jų tikimybių vadinamas [[tikimybinis-skirstinys|tikimybiniu skirstiniu]]. Jis dažnai pateikiamas kaip [[skirstinio-lentele|skirstinio lentelė]]."
        },
        {
          "type": "note",
          "text": "Svarbiausia taisyklė: visų skirstinio lentelės tikimybių suma visada turi būti lygi 1."
        }
      ]
    },
    {
      "id": "skaitines-charakteristikos",
      "title": "Matematinė viltis ir dispersija",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Norėdami apibūdinti atsitiktinį dydį vienu skaičiumi, naudojame [[matematine-viltis|matematinę viltį]] (vidutinę reikšmę)."
        },
        {
          "type": "formula",
          "formulaId": "matematines-vilties-formule",
          "latex": "E(X) = \\sum x_i p_i = x_1 p_1 + x_2 p_2 + \\dots + x_n p_n"
        },
        {
          "type": "paragraph",
          "text": "[[dispersija|Dispersija]] ir [[standartinis-nuokrypis|standartinis nuokrypis]] rodo, kaip stipriai reikšmės yra nutolusios nuo vidurkio (sklaidą)."
        },
        {
          "type": "formula",
          "formulaId": "dispersijos-formule",
          "latex": "Var(X) = E(X^2) - (E(X))^2"
        },
        {
          "type": "formula",
          "formulaId": "standartinio-nuokrypio-formule",
          "latex": "\\sigma = \\sqrt{Var(X)}"
        }
      ]
    },
    {
      "id": "bernulio-bandymai-theory",
      "title": "Bernulio bandymai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[bernulio-bandymai|Bernulio bandymai]] – tai seka nepriklausomų bandymų, kurių kiekvienas turi tik dvi galimas baigtis: 'sėkmę' (su tikimybe p) arba 'nesėkmę' (su tikimybe q = 1 - p)."
        },
        {
          "type": "formula",
          "formulaId": "bernulio-formule",
          "latex": "P_n(k) = C_n^k p^k q^{n-k}"
        },
        {
          "type": "paragraph",
          "text": "Ši formulė skaičiuoja tikimybę, kad atlikus n bandymų, sėkmė pasikartos lygiai k kartų."
        }
      ]
    },
    {
      "id": "normalusis-skirstinys-theory",
      "title": "Normalusis skirstinys",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[normalusis-skirstinys|Normalusis skirstinys]] yra dažniausiai gamtoje pasitaikantis tolydusis skirstinys, kurio grafikas yra varpo formos [[gauso-kreive|Gauso kreivė]]."
        },
        {
          "type": "property",
          "text": "Normalusis skirstinys yra simetriškas savo vidurkio atžvilgiu. Plotas po visa kreive lygus 1."
        },
        {
          "type": "note",
          "text": "Dauguma reikšmių (apie 68%) normaliajame skirstinyje patenka į vieno standartinio nuokrypio intervalą aplink vidurkį."
        }
      ]
    }
  ],
