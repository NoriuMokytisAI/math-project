  "workedExamples": [
    {
      "id": "atsit-worked-1",
      "title": "Skirstinio lentelės sudarymas",
      "level": "easy",
      "problem": "Metame monetą 2 kartus. Atsitiktinis dydis X – atsivertusių herbų skaičius. Sudarykite skirstinio lentelę.",
      "conceptIds": [
        "skirstinio-lentele",
        "atsitiktinis-dydis"
      ],
      "steps": [
        {
          "text": "Galimos baigtys: SS, SH, HS, HH (S-skaičius, H-herbas).",
          "latex": "n=4"
        },
        {
          "text": "X gali įgyti reikšmes 0, 1, 2.",
          "latex": "x \\in \\{0, 1, 2\\}"
        },
        {
          "text": "P(X=0) (tik SS) = 1/4.",
          "latex": "0.25"
        },
        {
          "text": "P(X=1) (SH ir HS) = 2/4 = 0.5.",
          "latex": "0.5"
        },
        {
          "text": "P(X=2) (tik HH) = 1/4.",
          "latex": "0.25"
        }
      ],
      "answer": "X: 0(0.25), 1(0.5), 2(0.25)"
    },
    {
      "id": "atsit-worked-2",
      "title": "Matematinės vilties skaičiavimas",
      "level": "easy",
      "problem": "Duotas skirstinys: X įgyja 2 su p=0.3 ir 5 su p=0.7. Raskite E(X).",
      "conceptIds": [
        "matematine-viltis"
      ],
      "steps": [
        {
          "text": "Naudojame formulę E(X) = x1*p1 + x2*p2.",
          "latex": "E(X) = 2 \\cdot 0.3 + 5 \\cdot 0.7"
        },
        {
          "text": "Apskaičiuojame.",
          "latex": "0.6 + 3.5 = 4.1"
        }
      ],
      "answer": "E(X) = 4.1"
    },
    {
      "id": "atsit-worked-3",
      "title": "Dispersijos radimas",
      "level": "medium",
      "problem": "Atsitiktinio dydžio E(X)=3, o E(X^2)=13. Raskite Var(X) ir standartinį nuokrypį.",
      "conceptIds": [
        "dispersija",
        "standartinis-nuokrypis"
      ],
      "steps": [
        {
          "text": "Var(X) = E(X^2) - (E(X))^2.",
          "latex": "13 - 3^2 = 13 - 9 = 4"
        },
        {
          "text": "Standartinis nuokrypis yra šaknis iš dispersijos.",
          "latex": "\\sigma = \\sqrt{4} = 2"
        }
      ],
      "answer": "Var(X)=4, σ=2"
    },
    {
      "id": "atsit-worked-4",
      "title": "Bernulio formulės taikymas",
      "level": "medium",
      "problem": "Šaulys pataiko į taikinį su tikimybe 0.8. Jis šauna 3 kartus. Kokia tikimybė, kad jis pataikys lygiai 2 kartus?",
      "conceptIds": [
        "bernulio-bandymai"
      ],
      "steps": [
        {
          "text": "Naudojame Bernulio formulę su n=3, k=2, p=0.8, q=0.2.",
          "latex": "P_3(2) = C_3^2 \\cdot (0.8)^2 \\cdot (0.2)^1"
        },
        {
          "text": "C(3, 2) = 3.",
          "latex": "3 \\cdot 0.64 \\cdot 0.2 = 3 \\cdot 0.128 = 0.384"
        }
      ],
      "answer": "0.384"
    },
    {
      "id": "atsit-worked-5",
      "title": "Normalusis skirstinys (68-95-99.7 taisyklė)",
      "level": "hard",
      "problem": "Ūgis pasiskirstęs normaliai su vidurkiu μ=170 cm ir σ=10 cm. Kiek procentų žmonių ūgis yra tarp 160 ir 180 cm?",
      "conceptIds": [
        "normalusis-skirstinys"
      ],
      "steps": [
        {
          "text": "Intervalas [160, 180] yra lygiai [μ - σ, μ + σ].",
          "latex": "170-10, 170+10"
        },
        {
          "text": "Pagal normaliojo skirstinio savybę, šiame intervale yra apie 68% reikšmių.",
          "latex": "68\\%"
        }
      ],
      "answer": "Apie 68%"
    }
  ],
