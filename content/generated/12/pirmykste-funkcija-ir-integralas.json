      "relatedConceptIds": [
        "aritmetine-progresija"
      ],
      "defaultSrs": true
    },
    {
      "id": "geometrines-progresijos-formule",
      "title": "Geometrinė progresija",
      "type": "formula",
      "latex": "a_n=a_1q^{n-1}",
      "conditions": [
        "Kai santykis pastovus"
      ],
      "variables": {
        "a_1": "pirmas narys",
        "q": "vardiklis"
      },
      "explanation": "Naudojama augimui ir mažėjimui.",
      "relatedConceptIds": [
        "geometrine-progresija"
      ],
      "defaultSrs": true
    },
    {
      "id": "laipsniu-formules",
      "title": "Laipsnių taisyklės",
      "type": "formula",
      "latex": "a^m a^n=a^{m+n}",
      "conditions": [
        "Kai dauginame to paties pagrindo laipsnius"
      ],
      "variables": {
        "a": "pagrindas"
      },
      "explanation": "Rodiklių taisyklė padeda pertvarkyti reiškinius.",
      "relatedConceptIds": [
        "laipsnis",
        "rodiklis"
      ],
      "defaultSrs": true
    },
    {
      "id": "logaritmo-formule",
      "title": "Logaritmo ryšys",
      "type": "formula",
      "latex": "\\log_a b=c \\Leftrightarrow a^c=b",
      "conditions": [
        "Kai a>0, a!=1"
      ],
      "variables": {
        "a": "pagrindas",
        "b": "skaičius"
      },
      "explanation": "Logaritmas yra laipsniavimo atvirkštinė operacija.",
      "relatedConceptIds": [
        "logaritmas"
      ],
      "defaultSrs": true
    },
    {
      "id": "sinuso-formule",
      "title": "Trigonometrinis santykis",
      "type": "formula",
      "latex": "\\sin\\alpha=\\frac{priešpriešinė}{įžambinė}",
      "conditions": [
        "Stačiajame trikampyje"
      ],
      "variables": {
        "α": "kampas"
      },
      "explanation": "Padeda matuoti kampą ir kraštines.",
      "relatedConceptIds": [
        "sinusas"
      ],
      "defaultSrs": true
    },
    {
      "id": "isvestines-galios-formule",
      "title": "Galios taisyklė",
      "type": "formula",
      "latex": "\\frac{d}{dx}x^n = nx^{n-1}",
      "conditions": [
        "Nagrinėjant polinomus"
      ],
      "variables": {
        "n": "laipsnis"
      },
      "explanation": "Svarbiausia išvestinių taisyklė.",
      "relatedConceptIds": [
        "isvestine"
      ],
      "defaultSrs": true
    },
    {
      "id": "integralo-formule",
      "title": "Pagrindinė integralo forma",
      "type": "formula",
