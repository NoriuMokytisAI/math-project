  "theory": [
    {
      "id": "pirmykste-funkcija-ir-integralas-ivadas",
      "title": "Įvadas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Pirmykštė funkcija ir integralas yra tema, kurioje mokomasi atpažinti pagrindinius integralas modelius ir juos taikyti skaičiavimuose, tekste bei brėžiniuose."
        },
        {
          "type": "paragraph",
          "text": "Šioje temoje svarbiausia nuolat matyti ryšį tarp sąvokų [[seka|Seka]], [[aritmetine-progresija|Aritmetinė progresija]], [[geometrine-progresija|Geometrinė progresija]] ir uždavinių sprendimo."
        }
      ]
    },
    {
      "id": "pirmykste-funkcija-ir-integralas-svarbiausios-savokos",
      "title": "Svarbiausios sąvokos",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "seka",
          "text": "Skaičių eilė pagal taisyklę."
        },
        {
          "type": "definition",
          "conceptId": "aritmetine-progresija",
          "text": "Seka su pastoviu skirtumu."
        },
        {
          "type": "definition",
          "conceptId": "geometrine-progresija",
          "text": "Seka su pastoviu santykiu."
        },
        {
          "type": "note",
          "text": "Jei sprendžiant kyla abejonė, pirmiausia tikrink, ar aiškiai supranti [[seka|Seka]] ir [[indukcija|Matematinė indukcija]]."
        }
      ]
    },
    {
      "id": "pirmykste-funkcija-ir-integralas-taisyklės",
      "title": "Svarbiausios taisyklės",
      "blocks": [
        {
          "type": "theorem",
          "text": "Pirmykštė funkcija ir integralas sprendimuose visada pirmiausia atskirk duomenis nuo ieškomo dydžio, o tada pasirink tinkamą modelį."
        },
        {
          "type": "property",
          "text": "Jei užduotyje pasirodo [[geometrine-progresija|Geometrinė progresija]] ar [[indukcija|Matematinė indukcija]], dažnai verta rašyti ryšį simboliais prieš skaičiuojant."
        },
        {
          "type": "formula",
          "formulaId": "sekos-forma",
          "latex": "a_n"
        }
      ]
    },
    {
      "id": "pirmykste-funkcija-ir-integralas-strategija",
      "title": "Sprendimo strategija",
      "blocks": [
        {
          "type": "method",
          "text": "1. Perskaityk užduotį ir pažymėk, kokie dydžiai žinomi. 2. Nustatyk, kuri sąvoka čia svarbiausia. 3. Užrašyk veiksmus arba ryšį. 4. Patikrink rezultatą kitaip arba atgaliniu skaičiavimu."
        },
        {
          "type": "warning",
          "text": "Dažna klaida yra imti skaičiuoti per anksti ir neįvardyti, ką reiškia gauta reikšmė."
        }
      ]
    },
    {
      "id": "pirmykste-funkcija-ir-integralas-rysys",
      "title": "Ryšys su kitomis temomis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Ši tema remiasi ankstesnėmis žiniomis iš kitų metų: skaičiavimu, reiškinių pertvarkymu, figūrų savybėmis ar duomenų skaitymu. Ji ruošia kelią tolimesnėms temoms, kuriose reikia daugiau bendro modelio ir tikslesnio argumentavimo."
        }
      ]
    }
  ],
