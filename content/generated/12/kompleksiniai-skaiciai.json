  "workedExamples": [
    {
      "id": "kompl-worked-1",
      "title": "Veiksmai algebrinėje formoje",
      "level": "easy",
      "problem": "Apskaičiuokite $z = (2 + 3i)(1 - 2i)$.",
      "conceptIds": [
        "algebrine-forma"
      ],
      "steps": [
        {
          "text": "Dauginame skliaustus: $2(1) + 2(-2i) + 3i(1) + 3i(-2i)$.",
          "latex": "2 - 4i + 3i - 6i^2"
        },
        {
          "text": "Pakeičiame $i^2$ į $-1$: $2 - i - 6(-1) = 2 - i + 6$.",
          "latex": "8 - i"
        }
      ],
      "answer": "8 - i"
    },
    {
      "id": "kompl-worked-2",
      "title": "Dalyba naudojant jungtinį skaičių",
      "level": "medium",
      "problem": "Padalinkite skaičius: $\\frac{5}{1+2i}$.",
      "conceptIds": [
        "jungtinis-skaicius"
      ],
      "steps": [
        {
          "text": "Dauginame skaitiklį ir vardiklį iš vardikliui jungtinio skaičiaus $1-2i$.",
          "latex": "\\frac{5(1-2i)}{(1+2i)(1-2i)}"
        },
        {
          "text": "Vardiklis taps kvadratų suma: $1^2 + 2^2 = 5$.",
          "latex": "\\frac{5 - 10i}{5}"
        },
        {
          "text": "Suprastiname iš 5.",
          "latex": "1 - 2i"
        }
      ],
      "answer": "1 - 2i"
    },
    {
      "id": "kompl-worked-3",
      "title": "Perėjimas į trigonometrinę formą",
      "level": "medium",
      "problem": "Užrašykite $z = -1 + i\\sqrt{3}$ trigonometrine forma.",
      "conceptIds": [
        "trigonometrine-forma",
        "modulis",
        "argumentas"
      ],
      "steps": [
        {
          "text": "Randame modulį: $r = \\sqrt{(-1)^2 + (\\sqrt{3})^2} = \\sqrt{1 + 3} = 2$.",
          "latex": "r = 2"
        },
        {
          "text": "Randame argumentą. Taškas $(-1, \\sqrt{3})$ yra II ketvirtyje.",
          "latex": "\\phi = 180^{\\circ} - 60^{\\circ} = 120^{\\circ} = \\frac{2\\pi}{3}"
        },
        {
          "text": "Surašome į formą $r(\\cos\\phi + i\\sin\\phi)$.",
          "latex": "2(\\cos \\frac{2\\pi}{3} + i\\sin \\frac{2\\pi}{3})"
        }
      ],
      "answer": "2(cos(2π/3) + i sin(2π/3))"
    },
    {
      "id": "kompl-worked-4",
      "title": "Kėlimas laipsniu (Muavras)",
      "level": "hard",
      "problem": "Apskaičiuokite $z = (1 - i)^8$.",
      "conceptIds": [
        "muavro-formule"
      ],
      "steps": [
        {
          "text": "Randame $r = \\sqrt{1^2 + (-1)^2} = \\sqrt{2}$ ir $\\phi = -45^{\\circ}$ (arba $315^{\\circ}$).",
          "latex": ""
        },
        {
          "text": "Taikome Muavro formulę: $z^8 = (\\sqrt{2})^8 (\\cos(8 \\cdot (-45^{\\circ})) + i\\sin(8 \\cdot (-45^{\\circ})))$.",
          "latex": "z^8 = 16(\\cos(-360^{\\circ}) + i\\sin(-360^{\\circ}))"
        },
        {
          "text": "Kadangi $\\cos(-360^{\\circ}) = 1$, o $\\sin(-360^{\\circ}) = 0$.",
          "latex": "16(1 + 0i) = 16"
        }
      ],
      "answer": "16"
    },
    {
      "id": "kompl-worked-5",
      "title": "Kvadratinė lygtis su neigiamu diskriminantu",
      "level": "easy",
      "problem": "Išspręskite lygtį $x^2 - 4x + 5 = 0$.",
      "conceptIds": [
        "kompleksinis-skaicius"
      ],
      "steps": [
        {
          "text": "Apskaičiuojame diskriminantą: $D = (-4)^2 - 4(1)(5) = 16 - 20 = -4$.",
          "latex": "D = -4"
        },
        {
          "text": "Šaknis iš $D$: $\\sqrt{-4} = 2i$.",
          "latex": ""
        },
        {
          "text": "Randame sprendinius: $x = \\frac{4 \\pm 2i}{2}$.",
          "latex": "x_1 = 2+i, x_2 = 2-i"
        }
      ],
      "answer": "2+i, 2-i"
    },
    {
      "id": "kompl-worked-6",
      "title": "i laipsnių skaičiavimas",
      "level": "easy",
      "problem": "Supaprastinkite reiškinį $i^{2023} + i^{2024}$.",
      "conceptIds": [
        "menamasis-vienetas"
      ],
