      "olympiadTier": "introductory",
      "requiredPrerequisiteMastery": 70,
      "statement": "Kiek yra triženklių skaičių, kurių visi skaitmenys yra skirtingi ir nelyginiai?",
      "answer": {
        "kind": "structuredReasoning",
        "expectedConclusion": "Yra $60$ tokie skaičiai."
      },
      "answerText": "60",
      "coreIdea": {
        "title": "Pasirinkite skaitmenis nuosekliai",
        "text": "Nelyginiai skaitmenys yra: $1, 3, 5, 7, 9$ (iš viso penki). Pirmąjį skaitmenį galime pasirinkti iš $5$ variantų, o tolesnius – iš likusių skaitmenų."
      },
      "strategyTags": ["kombinatorika", "proof"],
      "hints": [
        { "order": 1, "kind": "orientation", "text": "Pirmiausia išsirašykite visus nelyginius skaitmenis: $1, 3, 5, 7, 9$. Jų yra lygiai $5$.", "penalty": 0.05 },
        { "order": 2, "kind": "observation", "text": "Kadangi skaitmenys turi būti skirtingi, kiekvienai kitai skaičiaus pozicijai turėsite vienu pasirinkimu mažiau.", "penalty": 0.08 },
        { "order": 3, "kind": "method", "text": "Taikykite daugybos taisyklę: $5 \\times 4 \\times 3$.", "penalty": 0.1 }
      ],
      "solutionSteps": [
        { "text": "Nelyginių skaitmenų aibė yra {1, 3, 5, 7, 9} (5 elementai)." },
        { "text": "Šimtams - 5 galimybės, dešimtims - 4, vienetams - 3." },
        { "text": "Iš viso: 5 * 4 * 3 = 60." }
      ]
    },
