  "theory": [
    {
      "id": "dt-ivadas",
      "title": "Kas yra dešimtainė trupmena?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Dešimtainės trupmenos – tai skaičiai, kurių vardikliai yra 10, 100, 1000 ir t. t., bet užrašomi jie ne trupmena, o naudojant [[kablelis|kablelį]]."
        },
        {
          "type": "definition",
          "conceptId": "desimtaine-trupmena",
          "text": "Dešimtainė trupmena – tai skaičiaus užrašas, kuriame sveikoji dalis nuo trupmeninės atskiriama kableliu."
        },
        {
          "type": "example",
          "text": "Paprastoji trupmena 5/10 dešimtainiu būdu rašoma 0,5. Skaitome: 'nulis sveikų, penkios dešimtosios'."
        }
      ]
    },
    {
      "id": "dt-skyriai",
      "title": "Skyriai po kablelio",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kiekviena skaitmens vieta po kablelio turi savo pavadinimą:"
        },
        {
          "type": "table",
          "text": "Skyrių pavadinimai (pvz., 12,345):",
          "data": [
            ["3", "[[desimtosios-dalys|dešimtosios]]"],
            ["4", "[[simtosios-dalys|šimtosios]]"],
            ["5", "[[tukstantosios-dalys|tūkstantosios]]"]
          ]
        },
        {
          "type": "note",
          "text": "Pirmas skaitmuo po kablelio visada rodo dešimtąsias dalis."
        }
      ]
    },
    {
      "id": "dt-lyginimas",
      "title": "Kaip lyginti ir sulyginti?",
      "blocks": [
        {
          "type": "method",
          "text": "[[skaiciu-sulyginimas|Sulyginimas]]: dešimtainės trupmenos gale galima prirašyti nulių, skaičiaus reikšmė nuo to nesikeičia (pvz., 0,5 = 0,50)."
        },
        {
          "type": "property",
          "text": "[[desimtainiu-lyginimas|Lyginimas]]: pirmiausia lyginame sveikąsias dalis. Jei jos lygios, lyginame dešimtąsias, tada šimtąsias ir t. t."
        }
      ]
    },
    {
      "id": "dt-veiksmai",
      "title": "Sudėtis ir atimtis",
      "blocks": [
        {
          "type": "method",
          "text": "[[sudetis-stulpeliu-desimtainiu|Sudėtis stulpeliu]]: rašome skaičius taip, kad kablelis būtų po kableliu. Jei skaitmenų skaičius skiriasi, prirašome nulių."
        },
        {
          "type": "warning",
          "text": "Svarbiausia taisyklė: kablelis po kableliu!"
        },
        {
          "type": "example",
          "text": "2,5 + 0,14 = 2,50 + 0,14 = 2,64."
        }
      ]
    }
