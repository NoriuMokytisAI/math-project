  "theory": [
    {
      "id": "rom-ivadas",
      "title": "Kas yra romėniškieji skaičiai?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Romėniškieji skaičiai – tai senovės Romoje sukurta skaičiavimo sistema, kurią naudojame iki šiol: laikrodžių ciferblatuose, knygų skyriams žymėti ar istoriniams metams nurodyti."
        },
        {
          "type": "definition",
          "conceptId": "romeniskas-skaitmuo",
          "text": "Romėniškasis skaitmuo – tai lotynų abėcėlės raidė, turinti tam tikrą skaitinę reikšmę."
        },
        {
          "type": "table",
          "text": "Pagrindiniai romėniški simboliai:",
          "data": [
            ["I", "1"],
            ["V", "5"],
            ["X", "10"],
            ["L", "50"],
            ["C", "100"],
            ["D", "500"],
            ["M", "1000"]
          ]
        }
      ]
    },
    {
      "id": "rom-taisykles",
      "title": "Pagrindinės rašymo taisyklės",
      "blocks": [
        {
          "type": "property",
          "text": "[[sudeties-taisykle-romeniskiems|Sudėties taisyklė]]: jei mažesnis skaitmuo rašomas po didesnio, jų reikšmės sudedamos (pvz., VI = 5 + 1 = 6)."
        },
        {
          "type": "property",
          "text": "[[atimties-taisykle-romeniskiems|Atimties taisyklė]]: jei mažesnis skaitmuo rašomas prieš didesnį, jis atimamas iš didesnio (pvz., IV = 5 - 1 = 4)."
        },
        {
          "type": "warning",
          "text": "[[kartojimo-taisykle|Kartojimo taisyklė]]: tas pats skaitmuo (I, X, C, M) negali būti rašomas iš eilės daugiau nei tris kartus. Skaitmenys V, L, D niekada nekartojami."
        }
      ]
    },
    {
      "id": "rom-konvertavimas",
      "title": "Kaip užrašyti didelius skaičius?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Norint užrašyti skaičių, jis skaidomas skyriais: tūkstančiais, šimtais, dešimtimis ir vienetais. Kiekviena dalis užrašoma atskirai."
        },
        {
          "type": "example",
          "text": "Užrašykime 2024: 2000 = MM, 20 = XX, 4 = IV. Tad 2024 = MMXXIV."
        },
        {
          "type": "note",
          "text": "Atimties taisyklė galioja tik tam tikroms poroms: I prieš V arba X; X prieš L arba C; C prieš D arba M."
        }
      ]
    }
  ],
