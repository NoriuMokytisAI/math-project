  "theory": [
    {
      "id": "finansiniai-skaiciavimai-5-ivadas",
      "title": "Įvadas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Finansiniai skaičiavimai: procentai, pirkimas ir nuolaidos yra tema, kurioje mokomasi atpažinti pagrindinius finansiniai procentų skaičiavimai modelius ir juos taikyti skaičiavimuose, tekste bei brėžiniuose."
        },
        {
          "type": "paragraph",
          "text": "Šioje temoje svarbiausia nuolat matyti ryšį tarp sąvokų [[skaicius|Skaičius]], [[naturalieji-skaiciai|Natūralieji skaičiai]], [[sveikieji-skaiciai|Sveikieji skaičiai]] ir uždavinių sprendimo."
        }
      ]
    },
    {
      "id": "finansiniai-skaiciavimai-5-svarbiausios-savokos",
      "title": "Svarbiausios sąvokos",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "skaicius",
          "text": "Skaičius aprašo kiekybę ar tvarką finansiniai procentų skaičiavimai uždaviniuose."
        },
        {
          "type": "definition",
          "conceptId": "naturalieji-skaiciai",
          "text": "Skaičiai, kuriais skaičiuojame objektus ir tvarką."
        },
        {
          "type": "definition",
          "conceptId": "sveikieji-skaiciai",
          "text": "Natūralieji skaičiai, jų priešingieji ir nulis."
        },
        {
          "type": "note",
          "text": "Jei sprendžiant kyla abejonė, pirmiausia tikrink, ar aiškiai supranti [[skaicius|Skaičius]] ir [[racionalieji-skaiciai|Racionalieji skaičiai]]."
        }
      ]
    },
    {
      "id": "finansiniai-skaiciavimai-5-taisyklės",
      "title": "Svarbiausios taisyklės",
      "blocks": [
        {
          "type": "theorem",
          "text": "Finansiniai skaičiavimai: procentai, pirkimas ir nuolaidos sprendimuose visada pirmiausia atskirk duomenis nuo ieškomo dydžio, o tada pasirink tinkamą modelį."
        },
        {
          "type": "property",
          "text": "Jei užduotyje pasirodo [[sveikieji-skaiciai|Sveikieji skaičiai]] ar [[racionalieji-skaiciai|Racionalieji skaičiai]], dažnai verta rašyti ryšį simboliais prieš skaičiuojant."
        },
        {
          "type": "formula",
          "formulaId": "procento-formule",
          "latex": "x\\% = \\frac{x}{100}"
        }
      ]
    },
    {
      "id": "finansiniai-skaiciavimai-5-strategija",
      "title": "Sprendimo strategija",
      "blocks": [
        {
          "type": "method",
          "text": "1. Perskaityk užduotį ir pažymėk, kokie dydžiai žinomi. 2. Nustatyk, kuri sąvoka čia svarbiausia. 3. Užrašyk veiksmus arba ryšį. 4. Patikrink rezultatą kitaip arba atgaliniu skaičiavimu."
        },
        {
          "type": "warning",
          "text": "Dažna klaida yra imti skaičiuoti per anksti ir neįvardyti, ką reiškia gauta reikšmė."
        }
      ]
    },
    {
      "id": "finansiniai-skaiciavimai-5-rysys",
      "title": "Ryšys su kitomis temomis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Ši tema remiasi ankstesnėmis žiniomis iš kitų metų: skaičiavimu, reiškinių pertvarkymu, figūrų savybėmis ar duomenų skaitymu. Ji ruošia kelią tolimesnėms temoms, kuriose reikia daugiau bendro modelio ir tikslesnio argumentavimo."
        }
      ]
    }
  ],
