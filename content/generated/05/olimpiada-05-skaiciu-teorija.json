  "theory": [
    {
      "title": "Matematinis mąstymas ir loginė dedukcija",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Sveiki atvykę į olimpiadinę matematiką! Skirtingai nuo įprastų pamokų, čia svarbiausia yra ne atlikti standartinius veiksmus pagal taisykles, bet atrasti naujus kelius ir juos logiškai pagrįsti."
        },
        {
          "type": "paragraph",
          "text": "Spręsdami olimpiadinius uždavinius, visada pradėkite nuo sąlygos analizės. Užsirašykite, kas yra duota, ir pabandykite išspręsti supaprastintą uždavinio versiją (pvz., su mažesniais skaičiais)."
        },
        {
          "type": "method",
          "text": "Taikykite **dedukcijos metodą**: jei žinome, kad teiginys A yra teisingas, o iš jo seka B, vadinasi, B taip pat teisingas. Niekada nesiremkite spėjimais – kiekvienas jūsų teiginys turi turėti aiškų matematinį pagrindimą."
        }
      ]
    },
    {
      "title": "Paritetas: lyginių ir nelyginių skaičių magija",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Vienas galingiausių ir paprasčiausių įrankių pradinėse olimpiadose yra skaičių lyginumas (paritetas)."
        },
        {
          "type": "paragraph",
          "text": "Prisiminkite pagrindines taisykles:\n- $\\text{Lyginis} \\pm \\text{Lyginis} = \\text{Lyginis}$\n- $\\text{Nelyginis} \\pm \\text{Nelyginis} = \\text{Lyginis}$\n- $\\text{Lyginis} \\pm \\text{Nelyginis} = \\text{Nelyginis}$\n- $\\text{Lyginis} \\times \\text{Bet koks} = \\text{Lyginis}$\n- $\\text{Nelyginis} \\times \\text{Nelyginis} = \\text{Nelyginis}$"
        },
        {
          "type": "method",
          "text": "Jei uždavinyje kalbama apie objektų mainus, lentelės spalvinimą ar operacijas su skaičiais, stebėkite, kaip keičiasi lyginių arba nelyginių skaičių kiekis. Šis savybės nekintamumas vadinamas **invariantu**."
        }
      ]
    }
  ],
  "concepts": [
