  "theory": [
    {
      "id": "judejimo-uzdaviniai-ir-matavimo-vienetai-ivadas",
      "title": "Įvadas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kelias, laikas, greitis ir matavimo vienetai yra tema, kurioje mokomasi atpažinti pagrindinius judėjimo uždaviniai ir matavimo vienetai modelius ir juos taikyti skaičiavimuose, tekste bei brėžiniuose."
        },
        {
          "type": "paragraph",
          "text": "Šioje temoje svarbiausia nuolat matyti ryšį tarp sąvokų [[kampas|Kampas]], [[trikampis|Trikampis]], [[keturkampis|Keturkampis]] ir uždavinių sprendimo."
        }
      ]
    },
    {
      "id": "judejimo-uzdaviniai-ir-matavimo-vienetai-svarbiausios-savokos",
      "title": "Svarbiausios sąvokos",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "kampas",
          "text": "Dviejų spindulių arba tiesių susikirtimo dydis."
        },
        {
          "type": "definition",
          "conceptId": "trikampis",
          "text": "Figūra iš trijų kraštinių ir trijų kampų."
        },
        {
          "type": "definition",
          "conceptId": "keturkampis",
          "text": "Figūra iš keturių kraštinių."
        },
        {
          "type": "note",
          "text": "Jei sprendžiant kyla abejonė, pirmiausia tikrink, ar aiškiai supranti [[kampas|Kampas]] ir [[perimetras|Perimetras]]."
        }
      ]
    },
    {
      "id": "judejimo-uzdaviniai-ir-matavimo-vienetai-taisyklės",
      "title": "Svarbiausios taisyklės",
      "blocks": [
        {
          "type": "theorem",
          "text": "Kelias, laikas, greitis ir matavimo vienetai sprendimuose visada pirmiausia atskirk duomenis nuo ieškomo dydžio, o tada pasirink tinkamą modelį."
        },
        {
          "type": "property",
          "text": "Jei užduotyje pasirodo [[keturkampis|Keturkampis]] ar [[perimetras|Perimetras]], dažnai verta rašyti ryšį simboliais prieš skaičiuojant."
        },
        {
          "type": "formula",
          "formulaId": "trikampio-plotas",
          "latex": "S=\\frac{ah}{2}"
        }
      ]
    },
    {
      "id": "judejimo-uzdaviniai-ir-matavimo-vienetai-strategija",
      "title": "Sprendimo strategija",
      "blocks": [
        {
          "type": "method",
          "text": "1. Perskaityk užduotį ir pažymėk, kokie dydžiai žinomi. 2. Nustatyk, kuri sąvoka čia svarbiausia. 3. Užrašyk veiksmus arba ryšį. 4. Patikrink rezultatą kitaip arba atgaliniu skaičiavimu."
        },
        {
          "type": "warning",
          "text": "Dažna klaida yra imti skaičiuoti per anksti ir neįvardyti, ką reiškia gauta reikšmė."
        }
      ]
    },
    {
      "id": "judejimo-uzdaviniai-ir-matavimo-vienetai-rysys",
      "title": "Ryšys su kitomis temomis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Ši tema remiasi ankstesnėmis žiniomis iš kitų metų: skaičiavimu, reiškinių pertvarkymu, figūrų savybėmis ar duomenų skaitymu. Ji ruošia kelią tolimesnėms temoms, kuriose reikia daugiau bendro modelio ir tikslesnio argumentavimo."
        }
      ]
    }
  ],
