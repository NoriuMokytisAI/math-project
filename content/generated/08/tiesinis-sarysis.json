  "theory": [
    {
      "id": "tiesinis-sarysis-ivadas-detalus",
      "title": "Kas yra kintamieji ir sąryšiai?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kasdieniniame gyvenime daugybė dalykų priklauso vienas nuo kito. Pavyzdžiui, kuo daugiau kilometrų nuvažiuoja automobilis, tuo daugiau degalų jis sunaudoja. Kuo ilgiau dega žvakė, tuo trumpesnė ji tampa. Matematikoje tokios priklausomybės vadinamos **sąryšiais**."
        },
        {
          "type": "paragraph",
          "text": "Svarbiausia suprasti du kintamuosius: [[nepriklausomas-kintamasis|nepriklausomą kintamąjį]] (dažniausiai žymimą $x$), kurį mes patys pasirenkame, ir [[priklausomas-kintamasis|priklausomą kintamąjį]] (žymimą $y$), kurio reikšmė priklauso nuo pasirinkto $x$."
        },
        {
          "type": "definition",
          "conceptId": "tiesinis-sarysis",
          "text": "[[tiesinis-sarysis|Tiesinis sąryšis]] – tai tokia priklausomybė tarp dviejų kintamųjų, kurią grafiškai vaizduoja tiesė, o matematiškai aprašo lygtis, kurioje kintamasis $x$ yra pirmojo laipsnio."
        }
      ]
    },
    {
      "id": "tiesine-funkcija-formule",
      "title": "Tiesinės funkcijos lygtis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Tiesinė funkcija yra dažniausiai sutinkamas tiesinio sąryšio pavidalas."
        },
        {
          "type": "formula",
          "formulaId": "tiesines-funkcijos-lygtis",
          "latex": "y = kx + b"
        },
        {
          "type": "paragraph",
          "text": "Čia $x$ ir $y$ yra kintamieji, o $k$ ir $b$ – skaičiai, kurie turi labai svarbias reikšmes:"
        },
        {
          "type": "definition",
          "conceptId": "krypties-koeficientas",
          "text": "[[krypties-koeficientas|Krypties koeficientas]] ($k$) rodo tiesės pasvirimą. Jei $k > 0$, funkcija didėja (tiesė kyla į viršų). Jei $k < 0$, funkcija mažėja (tiesė leidžiasi žemyn). Jei $k = 0$, tiesė yra horizontali."
        },
        {
          "type": "definition",
          "conceptId": "laisvasis-narys",
          "text": "[[laisvasis-narys|Laisvasis narys]] ($b$) rodo tašką, kuriame tiesė kerta $OY$ ašį (ordinačių ašį). Šio taško koordinatės visada yra $(0; b)$."
        }
      ]
    },
    {
      "id": "tiesinis-sarysis-grafikas",
      "title": "Kaip nubraižyti tiesę?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Geometrijoje žinome, kad per du taškus galima nubrėžti vienintelę tiesę. Todėl norint nubraižyti tiesinės funkcijos grafiką, pakanka rasti tik **du** jos taškus."
        },
        {
          "type": "method",
          "text": "1. Pasirenkame dvi laisvas $x$ reikšmes (pvz., $x=0$ ir $x=2$). 2. Įstatome jas į funkcijos lygtį ir apskaičiuojame atitinkamas $y$ reikšmes. 3. Gautus taškus pažymime koordinačių plokštumoje. 4. Per šiuos taškus nubrėžiame tiesę."
        },
        {
          "type": "note",
          "text": "Patogiausia vieną tašką rinktis ten, kur $x=0$ (tai bus laisvasis narys $b$), o kitą – bet kokį nedidelį sveikąjį skaičių."
        }
      ]
    },
    {
      "id": "tiesinis-sarysis-proporcingumas",
      "title": "Tiesioginis proporcingumas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Tai specialus tiesinės funkcijos atvejis, kai tiesė eina per koordinačių pradžios tašką $(0; 0)$."
        },
        {
          "type": "formula",
          "formulaId": "tiesioginis-proporcingumas-formule",
          "latex": "y = kx \\quad (b=0)"
        },
        {
          "type": "paragraph",
          "text": "Tokioje funkcijoje santykis $\\frac{y}{x}$ visada yra pastovus ir lygus $k$."
        }
      ]
    },
    {
      "id": "tiesinis-sarysis-nulis",
      "title": "Funkcijos nulis ir kirtimo taškai",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "funkcijos-nulis",
          "text": "[[funkcijos-nulis|Funkcijos nulis]] – tai argumento $x$ reikšmė, su kuria $y=0$. Grafiškai tai taškas, kuriame tiesė kerta $OX$ (abscisių) ašį."
        },
        {
          "type": "method",
          "text": "Norėdami rasti sankirtos su $OX$ ašimi tašką, lygtyje $y = kx + b$ vietoj $y$ įrašome $0$ ir išsprendžiame lygtį: $kx + b = 0$."
        }
      ]
    },
    {
      "id": "tiesinis-sarysis-lygtis-is-tasku",
      "title": "Tiesės lygties sudarymas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Jei žinome du taškus $A(x_1; y_1)$ ir $B(x_2; y_2)$, kuriais eina tiesė, galime apskaičiuoti krypties koeficientą $k$."
        },
        {
          "type": "formula",
          "formulaId": "krypties-koeficientas-per-taskus",
          "latex": "k = \\frac{y_2 - y_1}{x_2 - x_1}"
        },
        {
          "type": "paragraph",
          "text": "Radus $k$, laisvąjį narį $b$ randame į bendrąją lygtį įstatę vieno iš taškų koordinates."
        }
      ]
    },
    {
      "id": "tiesinis-sarysis-klaidos",
      "title": "Dažnos klaidos",
      "blocks": [
        {
          "type": "warning",
          "text": "Nesuimaisykite: krypties koeficientas $k$ visada stovi prie $x$. Jei lygtis užrašyta $y = 5 - 2x$, tai $k = -2$, o $b = 5$."
        },
        {
          "type": "warning",
          "text": "Tikrinant, ar taškas priklauso tiesei, būtina įstatyti abi koordinates ($x$ ir $y$). Jei gaunama teisinga lygybė, taškas priklauso."
        }
      ]
    }
  ],
