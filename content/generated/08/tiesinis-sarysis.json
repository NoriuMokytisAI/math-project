  "workedExamples": [
    {
      "id": "tiesinis-sarysis-exmp-1",
      "title": "Funkcijos reikšmės skaičiavimas",
      "level": "easy",
      "problem": "Duota tiesinė funkcija $y = -3x + 5$. Apskaičiuokite $y$ reikšmę, kai $x = 4$.",
      "conceptIds": [
        "priklausomas-kintamasis"
      ],
      "formulaIds": [
        "tiesines-funkcijos-lygtis"
      ],
      "steps": [
        {
          "text": "Į funkcijos formulę vietoje x įstatome skaičių 4.",
          "latex": "y = -3 \\cdot 4 + 5"
        },
        {
          "text": "Atliekame daugybą.",
          "latex": "y = -12 + 5"
        },
        {
          "text": "Atliekame sudėtį.",
          "latex": "y = -7"
        }
      ],
      "answer": "-7"
    },
    {
      "id": "tiesinis-sarysis-exmp-2",
      "title": "Argumento radimas",
      "level": "easy",
      "problem": "Su kuria $x$ reikšme funkcijos $y = 2x - 8$ reikšmė lygi $10$?",
      "conceptIds": [
        "nepriklausomas-kintamasis"
      ],
      "formulaIds": [
        "tiesines-funkcijos-lygtis"
      ],
      "steps": [
        {
          "text": "Vietoj y įrašome 10 ir sudarome lygtį.",
          "latex": "10 = 2x - 8"
        },
        {
          "text": "Perkeliame laisvąjį narį į kairę pusę su priešingu ženklu.",
          "latex": "10 + 8 = 2x"
        },
        {
          "text": "Sudedame ir padalijame iš 2.",
          "latex": "18 = 2x \\Rightarrow x = 9"
        }
      ],
      "answer": "9"
    },
    {
      "id": "tiesinis-sarysis-exmp-3",
      "title": "Grafiko braižymas (taškai)",
      "level": "easy",
      "problem": "Raskite du taškus tiesei $y = 0,5x - 1$ nubraižyti.",
      "conceptIds": [
        "tieses-grafikas"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Pasirenkame x = 0.",
          "latex": "y = 0,5 \\cdot 0 - 1 = -1 \\Rightarrow (0; -1)"
        },
        {
          "text": "Pasirenkame x = 4 (kad gautume sveikąjį skaičių).",
          "latex": "y = 0,5 \\cdot 4 - 1 = 2 - 1 = 1 \\Rightarrow (4; 1)"
        }
      ],
      "answer": "(0; -1) ir (4; 1)"
    },
    {
      "id": "tiesinis-sarysis-exmp-4",
      "title": "Koeficientų nustatymas",
      "level": "medium",
      "problem": "Nurodykite funkcijos $y = 10 - x$ krypties koeficientą ir laisvąjį narį. Ar ši funkcija didėja, ar mažėja?",
      "conceptIds": [
        "krypties-koeficientas",
        "laisvasis-narys"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Pertvarkome lygtį į standartinį pavidalą y = kx + b.",
          "latex": "y = -1x + 10"
        },
        {
          "text": "Matome koeficientus.",
          "latex": "k = -1, b = 10"
        },
        {
          "text": "Kadangi k < 0, funkcija yra mažėjanti.",
          "latex": "-1 < 0"
        }
      ],
      "answer": "k = -1, b = 10; mažėja."
    },
    {
      "id": "tiesinis-sarysis-exmp-5",
      "title": "Funkcijos nulio radimas",
      "level": "medium",
      "problem": "Raskite funkcijos $y = 4x + 12$ nulį.",
      "conceptIds": [
        "funkcijos-nulis"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Funkcijos nulis yra taškas, kuriame y = 0.",
          "latex": "0 = 4x + 12"
        },
        {
          "text": "Išsprendžiame lygtį.",
          "latex": "-12 = 4x \\Rightarrow x = -3"
        }
      ],
      "answer": "-3"
    },
    {
      "id": "tiesinis-sarysis-exmp-6",
      "title": "Taško priklausomumas",
      "level": "medium",
      "problem": "Ar taškas $M(-2; 7)$ priklauso tiesei $y = -2x + 3$?",
      "conceptIds": [
        "tieses-grafikas"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Įstatome x = -2 ir y = 7 į lygtį.",
          "latex": "7 = -2 \\cdot (-2) + 3"
        },
        {
          "text": "Apskaičiuojame dešinę pusę.",
          "latex": "7 = 4 + 3 \\Rightarrow 7 = 7"
        },
        {
          "text": "Kadangi gavome teisingą lygybę, taškas priklauso.",
          "latex": "7=7"
        }
      ],
      "answer": "Taip, priklauso."
    },
    {
      "id": "tiesinis-sarysis-exmp-7",
      "title": "Lygties sudarymas per du taškus",
      "level": "hard",
      "problem": "Sudarykite tiesės lygtį, jei ji eina per taškus $A(1; 5)$ ir $B(3; 9)$.",
      "conceptIds": [
        "tiesine-funkcija"
      ],
      "formulaIds": [
        "krypties-koeficientas-per-taskus"
      ],
      "steps": [
        {
          "text": "Apskaičiuojame k.",
          "latex": "k = \\frac{9 - 5}{3 - 1} = \\frac{4}{2} = 2"
        },
        {
          "text": "Į lygtį y = 2x + b įstatome taško A koordinates.",
          "latex": "5 = 2 \\cdot 1 + b"
        },
        {
          "text": "Randame b.",
          "latex": "5 = 2 + b \\Rightarrow b = 3"
