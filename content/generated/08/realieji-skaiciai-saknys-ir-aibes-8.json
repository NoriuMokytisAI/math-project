  "theory": [
    {
      "id": "realieji-skaiciai-aibes-ivadas",
      "title": "Įvadas į skaičių pasaulį",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Skaičiai lydi mus kiekviename žingsnyje. Pradedame nuo paprasčiausio daiktų skaičiavimo (1, 2, 3...), o vėliau susiduriame su situacijomis, kur prireikia neigiamų skaičių temperatūrai matuoti, trupmenų dalijant picą ar sudėtingesnių skaičių, tokių kaip $\\pi$ (pi) ar kvadratinė šaknis iš 2, matuojant geometrines figūras. Visi šie skaičiai sudaro vientisą sistemą, kurią vadiname [[realieji-skaiciai|realiųjų skaičių]] aibe."
        },
        {
          "type": "paragraph",
          "text": "Šioje temoje išmoksime ne tik klasifikuoti skaičius į skirtingas šeimas (aibas), bet ir dirbti su šaknimis – veiksmu, kuris leidžia mums rasti skaičių, kurį pakėlus kvadratu ar kubu gautume norimą rezultatą. Tai pamatas, ant kurio laikosi visa vėlesnė algebra ir geometrija."
        }
      ]
    },
    {
      "id": "realieji-skaiciai-aibiu-klasifikacija",
      "title": "Skaičių aibės",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Matematikoje skaičiai skirstomi į aibas pagal jų savybes. Svarbu suprasti, kad mažesnės aibės „gyvena“ didesnių aibių viduje."
        },
        {
          "type": "definition",
          "conceptId": "naturalieji-skaiciai",
          "text": "[[naturalieji-skaiciai|Natūralieji skaičiai]] (žymimi $\\mathbb{N}$) – tai skaičiai, naudojami daiktams skaičiuoti: $1, 2, 3, 4, ...$. Kartais prie jų priskiriamas ir nulis ($0$), tačiau dažniau jis laikomas sveikuoju skaičiumi."
        },
        {
          "type": "definition",
          "conceptId": "sveikieji-skaiciai",
          "text": "[[sveikieji-skaiciai|Sveikieji skaičiai]] (žymimi $\\mathbb{Z}$) – tai natūralieji skaičiai, jiems priešingi neigiami skaičiai ir nulis: $..., -3, -2, -1, 0, 1, 2, 3, ...$."
        },
        {
          "type": "definition",
          "conceptId": "racionalieji-skaiciai",
          "text": "[[racionalieji-skaiciai|Racionalieji skaičiai]] (žymimi $\\mathbb{Q}$) – tai visi skaičiai, kuriuos galime užrašyti kaip nesuprastinamą trupmeną $\\frac{m}{n}$, kur $m \\in \\mathbb{Z}$ (sveikasis skaičius), o $n \\in \\mathbb{N}$ (natūralusis skaičius). Tai apima sveikuosius skaičius, paprastąsias trupmenas, baigtines dešimtaines trupmenas ir periodines dešimtaines trupmenas (pvz., $0,333... = \\frac{1}{3}$)."
        },
        {
          "type": "definition",
          "conceptId": "iracionalieji-skaiciai",
          "text": "[[iracionalieji-skaiciai|Iracionalieji skaičiai]] (žymimi $\\mathbb{I}$) – tai skaičiai, kurių negalima užrašyti kaip santykio $\\frac{m}{n}$. Jų dešimtainė išraiška yra nebaigtinė ir neperiodinė. Garsiausi pavyzdžiai: $\\pi \\approx 3,14159...$ ir $\\sqrt{2} \\approx 1,41421...$."
        },
        {
          "type": "definition",
          "conceptId": "realieji-skaiciai",
          "text": "[[realieji-skaiciai|Realieji skaičiai]] (žymimi $\\mathbb{R}$) – tai visų racionaliųjų ir iracionaliųjų skaičių sąjunga. Kiekvienas taškas skaičių tiesėje atitinka tam tikrą realųjį skaičių."
        },
        {
          "type": "note",
          "text": "Svarbu prisiminti: $\\mathbb{N} \\subset \\mathbb{Z} \\subset \\mathbb{Q} \\subset \\mathbb{R}$. Tai reiškia, kad kiekvienas natūralusis skaičius yra ir sveikasis, ir racionalusis, ir realusis."
        }
      ]
    },
    {
      "id": "realieji-skaiciai-kvadratine-saknis",
      "title": "Kvadratinė šaknis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kvadratinės šaknies traukimas yra veiksmas, atvirkštinis kėlimui kvadratu."
        },
        {
          "type": "definition",
          "conceptId": "kvadratine-saknis",
          "text": "Neneigiamo skaičiaus $a$ [[kvadratine-saknis|kvadratinė šaknis]] (rašoma $\\sqrt{a}$) yra toks neneigiamas skaičius $b$, kurį pakėlę kvadratu gauname $a$. Taigi, $\\sqrt{a} = b$, jei $b^2 = a$ ir $b \\ge 0$."
        },
        {
          "type": "formula",
          "formulaId": "kvadratines-saknies-kvadratas",
          "latex": "(\\sqrt{a})^2 = a \\quad (a \\ge 0)"
        },
        {
          "type": "warning",
          "text": "Pošaknis $a$ kvadratinėje šaknyje $\\sqrt{a}$ negali būti neigiamas skaičius realiųjų skaičių aibėje, nes bet kurį skaičių pakėlę kvadratu gausime neneigiamą rezultatą: $2^2 = 4$ ir $(-2)^2 = 4$."
        },
        {
          "type": "method",
          "text": "Norėdami apskaičiuoti $\\sqrt{a}$, klausiame savęs: koks neneigiamas skaičius pakeltas kvadratu duoda $a$? Pavyzdžiui, $\\sqrt{49} = 7$, nes $7^2 = 49$."
        }
      ]
    },
    {
      "id": "realieji-skaiciai-saknu-savybes",
      "title": "Kvadratinių šaknų savybės",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Dirbant su šaknimis, dažnai prireikia jas suprastinti arba sudauginti. Tam naudojame šias savybes:"
        },
        {
          "type": "formula",
          "title": "Sandaugos šaknis",
          "formulaId": "kvadratines-saknies-savybe-daugyba",
          "latex": "\\sqrt{a \\cdot b} = \\sqrt{a} \\cdot \\sqrt{b} \\quad (a \\ge 0, b \\ge 0)"
        },
        {
          "type": "formula",
          "title": "Santykio šaknis",
          "formulaId": "kvadratines-saknies-savybe-dalyba",
          "latex": "\\sqrt{\\frac{a}{b}} = \\frac{\\sqrt{a}}{\\sqrt{b}} \\quad (a \\ge 0, b > 0)"
        },
        {
          "type": "formula",
          "title": "Kvadratas po šaknimi",
          "formulaId": "skaiciaus-kvadrato-saknis",
          "latex": "\\sqrt{a^2} = |a|"
        },
        {
          "type": "paragraph",
          "text": "Šios savybės leidžia mums **iškelti daugiklį prieš šaknies ženklą**. Pavyzdžiui: $\\sqrt{12} = \\sqrt{4 \\cdot 3} = \\sqrt{4} \\cdot \\sqrt{3} = 2\\sqrt{3}$."
        },
        {
          "type": "paragraph",
          "text": "Taip pat galime **įkelti daugiklį po šaknies ženklu**: $3\\sqrt{2} = \\sqrt{3^2 \\cdot 2} = \\sqrt{9 \\cdot 2} = \\sqrt{18}$."
        }
      ]
    },
    {
      "id": "realieji-skaiciai-kubine-saknis",
      "title": "Kubinė šaknis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kubinė šaknis yra susijusi su kėlimu kubu ($a^3$)."
        },
        {
          "type": "definition",
          "conceptId": "kubine-saknis",
          "text": "Skaičiaus $a$ [[kubine-saknis|kubinė šaknis]] (rašoma $\\sqrt[3]{a}$) yra toks skaičius $b$, kurį pakėlę kubu gauname $a$. Taigi, $\\sqrt[3]{a} = b$, jei $b^3 = a$."
        },
        {
          "type": "note",
          "text": "Skirtingai nei kvadratinė šaknis, kubinė šaknis gali būti traukiama ir iš neigiamų skaičių. Pavyzdžiui, $\\sqrt[3]{-8} = -2$, nes $(-2)^3 = -8$."
        },
        {
          "type": "formula",
          "formulaId": "kubines-saknies-savybe-daugyba",
          "latex": "\\sqrt[3]{a \\cdot b} = \\sqrt[3]{a} \\cdot \\sqrt[3]{b}"
        }
      ]
    },
    {
      "id": "realieji-skaiciai-iracionalumas-vardiklyje",
      "title": "Iracionalumo naikinimas vardiklyje",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Matematikoje laikoma „gražiau“, jei trupmenos vardiklyje nėra šaknies. Norėdami jos atsikratyti, skaitiklį ir vardiklį dauginame iš tokios pačios šaknies."
        },
        {
          "type": "method",
          "text": "Pavyzdys: $\\frac{6}{\\sqrt{2}} = \\frac{6 \\cdot \\sqrt{2}}{\\sqrt{2} \\cdot \\sqrt{2}} = \\frac{6\\sqrt{2}}{2} = 3\\sqrt{2}$."
        }
      ]
    },
    {
      "id": "realieji-skaiciai-palyginimas",
      "title": "Šaknų įvertinimas ir palyginimas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kadangi daugelis šaknų yra iracionalieji skaičiai, jų tikslią reikšmę galime tik apytiksliai įvertinti tarp dviejų gretimų sveikųjų skaičių."
        },
        {
          "type": "method",
          "text": "Pavyzdžiui, tarp kokių sveikųjų skaičių yra $\\sqrt{20}$? Žinome, kad $4^2 = 16$ ir $5^2 = 25$. Kadangi $16 < 20 < 25$, tai $4 < \\sqrt{20} < 5$."
        }
      ]
    },
    {
      "id": "realieji-skaiciai-klaidos",
      "title": "Dažnos klaidos",
      "blocks": [
        {
          "type": "warning",
          "text": "Didžiausia klaida: manyti, kad $\\sqrt{a + b} = \\sqrt{a} + \\sqrt{b}$. PATIKRINKIME: $\\sqrt{9 + 16} = \\sqrt{25} = 5$, bet $\\sqrt{9} + \\sqrt{16} = 3 + 4 = 7$. Matome, kad $5 \\ne 7$!"
        },
        {
          "type": "warning",
          "text": "Nepamirškite: $\\sqrt{-16}$ neegzistuoja realiųjų skaičių aibėje, bet $\\sqrt[3]{-27}$ yra lygus $-3$."
        }
      ]
    }
  ],
