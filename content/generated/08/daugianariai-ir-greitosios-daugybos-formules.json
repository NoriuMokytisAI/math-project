  "theory": [
    {
      "id": "vienanariai-ir-daugianariai-ivadas",
      "title": "Vienanariai ir jų standartinė išraiška",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Algebra prasideda nuo paprasčiausių raidinių reiškinių, kurie vadinami vienanariais. Suprasti vienanarius yra būtina, norint sėkmingai dirbti su sudėtingesnėmis konstrukcijomis – daugianariais."
        },
        {
          "type": "definition",
          "conceptId": "vienanaris",
          "text": "[[vienanaris|Vienanaris]] – tai reiškinys, susidedantis iš skaičių, raidžių (kintamųjų) ir jų laipsnių sandaugos."
        },
        {
          "type": "paragraph",
          "text": "Vienanario pavyzdžiai: $5x$, $-2a^2b$, $x^3$, $7$. Atkreipkite dėmesį, kad net ir vienas skaičius arba viena raidė yra laikomi vienanariais."
        },
        {
          "type": "method",
          "title": "Vienanario standartinė išraiška",
          "text": "Vienanaris yra standartinės išraiškos, kai: 1) pirmas parašytas vienintelis skaitinis daugiklis (koeficientas); 2) kintamieji surašyti abėcėlės tvarka; 3) vienodos raidės pakeistos jų laipsniu."
        },
        {
          "type": "example",
          "text": "Vienanarį $2a \\cdot 3b \\cdot a$ sutvarkykime iki standartinės išraiškos: $2 \\cdot 3 \\cdot a \\cdot a \\cdot b = 6a^2b$."
        },
        {
          "type": "note",
          "text": "Vienanario laipsnis yra visų jo kintamųjų laipsnių rodiklių suma. Pavyzdžiui, $6a^2b^1$ laipsnis yra $2 + 1 = 3$."
        }
      ]
    },
    {
      "id": "daugianariai-savoka-ir-laipsnis",
      "title": "Daugianariai: sąvoka ir laipsnis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kai sudedame arba atimame kelis vienanarius, gauname sudėtingesnį reiškinį."
        },
        {
          "type": "definition",
          "conceptId": "daugianaris",
          "text": "[[daugianaris|Daugianaris]] – tai kelių vienanarių algebrainė suma."
        },
        {
          "type": "paragraph",
          "text": "Daugianariai skirstomi pagal narių skaičių: dvinaris ($x+y$), trinaris ($a^2+2ab+b^2$) ir t. t. Bendru atveju juos visus vadiname daugianariais."
        },
        {
          "type": "note",
          "text": "Daugianario laipsniu vadinamas didžiausias jį sudarančių vienanarių laipsnis (kai daugianaris yra sutvarkytas)."
        },
        {
          "type": "paragraph",
          "text": "Pavyzdžiui, daugianario $3x^4 - 2x^2 + 5$ laipsnis yra 4, nes didžiausias nario laipsnis yra $x^4$."
        }
      ]
    },
    {
      "id": "veiksmai-su-daugianariais-sudetis",
      "title": "Veiksmai su daugianariais: sudėtis ir atimtis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Sudedant arba atimant daugianarius, svarbiausia taisyklė yra **panašių narių sutraukimas**."
        },
        {
          "type": "definition",
          "conceptId": "panasus-nariai",
          "text": "[[panasus-nariai|Panašūs nariai]] – tai vienanariai, kurie turi visiškai tokią pačią raidinę dalį."
        },
        {
          "type": "method",
          "title": "Skliaustų atvėrimas",
          "text": "1) Jei prieš skliaustus yra pliusas (+), skliaustus tiesiog panaikiname, o narių ženklų nekeičiame. 2) Jei prieš skliaustus yra minusas (-), panaikinę skliaustus, visų narių ženklus pakeičiame priešingais."
        },
        {
          "type": "warning",
          "text": "Minusis prieš skliaustus yra viena dažniausių klaidų vietų. Būkite labai atidūs keisdami kiekvieno nario ženklą!"
        },
        {
          "type": "example",
          "text": "$(3x^2 - 5x) - (x^2 - 2x + 1) = 3x^2 - 5x - x^2 + 2x - 1 = 2x^2 - 3x - 1$."
        }
      ]
    },
    {
      "id": "daugianariu-daugyba",
      "title": "Daugianarių daugyba",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Daugianarių daugyba remiasi sklaidos (distributyvumo) dėsniu."
        },
        {
          "type": "method",
          "title": "Vienanario daugyba iš daugianario",
          "text": "Vienanarį padauginame iš kiekvieno daugianario nario."
        },
        {
          "type": "formula",
          "formulaId": "sklaidos-desnis",
          "latex": "a(b + c) = ab + ac"
        },
        {
          "type": "method",
          "title": "Daugianario daugyba iš daugianario",
          "text": "Kiekvieną pirmojo daugianario narį padauginame iš kiekvieno antrojo daugianario nario ir gautus rezultatus sudedame."
        },
        {
          "type": "example",
          "text": "$(x + 2)(y - 3) = x \\cdot y + x \\cdot (-3) + 2 \\cdot y + 2 \\cdot (-3) = xy - 3x + 2y - 6$."
        }
      ]
    },
    {
      "id": "greitosios-daugybos-formules-kvadratai",
      "title": "Greitosios daugybos formulės: Sumos ir skirtumo kvadratas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Yra atvejų, kai daugianarius dauginti galima daug greičiau, naudojant specialias formules."
        },
        {
          "type": "formula",
          "title": "Sumos kvadratas",
          "formulaId": "sumos-kvadratas",
          "latex": "(a + b)^2 = a^2 + 2ab + b^2"
        },
        {
          "type": "formula",
          "title": "Skirtumo kvadratas",
          "formulaId": "skirtumo-kvadratas",
          "latex": "(a - b)^2 = a^2 - 2ab + b^2"
        },
        {
          "type": "note",
          "text": "Sumos kvadratas yra lygus pirmo nario kvadratui, pridėjus dvigubą pirmo ir antro narių sandaugą ir pridėjus antro nario kvadratą."
        },
        {
          "type": "warning",
          "text": "Klaida: $(a+b)^2 = a^2 + b^2$. Tai neteisinga! Visada pamirštamas vidurinis narys $2ab$."
        }
      ]
    },
    {
      "id": "greitosios-daugybos-formules-skirtumas",
      "title": "Greitosios daugybos formulės: Kvadratų skirtumas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Dar viena labai svarbi formulė padeda sudauginti dviejų narių skirtumą iš jų sumos."
        },
        {
          "type": "formula",
          "title": "Kvadratų skirtumas",
          "formulaId": "kvadratu-skirtumas",
          "latex": "(a - b)(a + b) = a^2 - b^2"
        },
        {
          "type": "paragraph",
          "text": "Ši formulė veikia ir atgal: pamatę dviejų kvadratų skirtumą, galime jį išskaidyti į du skliaustus."
        },
        {
          "type": "example",
          "text": "$x^2 - 16 = x^2 - 4^2 = (x - 4)(x + 4)$."
        }
      ]
    },
    {
      "id": "daugianariu-skaidymas-dauginamaisiais",
      "title": "Daugianarių skaidymas dauginamaisiais",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Skaidymas dauginamaisiais yra veiksmas, priešingas skliaustų atvėrimui. Mes norime daugianarį paversti sandauga."
        },
        {
          "type": "method",
          "title": "Iškėlimas prieš skliaustus",
          "text": "Randame didžiausią bendrąjį daliklį visiems nariams (tiek skaičių, tiek raidžių) ir jį iškeliame."
        },
        {
          "type": "example",
          "text": "$6x^2 + 9x = 3x(2x + 3)$. Čia $3x$ yra bendras daugiklis."
        },
        {
          "type": "method",
          "title": "Grupavimo būdas",
          "text": "Jei bendro daugiklio visiems nariams nėra, narius sugrupuojame poromis taip, kad kiekviena pora turėtų bendrą daugiklį. Iškėlę juos, tikimės gauti vienodus skliaustus."
        },
        {
          "type": "example",
          "text": "$ax + ay + bx + by = a(x+y) + b(x+y) = (x+y)(a+b)$."
        }
      ]
    },
    {
      "id": "daugianariai-klaidos-ir-patarimai",
      "title": "Dažniausios klaidos ir patarimai",
      "blocks": [
        {
          "type": "warning",
          "title": "Ženklų painiojimas",
          "text": "Dauginant neigiamą skaičių iš neigiamo, gaunamas teigiamas. Pvz.: $-2(-x+3) = 2x - 6$."
        },
        {
          "type": "warning",
          "title": "Netinkamas laipsnių kėlimas",
          "text": "Keliant vienanarį kvadratu, reikia pakelti KIEKVIENĄ jo dalį: $(3x)^2 = 3^2 \\cdot x^2 = 9x^2$ (o ne $3x^2$)."
        },
        {
          "type": "note",
          "text": "Visada patikrinkite skaidymą vėl sudaugindami skliaustus – turite gauti pradinį reiškinį."
        }
      ]
    }
  ],
