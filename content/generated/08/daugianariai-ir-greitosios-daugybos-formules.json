  "workedExamples": [
    {
      "id": "daugianariai-exmp-1",
      "title": "Vienanario daugyba iš daugianario",
      "level": "easy",
      "problem": "Padauginkite: $3x(2x - 4)$.",
      "conceptIds": [
        "vienanaris",
        "daugianaris"
      ],
      "steps": [
        {
          "text": "Dauginame $3x$ iš pirmo nario $2x$.",
          "latex": "3x \\cdot 2x = 6x^2"
        },
        {
          "text": "Dauginame $3x$ iš antro nario $-4$.",
          "latex": "3x \\cdot (-4) = -12x"
        },
        {
          "text": "Surašome rezultatą.",
          "latex": "6x^2 - 12x"
        }
      ],
      "answer": "6x^2 - 12x"
    },
    {
      "id": "daugianariai-exmp-2",
      "title": "Daugianarių atimtis",
      "level": "easy",
      "problem": "Suprastinkite: $(5a - 3) - (2a + 7)$.",
      "conceptIds": [
        "daugianaris",
        "panasus-nariai"
      ],
      "steps": [
        {
          "text": "Atskliaudžiame keisdami ženklus antrame skliauste.",
          "latex": "5a - 3 - 2a - 7"
        },
        {
          "text": "Sutraukiame panašiuosius narius.",
          "latex": "(5a - 2a) + (-3 - 7) = 3a - 10"
        }
      ],
      "answer": "3a - 10"
    },
    {
      "id": "daugianariai-exmp-3",
      "title": "Daugianarių daugyba",
      "level": "medium",
      "problem": "Padauginkite: $(x + 3)(x - 5)$.",
      "conceptIds": [
        "daugianaris"
      ],
      "steps": [
        {
          "text": "Dauginame narį po nario (kiekvieną su kiekvienu).",
          "latex": "x^2 - 5x + 3x - 15"
        },
        {
          "text": "Sutraukiame panašiuosius narius.",
          "latex": "x^2 - 2x - 15"
        }
      ],
      "answer": "x^2 - 2x - 15"
    },
    {
      "id": "daugianariai-exmp-4",
      "title": "Sumos kvadrato formulė",
      "level": "medium",
      "problem": "Išskleiskite: $(2x + 3)^2$.",
      "conceptIds": [
        "greitosios-daugybos-formules"
      ],
      "formulaIds": [
        "sumos-kvadratas"
      ],
      "steps": [
        {
          "text": "Taikome formulę $(a+b)^2 = a^2 + 2ab + b^2$, kur $a=2x$ ir $b=3$.",
          "latex": "(2x)^2 + 2 \\cdot 2x \\cdot 3 + 3^2"
        },
        {
          "text": "Apskaičiuojame kiekvieną dėmenį.",
          "latex": "4x^2 + 12x + 9"
        }
      ],
      "answer": "4x^2 + 12x + 9"
    },
    {
      "id": "daugianariai-exmp-5",
      "title": "Skirtumo kvadrato formulė",
      "level": "medium",
      "problem": "Išskleiskite: $(y - 4)^2$.",
      "conceptIds": [
        "greitosios-daugybos-formules"
      ],
      "formulaIds": [
        "skirtumo-kvadratas"
      ],
      "steps": [
        {
          "text": "Taikome formulę $(a-b)^2 = a^2 - 2ab + b^2$.",
          "latex": "y^2 - 2 \\cdot y \\cdot 4 + 4^2"
        },
        {
          "text": "Supaprastiname.",
          "latex": "y^2 - 8y + 16"
        }
      ],
      "answer": "y^2 - 8y + 16"
    },
    {
      "id": "daugianariai-exmp-6",
      "title": "Kvadratų skirtumo formulė",
      "level": "medium",
      "problem": "Padauginkite: $(5 - z)(5 + z)$.",
      "conceptIds": [
        "greitosios-daugybos-formules"
      ],
      "formulaIds": [
        "kvadratu-skirtumas"
      ],
      "steps": [
        {
          "text": "Taikome formulę $(a-b)(a+b) = a^2 - b^2$.",
          "latex": "5^2 - z^2"
        },
        {
          "text": "Apskaičiuojame.",
          "latex": "25 - z^2"
        }
      ],
      "answer": "25 - z^2"
    },
    {
      "id": "daugianariai-exmp-7",
      "title": "Iškėlimas prieš skliaustus",
      "level": "medium",
      "problem": "Išskaidykite dauginamaisiais: $12a^3 - 8a^2$.",
      "conceptIds": [
        "skaidymas-dauginamaisiais"
      ],
      "steps": [
        {
          "text": "Randame bendrą skaitinį daliklį (4) ir raidžių daliklį ($a^2$).",
          "latex": "4a^2"
        },
        {
          "text": "Iškeliame bendrą daugiklį.",
          "latex": "4a^2(3a - 2)"
        }
      ],
      "answer": "4a^2(3a - 2)"
    },
    {
      "id": "daugianariai-exmp-8",
      "title": "Grupavimo būdas",
      "level": "hard",
      "problem": "Išskaidykite: $xy - 2y + 3x - 6$.",
      "conceptIds": [
        "skaidymas-dauginamaisiais"
      ],
      "steps": [
        {
          "text": "Grupuojame pirmus du ir paskutinius du narius.",
          "latex": "(xy - 2y) + (3x - 6)"
        },
        {
          "text": "Iškeliame bendrus daugiklius iš kiekvienos grupės.",
          "latex": "y(x - 2) + 3(x - 2)"
        },
        {
          "text": "Iškeliame bendrą skliaustą $(x-2)$.",
          "latex": "(x - 2)(y + 3)"
        }
      ],
      "answer": "(x - 2)(y + 3)"
    }
  ],
