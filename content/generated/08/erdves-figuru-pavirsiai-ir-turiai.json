  "workedExamples": [
    {
      "id": "3d-exmp-1",
      "title": "Ritinio tūris",
      "level": "easy",
      "problem": "Ritinio pagrindo spindulys r = 3 cm, o aukštinė H = 10 cm. Rask tūrį. (π ≈ 3,14).",
      "conceptIds": [
        "ritinys",
        "turis"
      ],
      "steps": [
        {
          "text": "Apskaičiuojame pagrindo plotą.",
          "latex": "S_{\\text{pagr}} = \\pi r^2 = 3,14 \\cdot 3^2 = 3,14 \\cdot 9 = 28,26 \\text{ cm}^2"
        },
        {
          "text": "Dauginame iš aukštinės.",
          "latex": "V = 28,26 \\cdot 10 = 282,6 \\text{ cm}^3"
        }
      ],
      "answer": "282,6 cm³"
    },
    {
      "id": "3d-exmp-2",
      "title": "Kūgio sudaromoji",
      "level": "medium",
      "problem": "Kūgio aukštinė H = 4 cm, o spindulys r = 3 cm. Rask sudaromąją l.",
      "conceptIds": [
        "kugis",
        "sudaromoji"
      ],
      "steps": [
        {
          "text": "Taikome Pitagoro teoremą trikampiui, kurį sudaro r, H ir l.",
          "latex": "l^2 = r^2 + H^2"
        },
        {
          "text": "Įrašome reikšmes.",
          "latex": "l^2 = 3^2 + 4^2 = 9 + 16 = 25"
        },
        {
          "text": "Traukiame šaknį.",
          "latex": "l = \\sqrt{25} = 5 \\text{ cm}"
        }
      ],
      "answer": "5 cm"
    }
  ],
