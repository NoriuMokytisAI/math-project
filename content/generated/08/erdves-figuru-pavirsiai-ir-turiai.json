  "theory": [
    {
      "id": "erdves-figuru-ivadas",
      "title": "Erdvės figūros ir tūrio samprata",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Erdvės figūros (kūnai) turi ne tik paviršiaus plotą, bet ir [[turis|tūrį]] – erdvės dalį, kurią jos užima. Tūris matuojamas kubiniais vienetais (cm³, m³)."
        },
        {
          "type": "definition",
          "conceptId": "stacioji-prizme",
          "text": "[[stacioji-prizme|Stačioji prizmė]] – tai kūnas, kurio šoninės briaunos yra statmenos pagrindams. Jos tūris lygus pagrindo ploto ir aukštinės sandaugai."
        },
        {
          "type": "formula",
          "formulaId": "prizmes-turio-formule",
          "latex": "V = S_{\\text{pagr}} \\cdot H"
        }
      ]
    },
    {
      "id": "piramides-teorija",
      "title": "Taisyklingoji piramidė",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[taisyklingoji-piramide|Taisyklingoji piramidė]] turi pagrindą (taisyklingąjį daugiakampį) ir viršūnę. Svarbu skirti piramidės [[aukstine|aukštinę]] H ir šoninės sienos aukštinę – [[apotema|apotemą]] h_a."
        },
        {
          "type": "note",
          "text": "Piramidės tūris yra tris kartus mažesnis už tokio pat pagrindo ir aukštinės prizmės tūrį."
        },
        {
          "type": "formula",
          "formulaId": "piramides-turio-formule",
          "latex": "V = \\frac{1}{3} S_{\\text{pagr}} \\cdot H"
        }
      ]
    },
    {
      "id": "ritinys-ir-kugis",
      "title": "Ritinys ir kūgis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[ritinys|Ritinio]] pagrindas yra skritulys. [[kugis|Kūgio]] pagrindas taip pat skritulys, bet jis baigiasi viršūne."
        },
        {
          "type": "formula",
          "formulaId": "ritinio-turio-formule",
          "latex": "V_{\\text{rit}} = \\pi r^2 H"
        },
        {
          "type": "formula",
          "formulaId": "kugio-turio-formule",
          "latex": "V_{\\text{kūg}} = \\frac{1}{3} \\pi r^2 H"
        },
        {
          "type": "paragraph",
          "text": "Kūgio šoninė atkarpa, jungianti viršūnę su apskritimo tašku, vadinama [[sudaromoji|sudaromąja]] (l)."
        }
      ]
    },
    {
      "id": "sfera-ir-rutulys",
      "title": "Sfera ir rutulys",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "sfera",
          "text": "[[sfera|Sfera]] yra rutulio paviršius (tarsi krepšinio kamuolio oda), o rutulys apima ir vidų."
        },
        {
          "type": "formula",
          "formulaId": "sferos-ploto-formule",
          "latex": "S = 4\\pi r^2"
        },
        {
          "type": "formula",
          "formulaId": "sferos-turio-formule",
          "latex": "V = \\frac{4}{3} \\pi r^3"
        }
      ]
    },
    {
      "id": "pitagoro-taikymas-3d",
      "title": "Pitagoro teoremos taikymas erdvėje",
      "blocks": [
        {
          "type": "method",
          "text": "Erdvės figūrose dažnai reikia rasti aukštinę arba sudaromąją naudojant Pitagoro teoremą. Pvz., kūgyje: r² + H² = l²."
        }
      ]
    }
  ],
