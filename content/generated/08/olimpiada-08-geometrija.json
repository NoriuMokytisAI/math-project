  "theory": [
    {
      "id": "apskritimo-geometrija",
      "title": "Apskritimo geometrija ir taško galia",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Geometrijoje ryšiai tarp kampų ir atkarpų apskritime leidžia įrodyti daugelį teoremų. Kampas tarp stygų arba liestinių yra susijęs su atitinkamų lankų dydžiais, o stygų susikirtimo taškas turi pastovią sandaugą."
        },
        {
          "type": "method",
          "text": "Taško galios teorema teigia, kad jei dvi stygos $AB$ ir $CD$ susikerta taške $P$ apskritimo viduje, tai $PA \\cdot PB = PC \\cdot PD$."
        }
      ]
    },
    {
      "id": "cevos-ir-menelajo-teoremos",
      "title": "Trikampio čevianės",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Čevos teorema: Trys čevianės $AD, BE, CF$ susikerta viename taške tada ir tik tada, kai $\\frac{AF}{FB} \\cdot \\frac{BD}{DC} \\cdot \\frac{CE}{EA} = 1$."
        }
      ]
    },
    {
      "id": "ptolemejo-teorema-teorija",
      "title": "Įbrėžtiniai keturkampiai",
      "blocks": [
        {
          "type": "theorem",
          "text": "Ptolemėjo teorema: Į apskritimą įbrėžto keturkampio priešingų kraštinių sandaugų suma lygi jo įstrižainių sandaugai."
        }
      ]
    }
  ],
  "concepts": [
    {
