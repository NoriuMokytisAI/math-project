  "workedExamples": [
    {
      "title": "Herono formulės taikymas",
      "problem": "Kraštinės 13, 14, 15. Raskite plotą.",
      "steps": [
        {
          "text": "p=21. S=84."
        }
      ],
      "answer": "84"
    },
    {
      "title": "Panašumas",
      "problem": "k=3, Sb=5. Raskite Sa.",
      "steps": [
        {
          "text": "Sa = 3^2 * 5 = 45."
        }
      ],
      "answer": "45"
    },
    {
      "title": "Įbrėžtinis keturkampis",
      "problem": "A=80. Raskite C.",
      "steps": [
        {
          "text": "C = 180-80 = 100."
        }
      ],
      "answer": "100"
    },
    {
      "title": "Čevos teoremos taikymas",
      "problem": "AF/FB=1, BD/DC=2. Raskite CE/EA.",
      "steps": [
        {
          "text": "1 * 2 * CE/EA = 1 \\implies CE/EA = 0.5."
        }
      ],
      "answer": "0.5"
    },
    {
      "title": "Liestinė ir kirstinė",
      "problem": "PT=4, PA=2. Raskite kirstinę PB.",
      "steps": [
        {
          "text": "4^2 = 2 * PB \\implies 16 = 2 * PB \\implies PB = 8."
        }
      ],
      "answer": "8"
    }
  ],
