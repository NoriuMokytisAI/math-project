  "workedExamples": [
    {
      "id": "we-geo-8-1",
      "title": "Taško galios taikymas",
      "level": "medium",
      "problem": "Dvi apskritimo stygos $AB$ ir $CD$ susikerta taške $P$. Žinoma, kad $AP=4, PB=6, CP=3$. Raskite atkarpos $PD$ ilgį.",
      "conceptIds": [
        "tasko-galia"
      ],
      "steps": [
        {
          "text": "Pagal stygų sankirtos savybę (taško galią), $AP \\cdot PB = CP \\cdot PD$."
        },
        {
          "text": "Įstatome žinomas vertes: $4 \\cdot 6 = 3 \\cdot PD$."
        },
        {
          "text": "$24 = 3 \\cdot PD \\implies PD = 8$."
        }
      ],
      "answer": "8"
    },
    {
      "id": "we-geo-8-2",
      "title": "Čevos teoremos taikymas: Pusiaukraštinės",
      "level": "easy",
      "problem": "Įrodykite, kad trikampio pusiaukraštinės susikerta viename taške.",
      "conceptIds": [
        "cevos-teorema"
      ],
      "steps": [
        {
          "text": "Pusiaukraštinės dalija kraštines pusiau, todėl taškai $D, E, F$ yra vidurio taškai."
        },
        {
          "text": "Atkarpų santykiai: $AF/FB = 1, BD/DC = 1, CE/EA = 1$."
        },
        {
          "text": "Sandauga: $1 \\cdot 1 \\cdot 1 = 1$."
        },
        {
          "text": "Pagal Čevos teoremą, kadangi sandauga lygi 1, pusiaukraštinės susikerta viename taške."
        }
      ],
      "answer": "Įrodyta"
    },
    {
      "id": "we-geo-8-3",
      "title": "Ptolemėjo teorema lygiašonėje trapecijoje",
      "level": "medium",
      "problem": "Lygiašonės trapecijos kraštinės yra $a=5, b=5, c=5$ (šoninės ir trumpasis pagrindas), o ilgas pagrindas $d=11$. Raskite įstrižainę $x$.",
      "conceptIds": [
        "ptolemejo-teorema"
      ],
      "steps": [
        {
          "text": "Lygiašonė trapecija visada yra įbrėžtinis keturkampis."
        },
        {
          "text": "Taikome Ptolemėjo teoremą: $x \\cdot x = 5 \\cdot 5 + 5 \\cdot 11$."
        },
        {
          "text": "$x^2 = 25 + 55 = 80$."
        },
        {
          "text": "$x = \\sqrt{80} = 4\\sqrt{5}$."
        }
      ],
      "answer": "4\\sqrt{5}"
    },
    {
      "id": "we-geo-8-4",
      "title": "Herono formulė ir R radimas",
      "level": "medium",
      "problem": "Trikampio kraštinės yra 7, 8, 9. Raskite jo plotą ir apibrėžtinio apskritimo spindulį $R$.",
      "conceptIds": [
        "herono-formule"
      ],
      "steps": [
        {
          "text": "Pusperimetris $p = (7+8+9)/2 = 12$."
        },
        {
          "text": "Plotas $S = \\sqrt{12(12-7)(12-8)(12-9)} = \\sqrt{12 \\cdot 5 \\cdot 4 \\cdot 3} = \\sqrt{720} = 12\\sqrt{5}$."
        },
        {
          "text": "Spindulys $R = abc / (4S) = (7 \\cdot 8 \\cdot 9) / (4 \\cdot 12\\sqrt{5}) = 504 / (48\\sqrt{5}) = 10.5 / \\sqrt{5} = 2.1\\sqrt{5}$."
        }
      ],
      "answer": "S=12√5, R=2.1√5"
    },
    {
      "id": "we-geo-8-5",
      "title": "Menelajo teorema ir santykių radimas",
      "level": "hard",
      "problem": "Trikampyje $ABC$ taškas $D$ yra kraštinėje $BC$ taip, kad $BD=2DC$. Taškas $E$ yra kraštinėje $AC$ taip, kad $AE=3EC$. Atkarpos $AD$ ir $BE$ susikerta taške $P$. Raskite santykį $AP:PD$.",
      "conceptIds": [
        "menelajo-teorema"
      ],
      "steps": [
        {
          "text": "Taikome Menelajo teoremą trikampiui $ADC$ ir tiesei $BPE$."
        },
        {
          "text": "Formulė: $\\frac{AP}{PD} \\cdot \\frac{DB}{BC} \\cdot \\frac{CE}{EA} = 1$."
        },
        {
          "text": "Žinome $DB = 2DC$, tad $BC = 3DC$. Santykis $DB/BC = 2/3$. Žinome $AE = 3EC$, tad $CE/EA = 1/3$."
        },
        {
          "text": "$\\frac{AP}{PD} \\cdot \\frac{2}{3} \\cdot \\frac{1}{3} = 1 \\implies \\frac{AP}{PD} \\cdot \\frac{2}{9} = 1 \\implies \\frac{AP}{PD} = 4.5$."
        }
      ],
      "answer": "9:2"
    }
  ],
