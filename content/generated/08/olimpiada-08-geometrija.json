  "theory": [
    {
      "id": "geo-8-theory-1",
      "title": "Apskritimo geometrija: Nuo kampų iki taško galios",
      "blocks": [
        {
          "type": "paragraph",
          "text": "8-os klasės olimpiadinė geometrija smarkiai išplečia žinias apie apskritimus. Be standartinių įbrėžtinių ir centrinių kampų, čia susiduriame su galingesnėmis metrinėmis savybėmis."
        },
        {
          "type": "definition",
          "title": "Taško galia apskritimo atžvilgiu",
          "text": "Tarkime, turime apskritimą $\\omega$ ir tašką $P$. Jei per $P$ nubrėžiame bet kokią kirstinę, kertančią apskritimą taškuose $A$ ir $B$, tai sandauga $PA \\cdot PB$ (atsižvelgiant į kryptį) yra pastovi. Ši vertė vadinama taško $P$ galia."
        },
        {
          "type": "strategy",
          "title": "Trys galios atvejai",
          "text": "1. **Stygų sankirta:** Jei $P$ yra apskritimo viduje, tai $PA \\cdot PB = PC \\cdot PD$. \n 2. **Kirstinių sankirta:** Jei $P$ yra išorėje, tai $PA \\cdot PB = PC \\cdot PD$. \n 3. **Liestinė ir kirstinė:** Jei $PT$ yra liestinė, o $PAB$ kirstinė, tai $PT^2 = PA \\cdot PB$."
        }
      ]
    },
    {
      "id": "geo-8-theory-2",
      "title": "Trikampio čevianės: Čevos ir Menelajo teoremos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Čevianė – tai bet kokia atkarpa, jungianti trikampio viršūnę su priešingos kraštinės tašku (pvz., pusiaukraštinė, aukštinė, pusiaukampinė)."
        },
        {
          "type": "theorem",
          "title": "Čevos teorema",
          "text": "Trikampio $ABC$ čevianės $AD, BE, CF$ susikerta viename taške tada ir tik tada, kai: \n $\\frac{AF}{FB} \\cdot \\frac{BD}{DC} \\cdot \\frac{CE}{EA} = 1$."
        },
        {
          "type": "theorem",
          "title": "Menelajo teorema",
          "text": "Tarkime, tiesė kerta trikampio $ABC$ kraštines (arba jų pratęsimus) taškuose $D, E, F$. Taškai $D, E, F$ yra vienoje tiesėje tada ir tik tada, kai: \n $\\frac{AF}{FB} \\cdot \\frac{BD}{DC} \\cdot \\frac{CE}{EA} = 1$."
        },
        {
          "type": "warning",
          "text": "Atkreipkite dėmesį, kad formulės atrodo identiškai, tačiau Menelajo teoremoje vienas arba trys taškai būtinai turi gulėti ant kraštinių pratęsimų (išorėje)."
        }
      ]
    },
    {
      "id": "geo-8-theory-3",
      "title": "Įbrėžtiniai keturkampiai ir Ptolemėjo teorema",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Keturkampis vadinamas įbrėžtiniu, jei apie jį galima apibrėžti apskritimą. Pagrindinis požymis: priešingų kampų suma lygi $180^\\circ$."
        },
        {
          "type": "theorem",
          "title": "Ptolemėjo teorema",
          "text": "Į apskritimą įbrėžto keturkampio priešingų kraštinių sandaugų suma lygi jo įstrižainių sandaugai: \n $AB \\cdot CD + BC \\cdot AD = AC \\cdot BD$."
        },
        {
          "type": "strategy",
          "title": "Simsonio tiesė",
          "text": "Jei iš taško $P$, esančio ant trikampio apibrėžtinio apskritimo, nuleidžiame statmenis į trikampio kraštines, tai šių statmenų pagrindai guli vienoje tiesėje. Tai vadinama Simsonio tiese."
        }
      ]
    },
    {
      "id": "geo-8-theory-4",
      "title": "Išplėstinis plotų metodas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Olimpiadose dažnai neužtenka žinoti $S = \\frac{1}{2}ah$. Reikia naudoti formules, jungiančias plotą su kitais elementais."
        },
        {
          "type": "formula",
          "title": "Herono formulė",
          "text": "$S = \\sqrt{p(p-a)(p-b)(p-c)}$, kur $p = \\frac{a+b+c}{2}$."
        },
        {
          "type": "formula",
          "title": "Plotas per spindulius",
          "text": "$S = pr = \\frac{abc}{4R}$, kur $r$ – įbrėžtinio, o $R$ – apibrėžtinio apskritimo spindulys."
        },
        {
          "type": "paragraph",
          "text": "Šios formulės leidžia „susieti“ linijinius matmenis su ploto invariantu, o tai dažnai yra raktas į sudėtingus įrodymus."
        }
      ]
    },
    {
      "id": "geo-8-theory-5",
      "title": "Oilerio tiesė ir devynių taškų apskritimas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kiekviename trikampyje aukštinių susikirtimo taškas (ortocentras $H$), apibrėžtinio apskritimo centras $O$ ir pusiaukraštinių susikirtimo taškas (centroidas $G$) guli vienoje tiesėje. Ši tiesė vadinama Oilerio tiese."
        },
        {
          "type": "strategy",
          "title": "Atstumų santykis",
          "text": "Svarbu atsiminti, kad taškas $G$ dalija atkarpą $HO$ santykiu $HG : GO = 2 : 1$. Tai leidžia perkelti geometrinį uždavinį į algebrinę santykių plokštumą."
        }
      ]
    }
  ],
