  "workedExamples": [
    {
      "title": "Tiesinės diofantinės lygties sprendimas",
      "problem": "Išspręskite sveikaisiais skaičiais lygtį $3x - 5y = 1$.",
      "steps": [
        {
          "text": "Kadangi $\\text{dbd}(3, -5) = 1$, lygtis turi sveikųjų sprendinių."
        },
        {
          "text": "Spėliojimo būdu randame vieną atskirąjį sprendinį: jei $x = 2$, tai $3(2) - 5(1) = 1$. Sprendinys $(2, 1)$."
        },
        {
          "text": "Bendrasis sprendinys: $x = 2 + 5t, y = 1 + 3t, t \\in \\mathbb{Z}$."
        }
      ],
      "answer": "x = 2+5t, y = 1+3t"
    },
    {
      "title": "Skaičių palyginimas laipsniais",
      "problem": "Kuris skaičius didesnis: $2^{300}$ ar $3^{200}$?",
      "steps": [
        {
          "text": "$2^{300} = (2^3)^{100} = 8^{100}$."
        },
        {
          "text": "$3^{200} = (3^2)^{100} = 9^{100}$."
        },
        {
          "text": "$9 > 8$, todėl $3^{200}$ yra didesnis."
        }
      ],
      "answer": "3^200"
    },
    {
      "title": "Lygtis su moduliais",
      "problem": "Išspręskite lygtį $|x-1| + |x-3| = 2$.",
      "steps": [
        {
          "text": "Nagrinėjame intervalus: $x < 1$, $1 \\le x \\le 3$, $x > 3$."
        },
        {
          "text": "Intervale $[1, 3]$ lygtis tampa $x-1 + 3-x = 2$, t.y. $2=2$. Visi taškai tinka."
        }
      ],
      "answer": "x ∈ [1, 3]"
    },
    {
      "title": "Simetrinio reiškinio reikšmė",
      "problem": "Jei $a+b=5$ ir $ab=6$, raskite $a^2+b^2$.",
      "steps": [
        {
          "text": "$(a+b)^2 = a^2+2ab+b^2$."
        },
        {
          "text": "$5^2 = a^2+b^2 + 2(6) \\implies 25 = a^2+b^2+12$."
        },
        {
          "text": "$a^2+b^2 = 13$."
        }
      ],
      "answer": "13"
    },
    {
      "title": "Diofantinė lygtis su dauginimu",
      "problem": "Raskite sveikus sprendinius: $(x-1)(y+2) = 3$.",
      "steps": [
        {
          "text": "Skaičiaus 3 dalikliai yra: 1, 3, -1, -3."
        },
        {
          "text": "1 atvejis: $x-1=1, y+2=3 \\implies x=2, y=1$."
        },
        {
          "text": "2 atvejis: $x-1=3, y+2=1 \\implies x=4, y=-1$."
        },
        {
          "text": "3 atvejis: $x-1=-1, y+2=-3 \\implies x=0, y=-5$."
        },
        {
          "text": "4 atvejis: $x-1=-3, y+2=-1 \\implies x=-2, y=-3$."
        }
      ],
      "answer": "(2,1), (4,-1), (0,-5), (-2,-3)"
    }
  ],
