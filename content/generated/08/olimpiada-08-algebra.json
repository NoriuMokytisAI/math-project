  "workedExamples": [
    {
      "id": "we-alg-8-1",
      "title": "Vijeto teoremos taikymas simetriniam reiškiniui",
      "level": "medium",
      "problem": "Tarkime, $x_1$ ir $x_2$ yra lygties $x^2 - 5x + 3 = 0$ šaknys. Neskaičiuodami pačių šaknų, raskite reiškinio $x_1^2 + x_2^2$ reikšmę.",
      "conceptIds": [
        "vijeto-teorema",
        "simetriniai-reiskiniai"
      ],
      "steps": [
        {
          "text": "Pagal Vijeto teoremą: $x_1 + x_2 = 5$ ir $x_1 x_2 = 3$."
        },
        {
          "text": "Žinome, kad $(x_1 + x_2)^2 = x_1^2 + 2x_1x_2 + x_2^2$."
        },
        {
          "text": "Išreiškiame ieškomą sumą: $x_1^2 + x_2^2 = (x_1 + x_2)^2 - 2x_1x_2$."
        },
        {
          "text": "Įstatome reikšmes: $5^2 - 2 \\cdot 3 = 25 - 6 = 19$."
        }
      ],
      "answer": "19"
    },
    {
      "id": "we-alg-8-2",
      "title": "Diofantinė lygtis su skaidymu",
      "level": "hard",
      "problem": "Raskite visus sveikųjų skaičių poras $(x, y)$, tenkinančias lygtį $xy + 3x - y = 7$.",
      "conceptIds": [
        "diofanto-lygtys",
        "skaidymas-dauginamaisiais"
      ],
      "steps": [
        {
          "text": "Bandom sugrupuoti narius taip, kad gautume sandaugą. Pridėkime po $-3$ abiejose pusėse: $xy + 3x - y - 3 = 7 - 3$."
        },
        {
          "text": "Grupuojame: $x(y+3) - 1(y+3) = 4$."
        },
        {
          "text": "Gauname $(x-1)(y+3) = 4$."
        },
        {
          "text": "Kadangi $x, y$ yra sveikieji, skliausteliuose esantys skaičiai yra skaičiaus 4 dalikliai. Galimos poros $(x-1, y+3)$ yra: $(1,4), (4,1), (2,2), (-1,-4), (-4,-1), (-2,-2)$."
        },
        {
          "text": "Sprendžiame kiekvieną sistemą: \n 1) $x-1=1, y+3=4 \\implies (2,1)$ \n 2) $x-1=4, y+3=1 \\implies (5,-2)$ \n 3) $x-1=2, y+3=2 \\implies (3,-1)$ \n 4) $x-1=-1, y+3=-4 \\implies (0,-7)$ \n 5) $x-1=-4, y+3=-1 \\implies (-3,-4)$ \n 6) $x-1=-2, y+3=-2 \\implies (-1,-5)$."
        }
      ],
      "answer": "(2,1), (5,-2), (3,-1), (0,-7), (-3,-4), (-1,-5)"
    },
    {
      "id": "we-alg-8-3",
      "title": "AM-GM nelygybė ir ekstremumas",
      "level": "medium",
      "problem": "Įrodykite, kad teigiamiems skaičiams $a$ ir $b$ galioja nelygybė $(a+b)(\\frac{1}{a} + \\frac{1}{b}) \\ge 4$.",
      "conceptIds": [
        "am-gm-nelygybe"
      ],
      "steps": [
        {
          "text": "Atskliaudžiame reiškinį: $1 + \\frac{a}{b} + \\frac{b}{a} + 1 = 2 + \\frac{a}{b} + \\frac{b}{a}$."
        },
        {
          "text": "Taikome AM-GM nelygybę nariams $\\frac{a}{b}$ ir $\\frac{b}{a}$ (jie teigiami): $\\frac{\\frac{a}{b} + \\frac{b}{a}}{2} \\ge \\sqrt{\\frac{a}{b} \\cdot \\frac{b}{a}} = \\sqrt{1} = 1$."
        },
        {
          "text": "Iš čia seka, kad $\\frac{a}{b} + \\frac{b}{a} \\ge 2$."
        },
        {
          "text": "Pridedame likusį dvejetą: $2 + (\\frac{a}{b} + \\frac{b}{a}) \\ge 2 + 2 = 4$. Įrodyta."
        }
      ],
      "answer": "Įrodyta"
    },
    {
      "id": "we-alg-8-4",
      "title": "Lygtis su moduliu per intervalus",
      "level": "hard",
      "problem": "Išspręskite lygtį $|x+2| + |x-1| = 5$.",
      "conceptIds": [
        "modulis-intervalai"
      ],
      "steps": [
        {
          "text": "Nuliniai taškai: $x = -2$ ir $x = 1$. Jie dalija tiesę į 3 intervalus."
        },
        {
          "text": "1) $x < -2$: Abu reiškiniai neigiami. $-(x+2) - (x-1) = 5 \\implies -x - 2 - x + 1 = 5 \\implies -2x = 6 \\implies x = -3$. (Tinka, nes $-3 < -2$)."
        },
        {
          "text": "2) $-2 \\le x \\le 1$: Pirmas teigiamas, antras neigiamas. $(x+2) - (x-1) = 5 \\implies x + 2 - x + 1 = 5 \\implies 3 = 5$. (Sprendinių nėra)."
        },
        {
          "text": "3) $x > 1$: Abu teigiami. $(x+2) + (x-1) = 5 \\implies 2x + 1 = 5 \\implies 2x = 4 \\implies x = 2$. (Tinka, nes $2 > 1$)."
        }
      ],
      "answer": "-3, 2"
    },
    {
      "id": "we-alg-8-5",
      "title": "Skaidymas: Sofi Žermen tapatybės idėja",
      "level": "hard",
      "problem": "Išskaidykite dauginamaisiais reiškinį $x^4 + 4y^4$.",
      "conceptIds": [
        "skaidymas-dauginamaisiais"
      ],
      "steps": [
        {
          "text": "Pridedame ir atimame narį $4x^2y^2$, kad gautume pilną kvadratą: $x^4 + 4x^2y^2 + 4y^4 - 4x^2y^2$."
        },
        {
          "text": "Pirmi trys nariai sudaro $(x^2 + 2y^2)^2$."
        },
        {
          "text": "Gauname kvadratų skirtumą: $(x^2 + 2y^2)^2 - (2xy)^2$."
        },
        {
          "text": "Taikome formulę $a^2 - b^2 = (a-b)(a+b)$: $(x^2 + 2y^2 - 2xy)(x^2 + 2y^2 + 2xy)$."
        }
      ],
      "answer": "(x^2 - 2xy + 2y^2)(x^2 + 2xy + 2y^2)"
    }
  ],
