  "theory": [
    {
      "id": "alg-8-theory-1",
      "title": "Algebrinės transformacijos: Menas skaidyti",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Olimpiadinėje algebroje gebėjimas transformuoti reiškinį į patogesnę formą yra kritinis. Dažniausiai tai reiškia reiškinio išskaidymą dauginamaisiais arba pilnojo kvadrato išskyrimą. Tai leidžia pamatyti struktūrą ten, kur iš pradžių matėsi tik chaosas."
        },
        {
          "type": "method",
          "title": "Skaidymo strategijos",
          "text": "1. **Grupavimas:** narių sujungimas į poras ar grupes, turinčias bendrą daugiklį. \n 2. **Sutrumpinto dauginimo formulės:** ne tik žinoti $(a+b)^2$, bet ir mokėti atpažinti jas atvirkštine tvarka. \n 3. **Sumanus pridėjimas ir atėmimas:** pavyzdžiui, pridėjus ir atėmus $2x^2$, reiškinį $x^4 + 4$ galima paversti $(x^2+2)^2 - 4x^2$, o tai jau yra kvadratų skirtumas."
        },
        {
          "type": "paragraph",
          "text": "Ypatingas dėmesys skiriamas simetriniams reiškiniams – tai reiškiniai, kurie nesikeičia sukeitus kintamuosius vietomis (pvz., $x^2 + y^2$). Juos visada galima išreikšti per pagrindines simetrines sumas $s = x+y$ ir $p = xy$."
        }
      ]
    },
    {
      "id": "alg-8-theory-2",
      "title": "Kvadratinės lygtys ir Vijeto teorema",
      "blocks": [
        {
          "type": "paragraph",
          "text": "8-oje klasėje kvadratinės lygtys tampa pagrindiniu įrankiu. Olimpiadose retai prašoma tiesiog rasti šaknis per diskriminantą – dažniau reikia analizuoti jų savybes naudojant Vijeto teoremą."
        },
        {
          "type": "theorem",
          "title": "Vijeto teorema",
          "text": "Jei $x_1$ ir $x_2$ yra lygties $ax^2 + bx + c = 0$ šaknys, tai: \n $x_1 + x_2 = -\\frac{b}{a}$ \n $x_1 x_2 = \\frac{c}{a}$"
        },
        {
          "type": "strategy",
          "title": "Reiškinių skaičiavimas be šaknų radimo",
          "text": "Jei reikia rasti $x_1^2 + x_2^2$, naudojame formulę $(x_1+x_2)^2 - 2x_1x_2$. Jei reikia $x_1^3 + x_2^3$, naudojame $(x_1+x_2)(x_1^2 - x_1x_2 + x_2^2)$. Tai sutaupo daug laiko ir apsaugo nuo klaidų dirbant su iracionaliomis šaknimis."
        }
      ]
    },
    {
      "id": "alg-8-theory-3",
      "title": "Diofantinės lygtys: Sveikieji sprendiniai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Diofantinės lygtys – tai lygtys, kurių sprendinių ieškome tik sveikųjų skaičių aibėje. Tai tiltas tarp algebros ir skaičių teorijos."
        },
        {
          "type": "method",
          "title": "Skaidymo metodas Diofanto lygtyse",
          "text": "Jei lygtį galime užrašyti pavidalu $(\\text{reiškinys}_1) \\cdot (\\text{reiškinys}_2) = \\text{skaičius}$, tai uždavinys virsta baigtinio skaičiaus atvejų nagrinėjimu (skaičiaus dalikliai)."
        },
        {
          "type": "paragraph",
          "text": "Pavyzdžiui, lygtis $xy + 2x + 3y = 1$ gali būti pertvarkyta į $(x+3)(y+2) = 1 + 6 = 7$. Kadangi 7 yra pirminis skaičius, turime tik 4 galimas daliklių poras: $(1,7), (7,1), (-1,-7), (-7,-1)$."
        }
      ]
    },
    {
      "id": "alg-8-theory-4",
      "title": "Nelygybės: AM-GM vidurkiai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Aritmetinio ir geometrinio vidurkių nelygybė (AM-GM) yra viena pamatinių nelygybių matematikoje."
        },
        {
          "type": "formula",
          "title": "AM-GM dviems skaičiams",
          "text": "$\\frac{a+b}{2} \\ge \\sqrt{ab}$, kai $a, b \\ge 0$."
        },
        {
          "type": "strategy",
          "title": "Kada taikyti AM-GM?",
          "text": "1. Kai reikia įrodyti, kad suma yra didesnė už tam tikrą konstantą. \n 2. Kai reikia rasti funkcijos mažiausią reikšmę (ekstremumą). \n 3. Lygybė galioja tada ir tik tada, kai $a=b$."
        },
        {
          "type": "paragraph",
          "text": "Svarbu: niekada netaikykite AM-GM skaičiams, kurie gali būti neigiami! Prieš taikydami, visada įsitikinkite neneigiamumu."
        }
      ]
    },
    {
      "id": "alg-8-theory-5",
      "title": "Absoliutinė reikšmė (modulis) ir intervalai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Lygtys ir nelygybės su moduliais olimpiadose sprendžiamos skaidant skaičių tiesę į intervalus, kuriuose modulio reiškinio ženklas yra pastovus."
        },
        {
          "type": "method",
          "title": "Nulinių taškų metodas",
          "text": "Raskite visus taškus, kuriuose po moduliu esantys reiškiniai lygūs nuliui. Šie taškai suskirsto tiesę į intervalus. Kiekviename intervale „nuimkite“ modulio ženklus pagal apibrėžimą: $|f(x)| = f(x)$, jei $f(x) \\ge 0$, ir $|f(x)| = -f(x)$, jei $f(x) < 0$."
        }
      ]
    }
  ],
