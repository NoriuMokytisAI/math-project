  "theory": [
    {
      "id": "diofantines-lygtys-ir-dalumas",
      "title": "Diofantinės lygtys ir dalumas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Sveikųjų skaičių lygtys, vadinamos Diofantinėmis lygtimis, turi ilgą istoriją. Tiesinė Diofantinė lygtis su dviem kintamaisiais turi pavidalą $ax + by = c$, kur $a, b, c$ yra sveikieji skaičiai. Ji turi sveikųjų skaičių sprendinių tada ir tik tada, kai skaičių $a$ ir $b$ didžiausias bendrasis daliklis $\\text{dbd}(a, b)$ dalija laisvąjį narį $c$."
        },
        {
          "type": "method",
          "text": "Jei lygtis turi sprendinių, vieną atskirąjį sprendinį galima rasti Euklido algoritmu arba spėliojimo būdu. Žinant vieną sprendinį $(x_0, y_0)$, visi kiti sprendiniai užrašomi formule: $x = x_0 + \\frac{b}{d}t$ ir $y = y_0 - \\frac{a}{d}t$, kur $d = \\text{dbd}(a, b)$ ir $t \\in \\mathbb{Z}$."
        }
      ]
    },
    {
      "id": "vijeto-teorema-ir-simetrija",
      "title": "Vijeto teorema ir simetriniai reiškiniai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Vijeto teorema sieja lygties koeficientus su jos šaknų suma ir sandauga. Kvadratinei lygčiai $ax^2 + bx + c = 0$ galioja: $x_1 + x_2 = -\\frac{b}{a}$ ir $x_1 x_2 = \\frac{c}{a}$."
        },
        {
          "type": "note",
          "text": "Simetriniai reiškiniai, tokie kaip $x_1^2 + x_2^2$ arba $\\frac{1}{x_1} + \\frac{1}{x_2}$, gali būti išreikšti per šaknų sumą ir sandaugą, net nežinant pačių šaknų reikšmių."
        }
      ]
    },
    {
      "id": "nelygybes-am-gm",
      "title": "Nelygybės: AM-GM principas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Aritmetinio ir geometrinio vidurkių nelygybė (AM-GM) teigia, kad neneigiamiems skaičiams jų aritmetinis vidurkis yra ne mažesnis už geometrinį vidurkį."
        },
        {
          "type": "formula",
          "formulaId": "am-gm-formule",
          "latex": "\\frac{a+b}{2} \\ge \\sqrt{ab}"
        },
        {
          "type": "note",
          "text": "Lygybė galioja tada ir tik tada, kai $a = b$. Ši nelygybė yra galingas įrankis įrodant kitas nelygybes ir ieškant funkcijų ekstremumų."
        }
      ]
    }
  ],
