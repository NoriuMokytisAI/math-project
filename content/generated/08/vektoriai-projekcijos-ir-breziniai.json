      "id": "vektoriai-exmp-1",
      "title": "Vektoriaus koordinačių radimas",
      "level": "easy",
      "problem": "Raskite vektoriaus $\\vec{AB}$ koordinates, jei jo pradžios taškas $A(2; 5)$, o galo taškas $B(6; 3)$.",
      "conceptIds": [
        "vektoriaus-koordinates"
      ],
      "formulaIds": [
        "vektoriaus-koordinates-is-tasku"
      ],
      "steps": [
        {
          "text": "Iš galo taško B x koordinatės atimame pradžios taško A x koordinatę.",
          "latex": "x = 6 - 2 = 4"
        },
        {
          "text": "Iš galo taško B y koordinatės atimame pradžios taško A y koordinatę.",
          "latex": "y = 3 - 5 = -2"
        }
      ],
      "answer": "vec{AB} = (4; -2)"
    },
    {
      "id": "vektoriai-exmp-2",
      "title": "Vektoriaus ilgis",
      "level": "easy",
      "problem": "Apskaičiuokite vektoriaus $\\vec{a}(-8; 6)$ ilgį.",
      "conceptIds": [
        "vektoriaus-ilgis"
      ],
      "formulaIds": [
        "vektoriaus-ilgio-formule"
      ],
      "steps": [
        {
          "text": "Keliame koordinates kvadratu.",
          "latex": "(-8)^2 = 64, \\quad 6^2 = 36"
        },
        {
          "text": "Sudedame gautas reikšmes.",
          "latex": "64 + 36 = 100"
        },
        {
          "text": "Ištraukiame kvadratinę šaknį.",
          "latex": "\\sqrt{100} = 10"
        }
      ],
      "answer": "10"
    },
    {
      "id": "vektoriai-exmp-3",
      "title": "Vektorių sudėtis (Algebrainė)",
      "level": "easy",
      "problem": "Sudėkite vektorius $\\vec{a}(3; -4)$ ir $\\vec{b}(-1; 5)$.",
      "conceptIds": [
        "vektoriu-sudetis"
      ],
      "formulaIds": [
        "vektoriu-sudetis-algebraine"
      ],
      "steps": [
        {
          "text": "Sudedame atitinkamas x koordinates.",
          "latex": "3 + (-1) = 2"
        },
        {
          "text": "Sudedame atitinkamas y koordinates.",
          "latex": "-4 + 5 = 1"
        }
      ],
      "answer": "vec{c}(2; 1)"
    },
    {
      "id": "vektoriai-exmp-4",
      "title": "Vektoriaus daugyba iš skaičiaus",
      "level": "easy",
      "problem": "Duotas vektorius $\\vec{m}(2; -3)$. Raskite vektoriaus $3\\vec{m}$ koordinates.",
      "conceptIds": [
        "vektoriaus-daugyba-is-skaiciaus"
      ],
      "formulaIds": [
        "vektoriaus-daugyba-is-k-algebraine"
      ],
      "steps": [
        {
          "text": "Kiekvieną vektoriaus koordinatę padauginame iš 3.",
          "latex": "3 \\cdot 2 = 6, \\quad 3 \\cdot (-3) = -9"
        }
      ],
      "answer": "(6; -9)"
    },
    {
      "id": "vektoriai-exmp-5",
      "title": "Vektorių atimtis",
      "level": "medium",
      "problem": "Raskite skirtumą $\\vec{a} - \\vec{b}$, kai $\\vec{a}(5; 10)$ ir $\\vec{b}(2; 12)$.",
      "conceptIds": [
        "vektoriu-atimtis"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Atimame x koordinates.",
          "latex": "5 - 2 = 3"
        },
        {
          "text": "Atimame y koordinates.",
          "latex": "10 - 12 = -2"
        }
      ],
      "answer": "(3; -2)"
    },
    {
      "id": "vektoriai-exmp-6",
      "title": "Sudėtinis veiksmas",
      "level": "medium",
      "problem": "Apskaičiuokite vektoriaus $\\vec{c} = 2\\vec{a} - \\vec{b}$ koordinates, jei $\\vec{a}(1; 2)$ ir $\\vec{b}(5; -1)$.",
      "conceptIds": [
        "vektoriu-sudetis",
        "vektoriaus-daugyba-is-skaiciaus"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Pirmiausia randame 2a.",
          "latex": "2\\vec{a} = (2; 4)"
        },
        {
          "text": "Atimame vektorių b.",
          "latex": "(2 - 5; 4 - (-1)) = (-3; 5)"
        }
      ],
      "answer": "(-3; 5)"
    },
    {
      "id": "vektoriai-exmp-7",
      "title": "Vektorių sudėtis (Geometrinė)",
      "level": "medium",
      "problem": "Nubraižytas trikampis ABC. Kam lygi suma vektorių $\\vec{AB} + \\vec{BC}$?",
