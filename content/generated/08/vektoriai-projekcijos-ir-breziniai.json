  "theory": [
    {
      "id": "vektoriai-ivadas-detalus",
      "title": "Kas yra vektorius?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Daugelis fizikinių dydžių, pavyzdžiui, jėga arba greitis, turi ne tik skaitinę reikšmę, bet ir kryptį. Matematikoje tokie dydžiai vadinami **vektoriais**."
        },
        {
          "type": "definition",
          "conceptId": "vektorius",
          "text": "[[vektorius|Vektorius]] – tai nukreipta atkarpa. Jis turi pradinį tašką, galinį tašką ir kryptį, nurodomą rodykle. Vektorius žymimas dviem didžiosiomis raidėmis su rodykle viršuje (pvz., $\\vec{AB}$) arba viena mažąja raide (pvz., $\\vec{a}$)."
        },
        {
          "type": "paragraph",
          "text": "Vektorius, kurio pradžios ir galo taškai sutampa, vadinamas **nuliniu vektoriumi** $\\vec{0}$."
        }
      ]
    },
    {
      "id": "vektoriai-koordinates-ir-ilgis",
      "title": "Vektoriaus koordinatės ir ilgis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Koordinačių plokštumoje vektorių galime aprašyti skaičių pora, kuri parodo, kiek vienetų ir kuria kryptimi reikia pasislinkti nuo pradžios taško iki galo."
        },
        {
          "type": "formula",
          "title": "Vektoriaus koordinatės",
          "formulaId": "vektoriaus-koordinates-is-tasku",
          "latex": "\\vec{AB} = (x_2 - x_1; y_2 - y_1)"
        },
        {
          "type": "warning",
          "text": "Svarbu: visada iš galo taško koordinačių atimame pradžios taško koordinates!"
        },
        {
          "type": "formula",
          "title": "Vektoriaus ilgis (modulis)",
          "formulaId": "vektoriaus-ilgio-formule",
          "latex": "|\\vec{a}| = \\sqrt{x^2 + y^2}"
        },
        {
          "type": "paragraph",
          "text": "Vektoriaus ilgis visada yra neneigiamas skaičius."
        }
      ]
    },
    {
      "id": "vektoriai-veiksmai",
      "title": "Veiksmai su vektoriais",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Vektorius galime sudėti, atimti ir dauginti iš skaičiaus."
        },
        {
          "type": "method",
          "title": "Vektorių sudėtis (Geometrinė)",
          "text": "**Trikampio taisyklė**: Prie pirmojo vektoriaus galo pridedame antrojo vektoriaus pradžią. Rezultatas yra vektorius, jungiantis pirmojo pradžią su antrojo galu."
        },
        {
          "type": "formula",
          "title": "Sudėtis pagal koordinates",
          "formulaId": "vektoriu-sudetis-algebraine",
          "latex": "\\vec{a} + \\vec{b} = (x_a + x_b; y_a + y_b)"
        },
        {
          "type": "formula",
          "title": "Daugyba iš skaičiaus",
          "formulaId": "vektoriaus-daugyba-is-k-algebraine",
          "latex": "k \\cdot \\vec{a} = (k \\cdot x_a; k \\cdot y_a)"
        },
        {
          "type": "note",
          "text": "Jei $k > 0$, vektoriaus kryptis nesikeičia. Jei $k < 0$, vektoriaus kryptis pasikeičia į priešingą."
        }
      ]
    },
    {
      "id": "vektoriai-projekcijos",
      "title": "Projekcijos ir brėžiniai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Norėdami pavaizduoti erdvinį objektą (pvz., pastatą ar detalę) popieriuje, naudojame projekcijas."
        },
        {
          "type": "definition",
          "conceptId": "projekcija",
          "text": "[[projekcija|Projekcija]] – tai objekto vaizdas plokštumoje, gautas iš tam tikros pusės."
        },
        {
          "type": "paragraph",
          "text": "Techniniuose brėžiniuose dažniausiai naudojami trys pagrindiniai vaizdai:"
        },
        {
          "type": "definition",
          "text": "1. [[vaizdas-is-priekio|Vaizdas iš priekio]] (pagrindinis vaizdas). 2. [[vaizdas-is-virsaus|Vaizdas iš viršaus]] (planas). 3. [[vaizdas-is-sono|Vaizdas iš šono]] (profilis)."
        },
        {
          "type": "method",
          "text": "Svarbu suprasti, kad nematomi objekto kraštai brėžiniuose žymimi brūkšnine linija, o matomi – ištisine storąja linija."
        }
      ]
    }
  ],
