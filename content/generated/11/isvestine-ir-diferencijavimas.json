      ],
      "steps": [
        {
          "text": "Naudojame sandaugos taisyklę (u*v)' = u'v + uv'. Čia u = x², v = sin x.",
          "latex": "f'(x) = (x^2)' \\sin x + x^2 (\\sin x)'"
        },
        {
          "text": "Apskaičiuojame atskiras išvestines.",
          "latex": "f'(x) = 2x \\sin x + x^2 \\cos x"
        }
      ],
      "answer": "f'(x) = 2x sin x + x² cos x"
    },
    {
      "id": "quotient-rule-ex",
      "title": "Dalmens taisyklės taikymas",
      "level": "medium",
      "problem": "Diferencijuokite f(x) = x / (x + 1).",
      "conceptIds": [
        "isvestine"
      ],
      "steps": [
        {
          "text": "Naudojame dalmens taisyklę.",
          "latex": "f'(x) = \\frac{(x)'(x+1) - x(x+1)'}{(x+1)^2}"
        },
        {
          "text": "Suprastiname.",
          "latex": "f'(x) = \\frac{1(x+1) - x(1)}{(x+1)^2} = \\frac{1}{(x+1)^2}"
        }
      ],
      "answer": "f'(x) = 1 / (x+1)²"
    },
