      "conceptIds": [
        "isvestine"
      ],
      "steps": [
        {
          "text": "Pažymime kraštinę statmeną upei x, o lygiagrečią y. Tvora: 2x + y = 40, tad y = 40 - 2x.",
          "latex": "S(x) = x \\cdot y = x(40 - 2x) = 40x - 2x^2"
        },
        {
          "text": "Randame išvestinę ir prilyginame nuliui.",
          "latex": "S'(x) = 40 - 4x = 0 \\implies x = 10"
        },
        {
          "text": "Randame kitą kraštinę y.",
          "latex": "y = 40 - 2(10) = 20"
        }
      ],
      "answer": "Kraštinės 10 m ir 20 m."
    }
