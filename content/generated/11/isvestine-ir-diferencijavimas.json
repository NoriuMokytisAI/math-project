  "workedExamples": [
    {
      "id": "isvestine-definition-ex",
      "title": "Išvestinės radimas pagal apibrėžimą",
      "level": "medium",
      "problem": "Raskite funkcijos f(x) = x² išvestinę naudodami ribos apibrėžimą.",
      "conceptIds": [
        "isvestine"
      ],
      "steps": [
        {
          "text": "Užrašome ribą.",
          "latex": "\\lim_{h \\to 0} \\frac{(x+h)^2 - x^2}{h}"
        },
        {
          "text": "Atskliaudžiame kvadratą.",
          "latex": "\\lim_{h \\to 0} \\frac{x^2 + 2xh + h^2 - x^2}{h} = \\lim_{h \\to 0} \\frac{2xh + h^2}{h}"
        },
        {
          "text": "Suprastiname iš h.",
          "latex": "\\lim_{h \\to 0} (2x + h) = 2x"
        }
      ],
      "answer": "f'(x) = 2x"
    },
    {
      "id": "liestine-example",
      "title": "Liestinės lygties sudarymas",
      "level": "medium",
      "problem": "Sudarykite funkcijos f(x) = x³ liestinės lygtį taške x0 = 1.",
      "conceptIds": [
        "liestine"
      ],
      "steps": [
        {
          "text": "Randame funkcijos reikšmę taške.",
          "latex": "f(1) = 1^3 = 1"
        },
        {
          "text": "Randame išvestinę.",
          "latex": "f'(x) = 3x^2"
        },
        {
          "text": "Randame išvestinės reikšmę taške (krypties koeficientą).",
          "latex": "f'(1) = 3(1)^2 = 3"
        },
        {
          "text": "Įstatome į liestinės formulę y = f(x0) + f'(x0)(x - x0).",
          "latex": "y = 1 + 3(x - 1) \\implies y = 3x - 2"
        }
      ],
      "answer": "y = 3x - 2"
    },
    {
      "id": "rules-combination-ex",
      "title": "Diferencijavimo taisyklių taikymas",
      "level": "medium",
      "problem": "Diferencijuokite funkciją f(x) = x² sin x.",
      "conceptIds": [
        "isvestine"
      ],
      "steps": [
        {
          "text": "Naudojame sandaugos taisyklę (u*v)' = u'v + uv'. Čia u = x², v = sin x.",
          "latex": "f'(x) = (x^2)' \\sin x + x^2 (\\sin x)'"
        },
        {
          "text": "Apskaičiuojame atskiras išvestines.",
          "latex": "f'(x) = 2x \\sin x + x^2 \\cos x"
        }
      ],
      "answer": "f'(x) = 2x sin x + x² cos x"
    },
    {
      "id": "quotient-rule-ex",
      "title": "Dalmens taisyklės taikymas",
      "level": "medium",
      "problem": "Diferencijuokite f(x) = x / (x + 1).",
      "conceptIds": [
        "isvestine"
      ],
      "steps": [
        {
          "text": "Naudojame dalmens taisyklę.",
          "latex": "f'(x) = \\frac{(x)'(x+1) - x(x+1)'}{(x+1)^2}"
        },
        {
          "text": "Suprastiname.",
          "latex": "f'(x) = \\frac{1(x+1) - x(1)}{(x+1)^2} = \\frac{1}{(x+1)^2}"
        }
      ],
      "answer": "f'(x) = 1 / (x+1)²"
    },
    {
      "id": "chain-rule-complex",
      "title": "Sudėtinės funkcijos išvestinė",
      "level": "hard",
      "problem": "Diferencijuokite f(x) = ln(x² + 5).",
      "conceptIds": [
        "grandinine-taisykle"
      ],
      "steps": [
        {
          "text": "Išorinė funkcija yra ln(u), jos išvestinė 1/u. Vidinė funkcija u = x² + 5.",
          "latex": "f'(x) = \\frac{1}{x^2 + 5} \\cdot (x^2 + 5)'"
        },
        {
          "text": "Randame vidinę išvestinę ir sudauginame.",
          "latex": "f'(x) = \\frac{1}{x^2 + 5} \\cdot 2x = \\frac{2x}{x^2 + 5}"
        }
      ],
      "answer": "f'(x) = 2x / (x² + 5)"
    },
    {
      "id": "monotonicity-ex",
      "title": "Didėjimo ir mažėjimo intervalai",
      "level": "medium",
      "problem": "Raskite funkcijos f(x) = x² - 4x + 3 didėjimo ir mažėjimo intervalus.",
      "conceptIds": [
        "isvestine"
      ],
      "steps": [
        {
          "text": "Randame išvestinę.",
          "latex": "f'(x) = 2x - 4"
        },
        {
          "text": "Randame kritinį tašką prilyginę nuliui.",
          "latex": "2x - 4 = 0 \\implies x = 2"
        },
        {
          "text": "Tikriname ženklus: kai x < 2, f'(x) < 0 (mažėja). Kai x > 2, f'(x) > 0 (didėja).",
          "latex": "\\text{Mažėja: } (-\\\\infty, 2), \\\\text{ Didėja: } (2, \\\\infty)"
        }
      ],
      "answer": "Mažėja (-∞, 2), didėja (2, ∞)"
    },
    {
      "id": "extremum-ex",
      "title": "Ekstremumų radimas",
      "level": "medium",
      "problem": "Raskite funkcijos f(x) = x³ - 3x ekstremumų taškus.",
      "conceptIds": [
        "ekstremumas"
      ],
      "steps": [
        {
          "text": "Randame išvestinę.",
          "latex": "f'(x) = 3x^2 - 3"
        },
        {
          "text": "Randame kritinius taškus: 3x² - 3 = 0.",
          "latex": "x^2 = 1 \\implies x = 1, x = -1"
        },
        {
          "text": "Tiriame ženklus aplink -1 ir 1. Ties -1 ženklas keičiasi iš + į - (Maksimumas). Ties 1 ženklas keičiasi iš - į + (Minimumas).",
          "latex": "x_{max} = -1, x_{min} = 1"
        }
      ],
      "answer": "Maksimumas ties x = -1, minimumas ties x = 1."
    },
    {
      "id": "optimization-ex",
      "title": "Optimizavimo uždavinys",
      "level": "hard",
      "problem": "Ūkininkas nori aptverti stačiakampį sklypą prie tiesios upės sienos. Jis turi 40 m tvoros. Upės pusės tverti nereikia. Kokio ilgio turi būti kraštinės, kad plotas būtų didžiausias?",
      "conceptIds": [
        "isvestine"
      ],
      "steps": [
        {
          "text": "Pažymime kraštinę statmeną upei x, o lygiagrečią y. Tvora: 2x + y = 40, tad y = 40 - 2x.",
          "latex": "S(x) = x \\cdot y = x(40 - 2x) = 40x - 2x^2"
        },
        {
          "text": "Randame išvestinę ir prilyginame nuliui.",
          "latex": "S'(x) = 40 - 4x = 0 \\implies x = 10"
        },
        {
          "text": "Randame kitą kraštinę y.",
          "latex": "y = 40 - 2(10) = 20"
        }
      ],
      "answer": "Kraštinės 10 m ir 20 m."
    }
  ],
