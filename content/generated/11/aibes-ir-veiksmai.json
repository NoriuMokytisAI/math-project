  "theory": [
    {
      "id": "aibes-savoka",
      "title": "Aibės sąvoka ir žymėjimas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[aibe|Aibė]] yra tam tikrų objektų, vadinamų [[elementas|elementais]], rinkinys. Aibės dažniausiai žymimos didžiosiomis raidėmis (A, B, C...), o jų elementai išvardijami riestiniuose skliaustuose."
        },
        {
          "type": "definition",
          "conceptId": "aibe",
          "text": "Aibė – tai visuma objektų, kurie turi bendrą požymį arba yra tiesiog sujungti į vieną rinkinį."
        },
        {
          "type": "paragraph",
          "text": "Jei objektas x priklauso aibei A, rašome x ∈ A. Jei nepriklauso – x ∉ A. Aibė, neturinti nei vieno elemento, vadinama [[tuscia-aibe|tuščiąja aibe]] ir žymima ∅."
        }
      ]
    },
    {
      "id": "aibiu-sajunga-ir-sankirta",
      "title": "Aibių sąjunga ir sankirta",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Pagrindiniai veiksmai su aibėmis yra [[aibiu-sajunga|sąjunga]] ir [[aibiu-sankirta|sankirta]]."
        },
        {
          "type": "property",
          "text": "Aibių A ir B sąjunga (A ∪ B) yra aibė, kurią sudaro visi elementai, priklausantys bent vienai iš tų aibių."
        },
        {
          "type": "formula",
          "formulaId": "sajungos-apibrezimas",
          "latex": "A \\cup B = \\{x \\mid x \\in A \\text{ arba } x \\in B\\}"
        },
        {
          "type": "property",
          "text": "Aibių A ir B sankirta (A ∩ B) yra aibė, kurią sudaro tik tie elementai, kurie priklauso ir aibei A, ir aibei B tuo pačiu metu."
        },
        {
          "type": "formula",
          "formulaId": "sankirtos-apibrezimas",
          "latex": "A \\cap B = \\{x \\mid x \\in A \\text{ ir } x \\in B\\}"
        }
      ]
    },
    {
      "id": "aibiu-skirtumas-ir-poaibis",
      "title": "Aibių skirtumas ir poaibis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[aibiu-skirtumas|Aibių skirtumas]] (A \\ B) yra aibė, kurią sudaro elementai, priklausantys aibei A, bet nepriklausantys aibei B."
        },
        {
          "type": "formula",
          "formulaId": "skirtumo-apibrezimas",
          "latex": "A \\setminus B = \\{x \\mid x \\in A \\text{ ir } x \\notin B\\}"
        },
        {
          "type": "paragraph",
          "text": "Jei kiekvienas aibės B elementas priklauso ir aibei A, sakome, kad B yra aibės A [[poaibis|poaibis]] (B ⊆ A)."
        }
      ]
    },
    {
      "id": "veno-diagramos-teorija",
      "title": "Veno diagramos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[veno-diagrama|Veno diagramos]] yra vaizdus būdas aibėms ir veiksmams su jomis pavaizduoti plokštumoje (dažniausiai apskritimais)."
        },
        {
          "type": "note",
          "text": "Veno diagramos padeda spręsti uždavinius, kuriuose reikia rasti elementų skaičių susikertančiose grupėse."
        }
      ]
    }
  ],
