  "workedExamples": [
    {
      "id": "aibiu-veiksmai-1",
      "title": "Sąjungos ir sankirtos radimas",
      "level": "easy",
      "problem": "Duotos aibės A = {1, 2, 3, 4} ir B = {3, 4, 5, 6}. Raskite A ∪ B ir A ∩ B.",
      "conceptIds": [
        "aibiu-sajunga",
        "aibiu-sankirta"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Sąjungai surašome visus elementus iš abiejų aibių, nepasikartodami.",
          "latex": "A \\cup B = \\{1, 2, 3, 4, 5, 6\\}"
        },
        {
          "text": "Sankirtai surašome tik tuos elementus, kurie yra ir A, ir B.",
          "latex": "A \\cap B = \\{3, 4\\}"
        }
      ],
      "answer": "A ∪ B = {1, 2, 3, 4, 5, 6}, A ∩ B = {3, 4}"
    },
    {
      "id": "aibiu-skirtumas-exmp",
      "title": "Aibių skirtumo skaičiavimas",
      "level": "easy",
      "problem": "Duotos aibės A = {a, b, c, d} ir B = {c, d, e}. Raskite A \\ B ir B \\ A.",
      "conceptIds": [
        "aibiu-skirtumas"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Iš aibės A išmetame elementus, kurie yra aibėje B (tai c ir d).",
          "latex": "A \\setminus B = \\{a, b\\}"
        },
        {
          "text": "Iš aibės B išmetame elementus, kurie yra aibėje A (tai c ir d).",
          "latex": "B \\setminus A = \\{e\\}"
        }
      ],
      "answer": "A \\ B = {a, b}, B \\ A = {e}"
    },
    {
      "id": "veno-diagrama-problem",
      "title": "Uždavinys su Veno diagrama",
      "level": "medium",
      "problem": "Klasėje yra 30 mokinių. 20 mokinių lanko krepšinį, 15 – futbolą, o 10 lanko abu. Kiek mokinių nelanko nei vieno iš šių būrelių?",
      "conceptIds": [
        "veno-diagrama",
        "aibiu-sajunga"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Apskaičiuojame, kiek mokinių lanko bent vieną būrelį (sąjunga). Naudojame formulę |A ∪ B| = |A| + |B| - |A ∩ B|.",
          "latex": "20 + 15 - 10 = 25"
        },
        {
          "text": "Iš bendro mokinių skaičiaus atimame tuos, kurie lanko bent vieną būrelį.",
          "latex": "30 - 25 = 5"
        }
      ],
      "answer": "5 mokiniai"
    },
    {
      "id": "poaibis-nustatymas",
      "title": "Poaibių radimas",
      "level": "medium",
      "problem": "Raskite visus aibės A = {1, 2} poaibius.",
      "conceptIds": [
        "poaibis",
        "tuscia-aibe"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Prisiminkite, kad tuščioji aibė yra kiekvienos aibės poaibis.",
          "latex": "\\emptyset"
        },
        {
          "text": "Surašome poaibius su vienu elementu.",
          "latex": "\\{1\\}, \\{2\\}"
        },
        {
          "text": "Surašome pačią aibę (kiekviena aibė yra savo pačios poaibis).",
          "latex": "\\{1, 2\\}"
        }
      ],
      "answer": "∅, {1}, {2}, {1, 2}"
    },
    {
      "id": "sudetingas-veiksmas",
      "title": "Kelių veiksmų derinimas",
      "level": "hard",
      "problem": "A = {1, 2, 3}, B = {2, 3, 4}, C = {3, 4, 5}. Raskite (A ∩ B) ∪ (B \\ C).",
      "conceptIds": [
        "aibiu-sankirta",
        "aibiu-skirtumas",
        "aibiu-sajunga"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Pirmiausia randame A ∩ B.",
          "latex": "A \\cap B = \\{2, 3\\}"
        },
        {
          "text": "Tada randame B \\ C.",
          "latex": "B \\setminus C = \\{2\\}"
        },
        {
          "text": "Galiausiai randame gautų aibių sąjungą.",
          "latex": "\\{2, 3\\} \\cup \\{2\\} = \\{2, 3\\}"
        }
      ],
      "answer": "{2, 3}"
    }
  ],
