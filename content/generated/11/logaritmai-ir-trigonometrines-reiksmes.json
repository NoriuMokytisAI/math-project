  "theory": [
    {
      "id": "logaritmo-savoka-teorija",
      "title": "1. Logaritmo sД…voka ir pagrindinis tapatumas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[logaritmas|Logaritmas]] yra matematinД— operacija, kuri nurodo, kokiu laipsniu reikia pakelti pagrindД…, kad gautume tam tikrД… skaiДҚiЕі. Tai yra atvirkЕЎtinis veiksmas laipsniavimui."
        },
        {
          "type": "definition",
          "conceptId": "logaritmas",
          "text": "SkaiДҚiaus $b$ logaritmas pagrindu $a$ (Еҫymima $\\log_a b$) yra laipsnio rodiklis, kuriuo pakД—lДҷ skaiДҚiЕі $a$, gauname skaiДҚiЕі $b$."
        },
        {
          "type": "formula",
          "formulaId": "log-def",
          "latex": "\\log_a b = c \\iff a^c = b"
        },
        {
          "type": "warning",
          "text": "SД…lygos: pagrindas $a$ turi bЕ«ti teigiamas ir nelygus vienetui ($a > 0, a \\neq 1$), o skaiДҚius $b$ turi bЕ«ti teigiamas ($b > 0$)."
        },
        {
          "type": "formula",
          "formulaId": "pagrindinis-logaritmu-tapatumas",
          "title": "Pagrindinis logaritmЕі tapatumas",
          "latex": "a^{\\log_a b} = b"
        }
      ]
    },
    {
      "id": "logaritmu-savybes-teorija",
      "title": "2. LogaritmЕі savybД—s ir veiksmai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Logaritmai turi savybes, kurios leidЕҫia sudД—tingus skaiДҚiavimus paversti paprastesniais."
        },
        {
          "type": "list",
          "items": [
            "**Sandaugos logaritmas:** $\\log_a (xy) = \\log_a x + \\log_a y$ (daugyba virsta sudД—timi).",
            "**Dalmens logaritmas:** $\\log_a (\\frac{x}, {y}) = \\log_a x - \\log_a y$ (dalyba virsta atimtimi).",
            "**Laipsnio logaritmas:** $\\log_a (x^k) = k \\cdot \\log_a x$ (laipsnДҜ galima iЕЎkelti ДҜ priekДҜ).",
            "**Vieneto logaritmas:** $\\log_a 1 = 0$.",
            "**Pagrindo logaritmas:** $\\log_a a = 1$."
          ]
        }
      ]
    },
    {
      "id": "pagrindo-keitimas-teorija",
      "title": "3. LogaritmЕі pagrindo keitimas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Jei turime logaritmД… nepatogiu pagrindu, galime jДҜ pakeisti ДҜ bet kokДҜ kitД… pagrindД… $c$."
        },
        {
          "type": "formula",
          "formulaId": "log-base-change",
          "latex": "\\log_a b = \\frac{\\log_c b}, {\\log_c a}"
        },
        {
          "type": "note",
          "text": "Е i formulД— ypaДҚ naudinga skaiДҚiuojant skaiДҚiuotuvu, kuriame daЕҫniausiai yra tik deЕЎimtainis ($\\lg x$, pagrindas 10) ir natЕ«ralusis ($\\ln x$, pagrindas $e$) logaritmai."
        }
      ]
    },
    {
      "id": "kampu-matavimas-teorija",
      "title": "4. KampЕі matavimas: laipsniai ir radianai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Trigonometrijoje kampai matuojami ne tik laipsniais, bet ir [[radianas|radianais]]."
        },
        {
          "type": "definition",
          "text": "Vienas radianas вҖ“ tai kampas, kurДҜ atitinka lanko ilgis, lygus apskritimo spinduliui."
        },
        {
          "type": "formula",
          "formulaId": "deg-to-rad",
          "latex": "180^\\circ = \\pi \\text{ rad}, \\quad 1^\\circ = \\frac{\\pi}, {180} \\text{ rad}"
        },
        {
          "type": "note",
          "text": "Atminkite pagrindines vertes: $90^\\circ = \\pi/2$, $60^\\circ = \\pi/3$, $45^\\circ = \\pi/4$, $30^\\circ = \\pi/6$."
        }
      ]
    },
    {
      "id": "vienetinis-apskritimas-teorija",
      "title": "5. Vienetinis apskritimas ir trigonometriniai santykiai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[vienetinis-apskritimas|Vienetinis apskritimas]] вҖ“ tai apskritimas, kurio spindulys $R=1$, o centras koordinaДҚiЕі pradЕҫios taЕЎke."
        },
        {
          "type": "list",
          "items": [
            "TaЕЎko koordinatД— $x$ ant apskritimo atitinka kampo **kosinusД…** ($\\cos \\alpha$).",
            "TaЕЎko koordinatД— $y$ ant apskritimo atitinka kampo **sinusД…** ($\\sin \\alpha$)."
          ]
        },
        {
          "type": "paragraph",
          "text": "Kadangi spindulys lygus 1, pagal Pitagoro teoremД… gauname pagrindinДҷ trigonometrijos tapatybДҷ:"
        },
        {
          "type": "formula",
          "formulaId": "trig-pythagorean",
          "latex": "\\sin^2 \\alpha + \\cos^2 \\alpha = 1"
        }
      ]
    },
    {
      "id": "pagrindines-trig-reiksmes-teorija",
      "title": "6. PagrindinД—s trigonometrinД—s reikЕЎmД—s",
      "blocks": [
        {
          "type": "paragraph",
          "text": "BЕ«tina Еҫinoti standartiniЕі kampЕі ($0^\\circ, 30^\\circ, 45^\\circ, 60^\\circ, 90^\\circ$) vertes. PavyzdЕҫiui, $\\sin 30^\\circ = 1/2$, $\\cos 60^\\circ = 1/2$, $\\sin 45^\\circ = \\sqrt{2}/2$."
        }
      ]
    },
    {
      "id": "redukcijos-formules-teorija",
      "title": "7. Redukcijos formulД—s ir jЕі taikymas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[redukcija|Redukcija]] leidЕҫia bet kokio kampo trigonometrinДҷ reikЕЎmДҷ pakeisti smailiojo kampo reikЕЎme."
        },
        {
          "type": "method",
          "text": "**TaisyklД—:**\n1. Nustatykite, kuriame ketvirtyje yra kampas ir koks ten pradinД—s funkcijos Еҫenklas.\n2. Jei naudojate $\\pi \\pm \\alpha$ arba $2\\pi \\pm \\alpha$, funkcija nesikeiДҚia.\n3. Jei naudojate $\\pi/2 \\pm \\alpha$ arba $3\\pi/2 \\pm \\alpha$, funkcija keiДҚiasi ДҜ kofunkcijД… (sin $\\leftrightarrow$ cos, tan $\\leftrightarrow$ cot)."
        }
      ]
    },
    {
      "id": "tan-ir-cot-teorija",
      "title": "8. Tangentas ir kotangentas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Be sinuso ir kosinuso naudojame [[tangentas|tangentД…]] ir [[kotangentas|kotangentД…]]."
        },
        {
          "type": "formula",
          "formulaId": "tan-def",
          "latex": "\\tan \\alpha = \\frac{\\sin \\alpha}, {\\cos \\alpha}"
        },
        {
          "type": "formula",
          "formulaId": "cot-def",
          "latex": "\\cot \\alpha = \\frac{\\cos \\alpha}, {\\sin \\alpha}"
        },
        {
          "type": "note",
          "text": "IЕЎ ЕЎiЕі formuliЕі iЕЎplaukia, kad $\tan \\alpha \\cdot \\cot \\alpha = 1$."
        }
      ]
    },
    {
      "id": "atvirkstines-trig-reiksmes-teorija",
      "title": "9. AtvirkЕЎtinД—s trigonometrinД—s reikЕЎmД—s",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Klausimas вҖһkoks kampas duoda tokiД… reikЕЎmДҷ?вҖң sprendЕҫiamas naudojant atvirkЕЎtines funkcijas: $\\arcsin x, \\arccos x, \\arctan x$."
        },
        {
          "type": "example",
          "text": "$\\arcsin(1/2) = 30^\\circ$ (arba $\\pi/6$), nes $\\sin 30^\\circ = 1/2$."
        }
      ]
    },
    {
      "id": "trig-zenklai-ketvirciuose",
      "title": "10. TrigonometriniЕі funkcijЕі Еҫenklai",
      "blocks": [
        {
          "type": "list",
          "items": [
            "I ketvirtis (0вҖ“90В°): visi teigiami.",
            "II ketvirtis (90вҖ“180В°): tik $\\sin$ teigiamas.",
            "III ketvirtis (180вҖ“270В°): tik $\\tan$ ir $\\cot$ teigiami.",
            "IV ketvirtis (270вҖ“360В°): tik $\\cos$ teigiamas."
          ]
        }
      ]
    }
