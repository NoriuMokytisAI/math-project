  "workedExamples": [
    {
      "id": "log-calc-basic",
      "title": "Logaritmo reikšmės skaičiavimas",
      "level": "easy",
      "problem": "Apskaičiuokite log_2 16 ir log_3 (1/27).",
      "conceptIds": [
        "logaritmas"
      ],
      "steps": [
        {
          "text": "16 yra 2⁴, todėl logaritmas yra 4.",
          "latex": "\\log_2 2^4 = 4"
        },
        {
          "text": "1/27 yra 3⁻³, todėl logaritmas yra -3.",
          "latex": "\\log_3 3^{-3} = -3"
        }
      ],
      "answer": "4 ir -3"
    },
    {
      "id": "log-simplify-ex",
      "title": "Logaritminio reiškinio paprastinimas",
      "level": "medium",
      "problem": "Suprastinkite: 2 log_5 10 - log_5 4.",
      "conceptIds": [
        "logaritmas"
      ],
      "steps": [
        {
          "text": "Įkeliame dauginamąjį į laipsnį.",
          "latex": "\\log_5 10^2 - \\log_5 4 = \\log_5 100 - \\log_5 4"
        },
        {
          "text": "Taikome skirtumo savybę (dalyba).",
          "latex": "\\log_5 (100 / 4) = \\log_5 25"
        },
        {
          "text": "Apskaičiuojame galutinę vertę.",
          "latex": "\\log_5 5^2 = 2"
        }
      ],
      "answer": "2"
    },
    {
      "id": "log-x-solve",
      "title": "Logaritminė lygtis su nežinomu pagrindu",
      "level": "medium",
      "problem": "Išspręskite lygtį: log_x 49 = 2.",
      "conceptIds": [
        "logaritmas"
      ],
      "steps": [
        {
          "text": "Pagal apibrėžimą: x² = 49.",
          "latex": "x^2 = 49"
        },
        {
          "text": "Kadangi pagrindas x privalo būti teigiamas, renkamės teigiamą šaknį.",
          "latex": "x = \\sqrt{49} = 7"
        }
      ],
      "answer": "x = 7"
    },
    {
      "id": "deg-rad-conv-ex",
      "title": "Laipsnių keitimas radianais",
      "level": "easy",
      "problem": "Paverskite 150° radianais.",
      "conceptIds": [
        "radianas"
      ],
      "steps": [
        {
          "text": "Dauginame iš π/180.",
          "latex": "150 \\cdot \\frac{\\pi}, {180} = \\frac{15\\pi}, {18} = \\frac{5\\pi}, {6}"
        }
      ],
      "answer": "5π/6 rad"
    },
    {
      "id": "reduction-ex",
      "title": "Redukcijos formulės taikymas",
      "level": "medium",
      "problem": "Apskaičiuokite cos(150°).",
      "conceptIds": [
        "redukcija"
      ],
      "steps": [
        {
          "text": "Užrašome kampą patogia forma: 150° = 180° - 30°.",
          "latex": "\\cos(180^\\circ - 30^\\circ)"
        },
        {
          "text": "150° yra II ketvirtyje, ten kosinusas neigiamas. Funkcija nesikeičia (nes naudojame 180°).",
          "latex": "-\\cos 30^\\circ"
        },
        {
          "text": "Įstatome lentelės vertę.",
          "latex": "-\\frac{\\sqrt{3}}, {2}"
        }
      ],
      "answer": "-√3/2"
    },
    {
      "id": "trig-identity-find",
      "title": "Sinuso radimas pagal kosinusą",
      "level": "medium",
      "problem": "Raskite sin α, jei cos α = 0,6 ir α yra I ketvirtyje.",
      "conceptIds": [
        "sinusas",
        "kosinusas"
      ],
      "steps": [
        {
          "text": "Naudojame pagrindinę tapatybę.",
          "latex": "\\sin^2 \\alpha = 1 - \\cos^2 \\alpha = 1 - 0{ }6^2 = 1 - 0{ }36 = 0{ }64"
        },
        {
          "text": "Traukiame šaknį. Kadangi I ketvirtis, sinusas teigiamas.",
          "latex": "\\sin \\alpha = \\sqrt{0{ }64} = 0{ }8"
        }
      ],
      "answer": "0.8"
    },
    {
      "id": "trig-simplify-identities",
      "title": "Trigonometrinio reiškinio paprastinimas",
      "level": "hard",
      "problem": "Suprastinkite: (1 - sin²α) / cos²α - 1.",
      "conceptIds": [
        "sinusas",
        "kosinusas"
      ],
      "steps": [
        {
          "text": "Atpažįstame, kad 1 - sin²α = cos²α.",
          "latex": "\\frac{\\cos^2 \\alpha}, {\\cos^2 \\alpha} - 1"
        },
        {
          "text": "Suprastiname trupmeną.",
          "latex": "1 - 1 = 0"
        }
      ],
      "answer": "0"
    },
    {
      "id": "arctan-ex",
      "title": "Atvirkštinės funkcijos vertė",
      "level": "easy",
      "problem": "Apskaičiuokite arctan(1) radianais.",
      "conceptIds": [
        "atvirkstine-trigonometrine-reiksme"
      ],
      "steps": [
        {
          "text": "Klausime: kokio smailiojo kampo tangentas lygus 1?",
          "latex": "\\tan \\alpha = 1 \\implies \\alpha = 45^\\circ"
        },
        {
          "text": "Paverčiame radianais.",
          "latex": "\\frac{\\pi}, {4}"
        }
      ],
      "answer": "π/4"
    }
  ],
