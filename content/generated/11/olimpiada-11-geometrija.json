  "theory": [
    {
      "id": "theory-geometry-inversion",
      "title": "Inversijos galia geometrijoje",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Inversija apskritimo atžvilgiu yra transformacija, kuri „išverčia“ plokštumą: taškai arti centro nukeliauja toli, o apskritimai, einantys per centrą, tampa tiesėmis."
        },
        {
          "type": "method",
          "text": "Sunkūs uždaviniai su besiliečiančiais apskritimais dažnai tampa paprasti, jei pasirenkate tinkamą inversijos centrą (paprastai lietimosi tašką). Tada besiliečiantys apskritimai tampa lygiagrečiomis tiesėmis."
        }
      ]
    },
    {
      "id": "theory-geometry-power",
      "title": "Taško galia ir radikalinė ašis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Taško $P$ galia apskritimo $\\omega(O, R)$ atžvilgiu apibrėžiama kaip $h = d^2 - R^2$, kur $d$ yra atstumas $PO$. Jei $P$ yra išorėje, tai lygu liestinės ilgio kvadratui."
        },
        {
          "type": "theorem",
          "text": "Radikalinė ašis yra visų taškų, turinčių vienodą galią dviejų apskritimų atžvilgiu, aibė. Tai visada yra tiesė, statmena apskritimų centrus jungiančiai atkarpai."
        }
      ]
    },
    {
      "id": "theory-geometry-theorems",
      "title": "Čevos ir Menelajo teoremos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Šios dvi teoremos yra pagrindiniai įrankiai nustatant taškų kolinearumą (Menelajas) arba tiesių susikirtimą viename taške (Čeva)."
        },
        {
          "type": "formula",
          "formulaId": "olimpiada-11-formula-menelaus",
          "latex": "\\frac{AF}{FB} \\cdot \\frac{BD}{DC} \\cdot \\frac{CE}{EA} = 1"
        }
      ]
    }
  ],
  "concepts": [
    {
      "id": "olimpiada-11-concept-inversion",
      "title": "Inversija",
      "type": "concept",
      "shortDefinition": "Transformacija, kuri tašką $P$ atvaizduoja į $P'$ taip, kad $OP \\cdot OP' = R^2$.",
      "intuition": "Tai tarsi atspindys apskritime: tai, kas buvo viduje, atsiduria išorėje, ir atvirkščiai.",
      "formal": "Inversija centro $O$ ir spindulio $R$ atžvilgiu: $f(P) = P'$, kur $P'$ yra spindulyje $OP$ ir $|OP'| = R^2/|OP|$.",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-11-concept-projective",
      "title": "Dvigubasis santykis",
      "type": "concept",
      "shortDefinition": "Projekcinės geometrijos invariantas keturiems taškams.",
      "intuition": "Nors projekcija keičia atstumus, ji išsaugo šį specifinį keturių taškų santykį.",
      "formal": "$(A,B;C,D) = \\frac{AC}{BC} / \\frac{AD}{BD}$ (naudojant orientuotas atkarpas).",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-11-concept-menelaus",
      "title": "Menelajo teorema",
      "type": "concept",
      "shortDefinition": "Sąlyga, kad trys taškai ant trikampio kraštinių (ar jų tęsinių) būtų vienoje tiesėje.",
      "intuition": "Jei tiesė kerta trikampį, atkarpų santykių sandauga yra 1.",
      "formal": "Taškai D, E, F yra vienoje tiesėje tada ir tik tada, kai $\\frac{AF}{FB} \\cdot \\frac{BD}{DC} \\cdot \\frac{CE}{EA} = 1$.",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-11-concept-power-of-point",
      "title": "Taško galia",
      "type": "concept",
      "shortDefinition": "Dydis $d^2 - R^2$, charakterizuojantis taško padėtį apskritimo atžvilgiu.",
      "intuition": "Tai matas, rodantis 'atstumą' iki apskritimo, išreikštą per sandaugas.",
      "formal": "Bet kuriai tiesei per P, kertančiai apskritimą taškuose A ir B, galia yra $PA \\cdot PB$ (su ženklu).",
      "relatedConceptIds": []
    },
    {
      "id": "olimpiada-11-concept-stewart",
      "title": "Stiuarto teorema",
      "type": "concept",
      "shortDefinition": "Sąryšis tarp trikampio kraštinių ir čevianos ilgio.",
      "intuition": "Leidžia apskaičiuoti bet kokios atkarpos iš viršūnės į pagrindą ilgį.",
      "formal": "$man + d^2n = b^2m + c^2n$ (kur n, m dalija pagrindą a).",
      "relatedConceptIds": []
    }
  ],
  "formulas": [
    {
      "id": "olimpiada-11-formula-power-of-point",
      "title": "Taško galios formulė",
      "latex": "h = d^2 - R^2 = PA \\cdot PB",
      "explanation": "Galioja bet kuriai tiesei per P, kertančiai apskritimą taškuose A ir B."
    },
    {
      "id": "olimpiada-11-formula-stewart",
      "title": "Stiuarto teorema",
      "latex": "b^2 m + c^2 n = a(d^2 + mn)",
      "explanation": "Čia d yra čevianos ilgis, m ir n - pagrindo a dalys."
    }
  ],
  "mistakes": [],
  "workedExamples": [
    {
      "title": "Inversijos taikymas besiliečiantiems apskritimams",
      "problem": "Du apskritimai $\\omega_1$ ir $\\omega_2$ liečiasi taške $P$. Tiesi per $P$ kerta $\\omega_1$ taške $A$ ir $\\omega_2$ taške $B$. Įrodykite, kad liestinės taškuose $A$ ir $B$ yra lygiagrečios.",
      "steps": [
        {
          "text": "Taikome inversiją su centru taške $P$."
        },
        {
          "text": "Po inversijos abu apskritimai $\\omega_1$ ir $\\omega_2$, einantys per centrą $P$, virsta lygiagrečiomis tiesėmis $L_1$ ir $L_2$."
        },
        {
          "text": "Tiesė $PAB$, einanti per inversijos centrą, virsta ta pačia tiese $PAB$."
        },
        {
          "text": "Taškai $A$ ir $B$ atvaizduojami į $A'$ ir $B'$ tiesėse $L_1$ ir $L_2$."
        },
        {
          "text": "Liestinė apskritimui taške $A$ po inversijos virsta apskritimu, einančiu per $A'$ ir $P$."
        },
        {
          "text": "Kampų išsaugojimo savybė užtikrina, kad liestinės virsta objektais, kurie išlaiko pradinį lygiagretumą vaizdų erdvėje."
        }
      ],
      "answer": "Įrodyta"
    },
    {
      "title": "Menelajo teoremos taikymas",
      "problem": "Trikampyje ABC taškas D yra kraštinėje BC taip, kad BD:DC = 2:1. Taškas E yra kraštinėje AC taip, kad AE:EC = 3:1. Tiesė DE kerta AB tęsinį taške F. Raskite AF:FB.",
      "steps": [
        {
          "text": "Taikome Menelajo teoremą trikampiui ABC ir tiesei F-E-D."
        },
        {
          "text": "$\\frac{AF}{FB} \\cdot \\frac{BD}{DC} \\cdot \\frac{CE}{EA} = 1$."
        },
        {
          "text": "Įstatome žinomus santykius: $\\frac{AF}{FB} \\cdot \\frac{2}{1} \\cdot \\frac{1}{3} = 1$."
        },
        {
          "text": "$\\frac{AF}{FB} \\cdot \\frac{2}{3} = 1 \\implies \\frac{AF}{FB} = \\frac{3}{2}$."
        }
      ],
      "answer": "3:2"
    },
    {
      "title": "Taško galios skaičiavimas",
      "problem": "Taškas P yra 5 cm atstumu nuo apskritimo centro. Apskritimo spindulys yra 3 cm. Raskite taško P galią.",
      "steps": [
        {
          "text": "Naudojame taško galios formulę $h = d^2 - R^2$."
        },
        {
          "text": "$d = 5, R = 3$."
        },
        {
          "text": "$h = 5^2 - 3^2 = 25 - 9 = 16$."
        }
      ],
      "answer": "16"
    },
    {
      "title": "Ptolemėjo teorema",
      "problem": "Įbrėžtinio keturkampio kraštinės yra 1, 2, 3, 4 (tokia tvarka). Raskite įstrižainių sandaugą.",
      "steps": [
        {
          "text": "Pagal Ptolemėjo teoremą, įbrėžtinio keturkampio įstrižainių sandauga lygi priešingų kraštinių sandaugų sumai."
        },
        {
          "text": "$d_1 d_2 = 1 \\cdot 3 + 2 \\cdot 4$."
        },
        {
          "text": "$d_1 d_2 = 3 + 8 = 11$."
        }
      ],
      "answer": "11"
    },
    {
      "title": "Stiuarto teorema pusiaukraštinei",
      "problem": "Trikampio kraštinės yra 5, 6, 7. Raskite pusiaukraštinės į kraštinę 7 ilgį.",
      "steps": [
        {
          "text": "Taikome Stiuarto teoremą $b^2 m + c^2 n = a(d^2 + mn)$."
        },
        {
          "text": "$a=7, b=5, c=6, m=3.5, n=3.5$."
        },
        {
          "text": "$5^2 \\cdot 3.5 + 6^2 \\cdot 3.5 = 7(d^2 + 3.5^2)$."
        },
        {
          "text": "$3.5(25+36) = 7(d^2 + 12.25) \\implies 61/2 = d^2 + 12.25$."
        },
        {
          "text": "$30.5 - 12.25 = d^2 \\implies d^2 = 18.25$."
        }
      ],
      "answer": "\\sqrt{18.25}"
    }
  ],
