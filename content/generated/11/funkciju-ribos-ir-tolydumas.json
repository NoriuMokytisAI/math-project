  "workedExamples": [
    {
      "id": "riba-seka-basic",
      "title": "Paprasta sekos riba",
      "level": "easy",
      "problem": "Apskaičiuokite ribą: $\\lim_{n \\to \\infty} \\frac{2n + 3}, {n + 1}$",
      "conceptIds": [
        "sekos-riba"
      ],
      "steps": [
        {
          "text": "Pastebime neapibrėžtumą $\\frac{\\infty}, {\\infty}$. Daliname skaitiklį ir vardiklį iš didžiausio $n$ laipsnio (šiuo atveju $n^1$).",
          "latex": "\\lim_{n \\to \\infty} \\frac{\\frac{2n}, {n} + \\frac{3}, {n}}, {\\frac{n}, {n} + \\frac{1}, {n}} = \\lim_{n \\to \\infty} \\frac{2 + \\frac{3}, {n}}, {1 + \\frac{1}, {n}}"
        },
        {
          "text": "Žinome, kad kai $n \\to \\infty$, tai $\\frac{3}, {n} \\to 0$ ir $\\frac{1}, {n} \\to 0$.",
          "latex": "\\frac{2 + 0}, {1 + 0} = 2"
        }
      ],
      "answer": "2"
