  "theory": [
    {
      "id": "racionaliosios-rodiklines-ir-logaritmines-nelygybes-ivadas",
      "title": "Įvadas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Racionaliosios, rodiklinės ir logaritminės nelygybės yra tema, kurioje mokomasi atpažinti pagrindinius aukštesniosios nelygybės modelius ir juos taikyti skaičiavimuose, tekste bei brėžiniuose."
        },
        {
          "type": "paragraph",
          "text": "Šioje temoje svarbiausia nuolat matyti ryšį tarp sąvokų [[kintamasis|Kintamasis]], [[reiskinys|Reiškinys]], [[koeficientas|Koeficientas]] ir uždavinių sprendimo."
        }
      ]
    },
    {
      "id": "racionaliosios-rodiklines-ir-logaritmines-nelygybes-svarbiausios-savokos",
      "title": "Svarbiausios sąvokos",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "kintamasis",
          "text": "Raidė, žyminti nežinomą arba kintantį dydį."
        },
        {
          "type": "definition",
          "conceptId": "reiskinys",
          "text": "Matematinis užrašas iš skaičių, kintamųjų ir veiksmų."
        },
        {
          "type": "definition",
          "conceptId": "koeficientas",
          "text": "Skaičius prie raidės."
        },
        {
          "type": "note",
          "text": "Jei sprendžiant kyla abejonė, pirmiausia tikrink, ar aiškiai supranti [[kintamasis|Kintamasis]] ir [[lygtis|Lygtis]]."
        }
      ]
    },
    {
      "id": "racionaliosios-rodiklines-ir-logaritmines-nelygybes-taisyklės",
      "title": "Svarbiausios taisyklės",
      "blocks": [
        {
          "type": "theorem",
          "text": "Racionaliosios, rodiklinės ir logaritminės nelygybės sprendimuose visada pirmiausia atskirk duomenis nuo ieškomo dydžio, o tada pasirink tinkamą modelį."
        },
        {
          "type": "property",
          "text": "Jei užduotyje pasirodo [[koeficientas|Koeficientas]] ar [[lygtis|Lygtis]], dažnai verta rašyti ryšį simboliais prieš skaičiuojant."
        },
        {
          "type": "formula",
          "formulaId": "sklaidos-desnis",
          "latex": "a(b+c)=ab+ac"
        }
      ]
    },
    {
      "id": "racionaliosios-rodiklines-ir-logaritmines-nelygybes-strategija",
      "title": "Sprendimo strategija",
      "blocks": [
        {
          "type": "method",
          "text": "1. Perskaityk užduotį ir pažymėk, kokie dydžiai žinomi. 2. Nustatyk, kuri sąvoka čia svarbiausia. 3. Užrašyk veiksmus arba ryšį. 4. Patikrink rezultatą kitaip arba atgaliniu skaičiavimu."
        },
        {
          "type": "warning",
          "text": "Dažna klaida yra imti skaičiuoti per anksti ir neįvardyti, ką reiškia gauta reikšmė."
        }
      ]
    },
    {
      "id": "racionaliosios-rodiklines-ir-logaritmines-nelygybes-rysys",
      "title": "Ryšys su kitomis temomis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Ši tema remiasi ankstesnėmis žiniomis iš kitų metų: skaičiavimu, reiškinių pertvarkymu, figūrų savybėmis ar duomenų skaitymu. Ji ruošia kelią tolimesnėms temoms, kuriose reikia daugiau bendro modelio ir tikslesnio argumentavimo."
        }
      ]
    }
  ],
