      "answer": "A ГўЛҶВӘ B = {1, 2, 3, 4, 5, 6}, A ГўЛҶВ© B = {3, 4}"
    },
    {
      "id": "aibiu-skirtumas-exmp",
      "title": "AibiГ…Ві skirtumo skaiГ„ВҚiavimas",
      "level": "easy",
      "problem": "Duotos aibГ„вҖ”s A = {a, b, c, d} ir B = {c, d, e}. Raskite A \\ B ir B \\ A.",
      "conceptIds": [
        "aibiu-skirtumas"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "IГ…ВЎ aibГ„вҖ”s A iГ…ВЎmetame elementus, kurie yra aibГ„вҖ”je B (tai c ir d).",
          "latex": "A \\setminus B = \\{a, b\\}"
