  "workedExamples": [
    {
      "id": "aibiu-veiksmai-1",
      "title": "SГ„вҖҰjungos ir sankirtos radimas",
      "level": "easy",
      "problem": "Duotos aibГ„вҖ”s A = {1, 2, 3, 4} ir B = {3, 4, 5, 6}. Raskite A ГўЛҶВӘ B ir A ГўЛҶВ© B.",
      "conceptIds": [
        "aibiu-sajunga",
        "aibiu-sankirta"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "SГ„вҖҰjungai suraГ…ВЎome visus elementus iГ…ВЎ abiejГ…Ві aibiГ…Ві, nepasikartodami.",
