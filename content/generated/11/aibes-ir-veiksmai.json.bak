  "theory": [
    {
      "id": "aibes-savoka",
      "title": "AibГ„вҖ”s sГ„вҖҰvoka ir Г…ВҫymГ„вҖ”jimas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[aibe|AibГ„вҖ”]] yra tam tikrГ…Ві objektГ…Ві, vadinamГ…Ві [[elementas|elementais]], rinkinys. AibГ„вҖ”s daГ…Вҫniausiai Г…Вҫymimos didГ…Вҫiosiomis raidГ„вҖ”mis (A, B, C...), o jГ…Ві elementai iГ…ВЎvardijami riestiniuose skliaustuose."
        },
        {
          "type": "definition",
          "conceptId": "aibe",
          "text": "AibГ„вҖ” ГўвӮ¬вҖң tai visuma objektГ…Ві, kurie turi bendrГ„вҖҰ poГ…ВҫymГ„ВҜ arba yra tiesiog sujungti Г„ВҜ vienГ„вҖҰ rinkinГ„ВҜ."
        },
        {
          "type": "paragraph",
          "text": "Jei objektas x priklauso aibei A, raГ…ВЎome x ГўЛҶЛҶ A. Jei nepriklauso ГўвӮ¬вҖң x ГўЛҶвҖ° A. AibГ„вҖ”, neturinti nei vieno elemento, vadinama [[tuscia-aibe|tuГ…ВЎГ„ВҚiГ„вҖҰja aibe]] ir Г…Вҫymima ГўЛҶвҖҰ."
        }
      ]
    },
    {
      "id": "aibiu-sajunga-ir-sankirta",
      "title": "AibiГ…Ві sГ„вҖҰjunga ir sankirta",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Pagrindiniai veiksmai su aibГ„вҖ”mis yra [[aibiu-sajunga|sГ„вҖҰjunga]] ir [[aibiu-sankirta|sankirta]]."
        },
        {
          "type": "property",
          "text": "AibiГ…Ві A ir B sГ„вҖҰjunga (A ГўЛҶВӘ B) yra aibГ„вҖ”, kuriГ„вҖҰ sudaro visi elementai, priklausantys bent vienai iГ…ВЎ tГ…Ві aibiГ…Ві."
        },
        {
          "type": "formula",
          "formulaId": "sajungos-apibrezimas",
          "latex": "A \\cup B = \\{x \\mid x \\in A \\text{ arba } x \\in B\\}"
        },
        {
          "type": "property",
          "text": "AibiГ…Ві A ir B sankirta (A ГўЛҶВ© B) yra aibГ„вҖ”, kuriГ„вҖҰ sudaro tik tie elementai, kurie priklauso ir aibei A, ir aibei B tuo paГ„ВҚiu metu."
        },
        {
          "type": "formula",
          "formulaId": "sankirtos-apibrezimas",
          "latex": "A \\cap B = \\{x \\mid x \\in A \\text{ ir } x \\in B\\}"
        }
      ]
    },
    {
      "id": "aibiu-skirtumas-ir-poaibis",
      "title": "AibiГ…Ві skirtumas ir poaibis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[aibiu-skirtumas|AibiГ…Ві skirtumas]] (A \\ B) yra aibГ„вҖ”, kuriГ„вҖҰ sudaro elementai, priklausantys aibei A, bet nepriklausantys aibei B."
        },
        {
          "type": "formula",
          "formulaId": "skirtumo-apibrezimas",
          "latex": "A \\setminus B = \\{x \\mid x \\in A \\text{ ir } x \\notin B\\}"
        },
        {
          "type": "paragraph",
          "text": "Jei kiekvienas aibГ„вҖ”s B elementas priklauso ir aibei A, sakome, kad B yra aibГ„вҖ”s A [[poaibis|poaibis]] (B ГўЕ вҖ  A)."
        }
      ]
    },
    {
      "id": "veno-diagramos-teorija",
      "title": "Veno diagramos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[veno-diagrama|Veno diagramos]] yra vaizdus bГ…В«das aibГ„вҖ”ms ir veiksmams su jomis pavaizduoti plokГ…ВЎtumoje (daГ…Вҫniausiai apskritimais)."
        },
        {
          "type": "note",
          "text": "Veno diagramos padeda sprГ„в„ўsti uГ…Вҫdavinius, kuriuose reikia rasti elementГ…Ві skaiГ„ВҚiГ…Ві susikertanГ„ВҚiose grupГ„вҖ”se."
        }
      ]
    }
  ],
