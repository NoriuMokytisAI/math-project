  "theory": [
    {
      "id": "laipsnio-samprata",
      "title": "Kas yra laipsnis?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Matematikoje dažnai tenka tą patį skaičių dauginti iš savęs daug kartų. Pavyzdžiui, užrašas $2 \\cdot 2 \\cdot 2 \\cdot 2 \\cdot 2$ užima daug vietos. Kad būtų patogiau, sugalvotas trumpesnis užrašas – laipsnis."
        },
        {
          "type": "definition",
          "conceptId": "laipsnis",
          "text": "[[laipsnis|Laipsnis]] – tai sandaugos, susidedančios iš vienodų daugiklių, trumpas užrašas. Užrašas $a^n$ skaitomas: „$a$ pakelta $n$-tuoju laipsniu“."
        },
        {
          "type": "paragraph",
          "text": "Šiame užraše skaičius $a$ vadinamas [[pagrindas|pagrindu]] (skaičius, kurį dauginame), o skaičius $n$ – [[rodiklis|rodikliu]] (kiek kartų tą skaičių dauginame)."
        },
        {
          "type": "note",
          "text": "Svarbu: bet koks skaičius (išskyrus nulį) pakeltas nuliniu laipsniu yra lygus 1 ($a^0 = 1$), o pirmuoju laipsniu – pačiam sau ($a^1 = a$)."
        }
      ]
    },
    {
      "id": "kvadratas-ir-kubas",
      "title": "Kvadratas ir kubas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Antrasis ir trečiasis laipsniai geometrijoje turi specialius pavadinimus, nes jie tiesiogiai susiję su figūrų matavimais."
        },
        {
          "type": "definition",
          "conceptId": "kvadratas",
          "text": "Skaičiaus [[kvadratas|kvadratas]] ($a^2$) yra to skaičiaus sandauga iš savęs. Geometrijoje tai atitinka kvadrato, kurio kraštinė $a$, plotą."
        },
        {
          "type": "definition",
          "conceptId": "kubas",
          "text": "Skaičiaus [[kubas|kubas]] ($a^3$) yra trijų vienodų skaičių sandauga. Geometrijoje tai atitinka kubo, kurio briauna $a$, tūrį."
        },
        {
          "type": "paragraph",
          "text": "Pavyzdžiui, $5^2 = 25$ (kvadratas), o $5^3 = 125$ (kubas)."
        }
      ]
    },
    {
      "id": "laipsniu-savybes-daugyba-dalyba",
      "title": "Veiksmai su laipsniais: daugyba ir dalyba",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Svarbiausia taisyklė: veiksmai su laipsnių rodikliais atliekami tik tada, kai laipsnių **pagrindai yra vienodi**."
        },
        {
          "type": "method",
          "text": "1. Dauginant laipsnius su vienodais pagrindais, pagrindas paliekamas tas pats, o rodikliai sudedami.",
          "latex": "a^m \\cdot a^n = a^{m+n}"
        },
        {
          "type": "method",
          "text": "2. Dalijant laipsnius su vienodais pagrindais, pagrindas lieka tas pats, o rodikliai atimami.",
          "latex": "\\frac{a^m}{a^n} = a^{m-n}"
        },
        {
          "type": "warning",
          "text": "Niekada nesudėkite laipsnių rodiklių, jei pagrindai skirtingi! Pavyzdžiui, $2^3 \\cdot 3^2$ negalima suprastinti į vieną laipsnį."
        }
      ]
    },
    {
      "id": "laipsnio-kelimas-laipsniu",
      "title": "Laipsnio kėlimas laipsniu ir sandaugos laipsnis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Ką daryti, jei laipsnį vėl reikia kelti laipsniu? Arba jei laipsniu keliame visą skliaustelį?"
        },
        {
          "type": "formula",
          "formulaId": "laipsnio-kelimas-laipsniu",
          "latex": "(a^m)^n = a^{m \\cdot n}"
        },
        {
          "type": "paragraph",
          "text": "Keliant laipsnį laipsniu, rodikliai sudauginami. O keliant sandaugą, laipsniu keliamas kiekvienas daugiklis atskirai:"
        },
        {
          "type": "formula",
          "formulaId": "sandaugos-laipsnis",
          "latex": "(a \\cdot b)^n = a^n \\cdot b^n"
        }
      ]
    },
    {
      "id": "kvadratine-saknis",
      "title": "Kvadratinė šaknis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Šaknies traukimas yra veiksmas, atvirkštinis kėlimui kvadratu. Jei kėlimas kvadratu klausia „kiek bus 5 kvadratu?“, tai šaknis klausia „kokį skaičių pakėlę kvadratu gausime 25?“."
        },
        {
          "type": "definition",
          "conceptId": "kvadratine-saknis",
          "text": "Skaičiaus $a$ [[kvadratine-saknis|kvadratinė šaknis]] ($\\sqrt{a}$) yra toks neneigiamas skaičius, kurį pakėlę kvadratu gauname $a$."
        },
        {
          "type": "note",
          "text": "Kadangi bet koks skaičius (tiek teigiamas, tiek neigiamas), pakeltas kvadratu, tampa teigiamu, kvadratinės šaknies iš neigiamo skaičiaus ištraukti realiųjų skaičių aibėje negalima."
        }
      ]
    },
    {
      "id": "neigiamas-pagrindas",
      "title": "Neigiamas pagrindas ir laipsnis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Keliant neigiamą skaičių laipsniu, rezultato ženklas priklauso nuo rodiklio lyginumo:"
        },
        {
          "type": "method",
          "text": "- Jei rodiklis yra **lyginis** (2, 4, 6...), rezultatas visada teigiamas: $(-3)^2 = 9$.\n- Jei rodiklis yra **nelyginis** (1, 3, 5...), rezultatas lieka neigiamas: $(-3)^3 = -27$."
        },
        {
          "type": "warning",
          "text": "Būkite atsargūs su skliausteliais! $-3^2$ reiškia $-(3 \\cdot 3) = -9$, o $(-3)^2$ reiškia $(-3) \\cdot (-3) = 9$."
        }
      ]
    },
    {
      "id": "standartine-israiska",
      "title": "Standartinė skaičiaus išraiška",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Moksle (ypač astronomijoje ar mikrobiologijoje) susiduriame su milžiniškais arba mikroskopiniais skaičiais. Juos patogiau užrašyti naudojant 10-ies laipsnį."
        },
        {
          "type": "definition",
          "conceptId": "standartine-israiska",
          "text": "Skaičiaus [[standartine-israiska|standartinė išraiška]] yra pavidalas $a \\cdot 10^n$, kur $1 \\le a < 10$, o $n$ yra sveikasis skaičius."
        },
        {
          "type": "paragraph",
          "text": "Pavyzdžiui, atstumas nuo Žemės iki Saulės ($150\\,000\\,000$ km) standartine išraiška užrašomas kaip $1,5 \\cdot 10^8$ km."
        }
      ]
    },
    {
      "id": "veiksmu-tvarka-laipsniai",
      "title": "Veiksmų tvarka",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Atsiradus laipsniams ir šaknims, mūsų įprasta veiksmų tvarka pasipildo nauju prioritetu."
        },
        {
          "type": "method",
          "text": "1. Veiksmai skliausteliuose.\n2. Kėlimas laipsniu ir šaknies traukimas.\n3. Daugyba ir dalyba.\n4. Sudėtis ir atimtis."
        }
      ]
    }
  ],
