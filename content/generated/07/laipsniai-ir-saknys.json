      ],
      "steps": [
        {
          "text": "Randame kvadrato kraštinę ištraukę šaknį iš ploto.",
          "latex": "a = \\sqrt{144} = 12 \\text{ cm}"
        },
        {
          "text": "Apskaičiuojame perimetrą dauginant kraštinę iš 4.",
          "latex": "P = 4 \\cdot 12 = 48 \\text{ cm}"
        }
      ],
      "answer": "48 cm"
    },
    {
      "id": "lp-exmp-8",
      "title": "Sudėtingas reiškinys su trupmena",
      "level": "hard",
      "problem": "Apskaičiuokite: $\\frac{4^5 \\cdot 2^6}{8^4}$.",
      "conceptIds": [
        "laipsnis"
      ],
      "steps": [
        {
          "text": "Suvienodiname visus pagrindus (paverčiame į pagrindą 2).",
          "latex": "4^5 = (2^2)^5 = 2^{10}; \\quad 8^4 = (2^3)^4 = 2^{12}"
        },
        {
          "text": "Įrašome į pradinį reiškinį.",
          "latex": "\\frac{2^{10} \\cdot 2^6}{2^{12}}"
        },
        {
          "text": "Suprastiname skaitiklį.",
          "latex": "\\frac{2^{16}}{2^{12}}"
        },
        {
          "text": "Atimame rodiklius.",
          "latex": "2^4 = 16"
        }
      ],
      "answer": "16"
    }
