  "workedExamples": [
    {
      "id": "lp-exmp-1",
      "title": "Laipsnių daugyba ir dalyba",
      "level": "easy",
      "problem": "Suprastinkite reiškinį: $3^7 \\cdot 3^5 : 3^8$.",
      "conceptIds": [
        "laipsnis"
      ],
      "steps": [
        {
          "text": "Pirmiausia sudauginame laipsnius (sudedame rodiklius).",
          "latex": "3^{7+5} = 3^{12}"
        },
        {
          "text": "Tada padalijame (atimame rodiklius).",
          "latex": "3^{12-8} = 3^4"
        },
        {
          "text": "Apskaičiuojame galutinę reikšmę.",
          "latex": "3^4 = 3 \\cdot 3 \\cdot 3 \\cdot 3 = 81"
        }
      ],
      "answer": "81"
    },
    {
      "id": "lp-exmp-2",
      "title": "Neigiamo skaičiaus kėlimas laipsniu",
      "level": "easy",
      "problem": "Apskaičiuokite: $(-2)^4 + (-2)^3$.",
      "conceptIds": [
        "laipsnis"
      ],
      "steps": [
        {
          "text": "Kelime lyginiu laipsniu (minusas dingsta).",
          "latex": "(-2)^4 = 16"
        },
        {
          "text": "Kelime nelyginiu laipsniu (minusas lieka).",
          "latex": "(-2)^3 = -8"
        },
        {
          "text": "Sudedame gautus rezultatus.",
          "latex": "16 + (-8) = 8"
        }
      ],
      "answer": "8"
    },
    {
      "id": "lp-exmp-3",
      "title": "Kvadratinė šaknis reiškinyje",
      "level": "medium",
      "problem": "Apskaičiuokite: $2 \\cdot \\sqrt{64} - 3^2$.",
      "conceptIds": [
        "kvadratine-saknis",
        "kvadratas"
      ],
      "steps": [
        {
          "text": "Ištraukiame šaknį.",
          "latex": "\\sqrt{64} = 8"
        },
        {
          "text": "Pakeliame kvadratu.",
          "latex": "3^2 = 9"
        },
        {
          "text": "Atliekame daugybą ir atimtį pagal tvarką.",
          "latex": "2 \\cdot 8 - 9 = 16 - 9 = 7"
        }
      ],
      "answer": "7"
    },
    {
      "id": "lp-exmp-4",
      "title": "Laipsnio kėlimas laipsniu",
      "level": "medium",
      "problem": "Suprastinkite ir užrašykite vienu laipsniu: $(5^3)^4 \\cdot 5^2$.",
      "conceptIds": [
        "laipsnis"
      ],
      "steps": [
        {
          "text": "Pakeliame laipsnį laipsniu (dauginame rodiklius).",
          "latex": "(5^3)^4 = 5^{12}"
        },
        {
          "text": "Dauginame gautą rezultatą (sudedame rodiklius).",
          "latex": "5^{12} \\cdot 5^2 = 5^{14}"
        }
      ],
      "answer": "$5^{14}$"
    },
    {
      "id": "lp-exmp-5",
      "title": "Standartinė išraiška",
      "level": "medium",
      "problem": "Užrašykite skaičių $420\\,000$ standartine išraiška.",
      "conceptIds": [
        "standartine-israiska"
      ],
      "steps": [
        {
          "text": "Padedame kablelį po pirmo skaitmens, kad gautume skaičių tarp 1 ir 10.",
          "latex": "4,2"
        },
        {
          "text": "Suskaičiuojame, kiek vietų kablelis pasislinko į kairę.",
          "latex": "\\text{Pasislinko 5 vietas.}"
        },
        {
          "text": "Užrašome su 10-ies laipsniu.",
          "latex": "4,2 \\cdot 10^5"
        }
      ],
      "answer": "$4,2 \\cdot 10^5$"
    },
    {
      "id": "lp-exmp-6",
      "title": "Daugyba naudojant standartinę išraišką",
      "level": "hard",
      "problem": "Apskaičiuokite sandaugą $(2 \\cdot 10^3) \\cdot (3 \\cdot 10^4)$ ir atsakymą pateikite standartine išraiška.",
      "conceptIds": [
        "standartine-israiska"
      ],
      "steps": [
        {
          "text": "Sudauginame skaičius prieš laipsnius.",
