        {
          "text": "Sujungiame į standartinę išraišką.",
          "latex": "6 \\cdot 10^7"
        }
      ],
      "answer": "$6 \\cdot 10^7$"
    },
    {
      "id": "lp-exmp-7",
      "title": "Atvirkštinis uždavinys su kvadratu",
