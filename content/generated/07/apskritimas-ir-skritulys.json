      "conceptIds": ["lankas"],
      "formulaIds": ["lanko-ilgio-formule"],
      "steps": [
        {
          "text": "Naudojame lanko ilgio formulę.",
          "latex": "l = \\frac{2\\pi r \\alpha}{360}"
        },
        {
          "text": "Įrašome žinomas reikšmes.",
          "latex": "l = \\frac{2\\pi \\cdot 6 \\cdot 60}{360}"
        },
        {
          "text": "Suprastiname trupmeną (60/360 = 1/6).",
          "latex": "l = \\frac{12\\pi}{6} = 2\\pi \\text{ cm}"
        }
      ],
      "answer": "2π cm"
    },
    {
      "id": "apsk-exmp-4",
      "title": "Spindulio radimas iš ploto",
      "level": "medium",
      "problem": "Skritulio plotas yra 25π cm². Rask jo apskritimo ilgį.",
      "conceptIds": ["skritulio-plotas", "apskritimo-ilgis", "spindulys"],
      "formulaIds": ["skritulio-ploto-formule", "apskritimo-ilgio-formule"],
      "steps": [
        {
          "text": "Iš ploto formulės randame spindulį r.",
          "latex": "25\\pi = \\pi r^2 \\implies r^2 = 25 \\implies r = 5 \\text{ cm}"
        },
        {
          "text": "Dabar apskaičiuojame ilgį.",
          "latex": "C = 2\\pi r = 2\\pi \\cdot 5 = 10\\pi \\text{ cm}"
        }
      ],
      "answer": "10π cm"
    },
    {
      "id": "apsk-exmp-5",
