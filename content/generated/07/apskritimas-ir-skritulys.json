  "theory": [
    {
      "id": "ivadas-i-apskritimo-geometrija",
      "title": "Įvadas į apskritimo geometriją",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Apskritimas yra viena tobuliausių ir dažniausiai gamtoje bei technikoje sutinkamų geometrinių figūrų. Nuo pat seniausių laikų žmonės stebėjo saulės diską, pilnatį, naudojo ratus transportui ir kūrė architektūros šedevrus remdamiesi apskritimo savybėmis. Šioje pamokoje išmoksime ne tik atskirti apskritimą nuo skritulio, bet ir skaičiuoti jų elementus: ilgį, plotą, lankus bei išpjovas."
        },
        {
          "type": "note",
          "text": "Svarbu suprasti esminį skirtumą: apskritimas yra linija (tarsi lankas ar tuščiaviduris žiedas), o skritulys – plokštumos dalis (tarsi moneta ar blynas)."
        }
      ]
    },
    {
      "id": "pagrindines-savokos-ir-elementai",
      "title": "Pagrindinės sąvokos ir elementai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kiekvienas apskritimas turi savo centrą – tašką, nuo kurio visi apskritimo taškai yra nutolę vienodu atstumu."
        },
        {
          "type": "definition",
          "conceptId": "apskritimas",
          "text": "[[apskritimas|Apskritimas]] – tai visų plokštumos taškų, nutolusių nuo vieno taško (centro) tuo pačiu atstumu $r$, aibė."
        },
        {
          "type": "definition",
          "conceptId": "spindulys",
          "text": "[[spindulys|Spindulys]] ($r$) – atkarpa, jungianti apskritimo centrą su bet kuriuo apskritimo tašku."
        },
        {
          "type": "definition",
          "conceptId": "skersmuo",
          "text": "[[skersmuo|Skersmuo]] ($d$) – atkarpa, jungianti du apskritimo taškus ir einanti per jo centrą."
        },
        {
          "type": "method",
          "text": "Ryšys tarp spindulio ir skersmens yra esminis sprendžiant uždavinius: skersmuo visada yra dvigubai ilgesnis už spindulį.",
          "latex": "d = 2r \\quad \\text{arba} \\quad r = \\frac{d}{2}"
        },
        {
          "type": "paragraph",
          "text": "Be spindulio ir skersmens, apskritime galime brėžti stygas. Styga – tai atkarpa, jungianti du bet kuriuos apskritimo taškus. Ilgiausia apskritimo styga yra skersmuo."
        }
      ]
    },
    {
      "id": "skaicius-pi-ir-istorija",
      "title": "Paslaptingasis skaičius π (Pi)",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Jei paimtumėte bet kokį apskritą daiktą (puodelį, monetą, ratą), išmatuotumėte jo apvadinį ilgį ir padalintumėte iš jo skersmens, visada gautumėte tą patį skaičių. Šis pastovus santykis matematikoje žymimas graikiška raide $\\pi$."
        },
        {
          "type": "definition",
          "conceptId": "pi-skaicius",
          "text": "[[pi-skaicius|Skaičius π]] yra apskritimo ilgio ir jo skersmens santykis. Tai iracionalusis skaičius, kurio skaitmenų seka po kablelio yra begalinė ir neperiodinė."
        },
        {
          "type": "note",
          "text": "Mokyklos kurse dažniausiai naudojame apytikslę reikšmę $\\pi \\approx 3,14$ arba $\\pi \\approx \\frac{22}{7}$."
        },
        {
          "type": "paragraph",
          "text": "Senovės graikų matematikas Archimedas pirmasis moksliškai pagrindė $\\pi$ vertę, naudodamas įbrėžtinius ir apibrėžtinius daugiakampius. Šiandien kompiuteriai apskaičiavo trilijonus $\\pi$ skaitmenų, tačiau praktiniams inžineriniams skaičiavimams visiškai pakanka vos kelių skaitmenų po kablelio."
        }
      ]
    },
    {
      "id": "apskritimo-ilgis",
      "title": "Apskritimo ilgis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Apskritimo ilgis (dažnai vadinamas apskritimo perimetru) parodo, kokį atstumą nueitume apėję vieną kartą aplink apskritimą."
        },
        {
          "type": "formula",
          "formulaId": "apskritimo-ilgio-formule",
          "latex": "C = 2\\pi r \\quad \\text{arba} \\quad C = \\pi d"
        },
        {
          "type": "paragraph",
          "text": "Kur $C$ – apskritimo ilgis, $r$ – spindulys, $d$ – skersmuo. Jei užduotyje prašoma pateikti „tikslų atsakymą“, skaičiaus $\\pi$ nereikia keisti į 3,14 – jis paliekamas kaip simbolis (pavyzdžiui, $10\\pi$)."
        },
        {
          "type": "warning",
          "text": "Skaitydami sąlygą, visada atkreipkite dėmesį, ar duotas spindulys, ar skersmuo. Tai dažniausia klaidų priežastis!"
        }
      ]
    },
    {
      "id": "skritulio-plotas-geometrija",
      "title": "Skritulio plotas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Skritulio plotas nusako plokštumos dalį, esančią apskritimo viduje. Galite įsivaizduoti, kad skritulį supjaustome į labai daug siaurų trikampių (išpjovų) ir sudėliojame juos į figūrą, panašią į stačiakampį. Tokio „stačiakampio“ viena kraštinė būtų lygi spinduliui $r$, o kita – pusei apskritimo ilgio $\\pi r$."
        },
        {
          "type": "formula",
          "formulaId": "skritulio-ploto-formule",
          "latex": "S = \\pi r^2"
        },
        {
          "type": "method",
          "text": "Jei žinomas tik skersmuo $d$, plotą galime skaičiuoti taip:",
          "latex": "S = \\pi \\left(\\frac{d}{2}\\right)^2 = \\frac{\\pi d^2}{4}"
        },
        {
          "type": "note",
          "text": "Nepamirškite matavimo vienetų: jei spindulys cm, tai ilgis cm, o plotas – $\\text{cm}^2$."
        }
      ]
    },
    {
      "id": "lankas-ir-centrinis-kampas",
      "title": "Apskritimo lankas ir centrinis kampas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Dalis apskritimo vadinama lanku. Lanką galime apibūdinti jo ilgiu (centimetrais, metrais) arba laipsniais. Kampas, kurio viršūnė yra apskritimo centre, vadinamas centriniu kampu."
        },
        {
          "type": "definition",
          "conceptId": "lankas",
          "text": "[[lankas|Lankas]] – tai apskritimo dalis tarp dviejų jo taškų. Lanką atitinka tam tikras centrinis kampas $\\alpha$."
        },
        {
          "type": "paragraph",
          "text": "Kadangi visas apskritimas sudaro $360^\\circ$, tai $1^\\circ$ lanko ilgis yra $\\frac{1}{360}$ dalis viso ilgio. Todėl lanko, kurio centrinis kampas yra $\\alpha$, ilgio formulė yra:"
        },
        {
          "type": "formula",
          "formulaId": "lanko-ilgio-formule",
          "latex": "l = \\frac{2\\pi r \\alpha}{360} = \\frac{\\pi r \\alpha}{180}"
        }
      ]
    },
    {
      "id": "ispjova-ir-jos-plotas",
      "title": "Skritulio išpjova",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Išpjova yra skritulio dalis, panaši į picos gabalėlį. Ją riboja du spinduliai ir lankas."
        },
        {
          "type": "definition",
          "conceptId": "ispjova",
          "text": "[[ispjova|Išpjova]] – tai skritulio dalis, apribota dviem spinduliais ir lanku."
        },
        {
          "type": "paragraph",
          "text": "Išpjovos plotas sudaro tokią pačią viso skritulio ploto dalį, kokią centrinis kampas sudaro nuo viso $360^\\circ$ kampo:"
        },
        {
          "type": "formula",
          "formulaId": "ispjovos-ploto-formule",
          "latex": "S_{\\text{išpj}} = \\frac{\\pi r^2 \\alpha}{360}"
        },
        {
          "type": "method",
          "text": "Yra dar vienas patogus būdas rasti išpjovos plotą, jei žinome lanko ilgį $l$:",
          "latex": "S_{\\text{išpj}} = \\frac{l \\cdot r}{2}"
        }
      ]
    },
    {
      "id": "praktiniai-patarimai-ir-klaidos",
      "title": "Praktiniai patarimai ir dažnos klaidos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Sprendžiant uždavinius su apskritimais, svarbu nepasimesti tarp formulių. Štai keli patarimai:"
        },
        {
          "type": "method",
          "text": "1. Visada pirmiausia išsiaiškinkite spindulį $r$. Jei duotas skersmuo, plotas ar ilgis, pirmas žingsnis beveik visada bus rasti $r$. 2. Plotas visada turi kvadratą ($r^2$), nes plotas matuojamas kvadratiniais vienetais. 3. Ilgis visada yra linijinis ($2r$ arba $d$)."
        },
        {
          "type": "warning",
          "text": "Dažna klaida: skaičiuojant plotą, mokiniai kartais padaugina $\\pi$ iš $r$, o tada gautą rezultatą kelia kvadratu. Teisinga tvarka: pirmiausia $r$ keliamas kvadratu, o tada dauginamas iš $\\pi$."
        }
      ]
    },
    {
      "id": "apskritimas-ir-skritulys-gilinimas-prasme",
      "title": "Gilesnis temos vaizdas: ką čia iš tikrųjų mokomės",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Tema „Apskritimas ir skritulys“ 7 klasės kurse priklauso sričiai „Geometrija ir matavimai“, todėl jos tikslas nėra vien išmokti vieną taisyklę. Reikia pamatyti, kokį matematinį ryšį ši tema aprašo, kada jį galima taikyti ir kaip atpažinti situacijas, kuriose tas pats ryšys pasirodo kita forma. Mokantis verta pradėti nuo paprasto klausimo: kokie dydžiai čia kinta, kas lieka pastovu ir kokios sąlygos riboja galimus veiksmus? Kai šis klausimas atsakytas, formulės tampa ne atskirais sakiniais, o trumpu ryšių užrašu."
        },
        {
          "type": "note",
          "text": "Šią temą patogu skaityti per tokį objektyvą: brėžinys, kampų ryšiai, atkarpų santykiai, plotai ir pagalbinės konstrukcijos. Jei mokinys geba tą patį ryšį paaiškinti žodžiais, parodyti pavyzdyje ir patikrinti skaičiavimu, jis jau turi tvirtą pagrindą pereiti prie įvairesnių uždavinių."
        }
      ]
    },
    {
      "id": "apskritimas-ir-skritulys-gilinimas-savokos",
      "title": "Sąvokų ryšiai ir minimalus žinių žemėlapis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Svarbiausios sąvokos: Apskritimas, Skritulys, Spindulys, Skersmuo, Skaičius Pi, Apskritimo ilgis ir Skritulio plotas. Mokantis verta prie kiekvienos sąvokos prisirašyti po vieną pavyzdį, vieną ne pavyzdį ir vieną tipinę klaidą; taip žodynas virsta sprendimo įrankiu, o ne atmintinai išmoktu sąrašu."
        },
        {
          "type": "method",
          "text": "Mokantis temos „Apskritimas ir skritulys“ naudinga susirašyti tris stulpelius: sąvoka, kaip ją atpažįstu uždavinio tekste, ir kokį veiksmą ji dažniausiai leidžia atlikti. Pavyzdžiui, jei sąlygoje atsiranda apribojimas, jis dažnai lemia apibrėžimo sritį, galimus atvejus arba tikrinimo žingsnį. Jei atsiranda santykis, ieškome proporcijos, mastelio, vieneto dalies arba lygiaverčio reiškinio. Toks žemėlapis sumažina spėliojimą ir padeda spręsti net tada, kai uždavinio formuluotė nėra pažįstama."
        }
      ]
    },
    {
      "id": "apskritimas-ir-skritulys-gilinimas-metodas",
      "title": "Sprendimo metodas nuo sąlygos iki atsakymo",
      "blocks": [
        {
          "type": "method",
          "text": "Pradėk nuo tikslaus brėžinio, pažymėk žinomus kampus arba ilgius, tada ieškok panašių trikampių, lygių kampų, apskritimo savybių ar ploto santykių. Jei tiesioginis kelias nematomas, pridėk pagalbinę atkarpą, aukštinę, pusiaukampinę arba apskritimą ir tikrink, ar naujas objektas sujungia dvi uždavinio dalis."
        },
        {
          "type": "paragraph",
          "text": "Praktikoje tai reiškia, kad pirmas sprendimo veiksmas neturėtų būti aklas skaičiavimas. Pirmiausia perrašyk sąlygą matematiškai: pažymėk nežinomuosius, užrašyk duotus dydžius, išskirk apribojimus ir nuspręsk, kokio tipo atsakymo reikia. Tada rinkis vieną pagrindinį kelią ir jo laikykis iki pat patikros. Jei kelias stringa, neperrašinėk visko iš naujo: grįžk į sąlygą ir paklausk, kuri informacija dar nepanaudota. Dažnai būtent nepanaudota sąlygos dalis parodo trūkstamą žingsnį."
        }
      ]
    },
    {
      "id": "apskritimas-ir-skritulys-gilinimas-pavyzdziai",
      "title": "Kaip skaityti pavyzdžius ir perkelti metodą",
      "blocks": [
        {
          "type": "example",
          "text": "Tipinis šios temos uždavinio sakinys gali atrodyti taip: „Apskaičiuok apskritimo ilgį, kai r = 7. (Naudok π ≈ 3).“. Skaitydamas tokį sakinį pirmiausia pabrauk duotus duomenis, tada atskirai pasižymėk, ko prašoma. Jeigu uždavinys turi kelis sakinius, paskutinis sakinys dažnai nusako tikslą, o ankstesni sakiniai pateikia sąlygas, kurias reikia paversti lygtimi, brėžiniu, lentele arba atvejų sistema."
        },
        {
          "type": "note",
          "text": "Vienas iš geriausių būdų mokytis yra po išspręsto pavyzdžio pakeisti vieną skaičių, vieną sąlygą arba klausimą ir pabandyti išspręsti dar kartą. Jei metodas sugriūva nuo mažo pakeitimo, vadinasi, buvo įsiminta forma, bet dar ne suprastas ryšys."
        }
      ]
    },
    {
      "id": "apskritimas-ir-skritulys-gilinimas-klaidos",
      "title": "Savikontrolė, klaidos ir pasiruošimas pratimams",
      "blocks": [
        {
          "type": "warning",
          "text": "Atsakymą tikrink pagal kraštinius atvejus: ar ilgiai teigiami, ar kampų suma atitinka figūrą, ar gautas santykis nepasikeistų perbraižius brėžinį kitu masteliu. Dažna klaida šioje temoje yra praleisti paskutinį patikrinimą, nes tarpiniai veiksmai atrodo logiški. Vis dėlto net teisingas pertvarkymas gali duoti netinkamą atsakymą, jei nepaisyta sąlygos apribojimų arba supainiota, ką reiškia gautas dydis."
        },
        {
          "type": "paragraph",
          "text": "Prieš pereidamas prie sunkių uždavinių, mokinys turėtų gebėti atlikti tris veiksmus: savais žodžiais paaiškinti temą „Apskritimas ir skritulys“, išspręsti paprastą tiesioginį uždavinį be užuominų ir ištaisyti bent vieną sąmoningai padarytą klaidą. Tik tada verta didinti uždavinių įvairovę, nes įvairovė be pagrindo dažnai sukuria triukšmą, o ne meistriškumą."
        }
      ]
    }
  ],
