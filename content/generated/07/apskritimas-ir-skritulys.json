  "theory": [
    {
      "id": "apskritimas-ir-skritulys-pagrindai",
      "title": "Apskritimas ir skritulys: pagrindinės sąvokos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[apskritimas|Apskritimas]] – tai visų plokštumos taškų, nutolusių nuo vieno taško (centro) tuo pačiu atstumu, aibė. Šis atstumas vadinamas [[spindulys|spinduliu]] (r)."
        },
        {
          "type": "paragraph",
          "text": "[[skritulys|Skritulys]] – tai plokštumos dalis, kurią riboja apskritimas. Skritulys apima ir patį apskritimą, ir visus jo viduje esančius taškus."
        },
        {
          "type": "definition",
          "conceptId": "skersmuo",
          "text": "[[skersmuo|Skersmuo]] (d) yra atkarpa, jungianti du apskritimo taškus ir einanti per jo centrą. Skersmuo yra dvigubai ilgesnis už spindulį: d = 2r."
        }
      ]
    },
    {
      "id": "pi-skaicius-ir-ilgis",
      "title": "Skaičius Pi ir apskritimo ilgis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Visų apskritimų ilgio ir jų skersmens santykis yra pastovus skaičius, žymimas graikiška raide [[pi-skaicius|π (pi)]]."
        },
        {
          "type": "formula",
          "formulaId": "apskritimo-ilgio-formule",
          "latex": "C = 2\\pi r \\quad \\text{arba} \\quad C = \\pi d"
        },
        {
          "type": "note",
          "text": "Skaičius π yra iracionalusis, jo apytikslė reikšmė yra 3,14."
        }
      ]
    },
    {
      "id": "skritulio-plotas",
      "title": "Skritulio plotas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[skritulio-plotas|Skritulio plotas]] parodo, kokį paviršiaus dydį užima figūra. Jis apskaičiuojamas pagal formulę:"
        },
        {
          "type": "formula",
          "formulaId": "skritulio-ploto-formule",
          "latex": "S = \\pi r^2"
        },
        {
          "type": "warning",
          "text": "Nepamirškite, kad keliamas kvadratu tik spindulys, o ne visa sandauga πr."
        }
      ]
    },
    {
      "id": "lankas-ir-ispjova",
      "title": "Apskritimo lankas ir skritulio išpjova",
      "blocks": [
        {
          "type": "paragraph",
          "text": "[[lankas|Lankas]] yra apskritimo dalis tarp dviejų jo taškų. [[ispjova|Išpjova]] yra skritulio dalis, apribota dviem spinduliais ir lanku."
        },
        {
          "type": "paragraph",
          "text": "Jei lanką atitinkantis centrinis kampas yra α laipsnių, tai lanko ilgį l ir išpjovos plotą S_ispj apskaičiuojame taip:"
        },
        {
          "type": "formula",
          "formulaId": "lanko-ilgio-formule",
          "latex": "l = \\frac{2\\pi r \\alpha}{360} = \\frac{\\pi r \\alpha}{180}"
        },
        {
          "type": "formula",
          "formulaId": "ispjovos-ploto-formule",
          "latex": "S_{\\text{išpj}} = \\frac{\\pi r^2 \\alpha}{360}"
        }
      ]
    }
  ],
