  "theory": [
    {
      "id": "statistika-kasdienybeje",
      "title": "Statistika: kaip nepasiklysti duomenų jūroje?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kiekvieną dieną girdime teiginius: „8 iš 10 odontologų rekomenduoja šią pastą“ arba „Dauguma moksleivių laisvalaikį leidžia prie kompiuterio“. Bet kaip mokslininkai tai sužino? Ar jie apklausia visus pasaulio odontologus ir visus moksleivius? Žinoma, ne. Čia į pagalbą ateina statistika – mokslas apie duomenų rinkimą, sisteminimą ir analizę."
        },
        {
          "type": "note",
          "text": "Statistika padeda daryti pagrįstas išvadas apie dideles grupes, ištiriant tik mažą jų dalį."
        }
      ]
    },
    {
      "id": "visuma-ir-imtis",
      "title": "Generalinė visuma ir imtis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Norėdami ištirti kokį nors reiškinį, pirmiausia turime apibrėžti objektų grupę, kuri mus domina."
        },
        {
          "type": "definition",
          "conceptId": "generaline-visuma",
          "text": "[[generaline-visuma|Generalinė visuma]] – tai visa tiriamų objektų ar reiškinių aibė (pvz., visi Lietuvos 7-okai)."
        },
        {
          "type": "definition",
          "conceptId": "imtis",
          "text": "[[imtis|Imtis]] – tai dalis objektų, paimtų iš generalinės visumos tyrimui."
        },
        {
          "type": "paragraph",
          "text": "Kad išvados būtų teisingos, imtis turi būti **reprezentatyvi**. Tai reiškia, kad ji turi tiksliai atspindėti visos grupės savybes. Geriausias būdas tai pasiekti – **atsitiktinė atranka**, kai kiekvienas grupės narys turi vienodą galimybę patekti į tyrimą."
        },
        {
          "type": "warning",
          "text": "Jei norite sužinoti visos mokyklos nuomonę apie maistą, bet apklausite tik savo geriausius draugus – jūsų imtis nebus reprezentatyvi!"
        }
      ]
    },
    {
      "id": "duomenu-sisteminimas",
      "title": "Duomenų sisteminimas ir dažniai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Surinkti žali duomenys dažniausiai yra netvarkingas skaičių ar atsakymų sąrašas. Juos reikia sutvarkyti į dažnių lenteles."
        },
        {
          "type": "definition",
          "conceptId": "daznis",
          "text": "[[daznis|Dažnis]] – skaičius, rodantis, kiek kartų konkreti reikšmė pasikartojo duomenų rinkinyje."
        },
        {
          "type": "formula",
          "formulaId": "santykinio-daznio-formule",
          "latex": "f_{sant} = \\frac{f}{n}"
        },
        {
          "type": "paragraph",
          "text": "[[santykinis-daznis|Santykinis dažnis]] parodo, kokią visų duomenų dalį sudaro konkretus atsakymas. Jis dažniausiai išreiškiamas trupmena arba procentais."
        }
      ]
    },
    {
      "id": "duomenu-charakteristikos",
      "title": "Pagrindinės duomenų charakteristikos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Duomenų rinkinį galime apibūdinti trimis pagrindiniais skaičiais:"
        },
        {
          "type": "method",
          "text": "1. [[vidurkis|Vidurkis]]: visų reikšmių suma padalinta iš jų skaičiaus.\n2. [[mediana|Mediana]]: vidurinė reikšmė surikiuotoje (nuo mažiausios iki didžiausios) duomenų eilėje.\n3. [[moda|Moda]]: dažniausiai pasikartojanti reikšmė."
        },
        {
          "type": "note",
          "text": "Jei duomenų kiekis porinis, mediana yra dviejų vidurinių reikšmių aritmetinis vidurkis."
        }
      ]
    },
    {
      "id": "vizualizacija-stulpelines-diagramos",
      "title": "Stulpelinės diagramos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Stulpelinė diagrama geriausiai tinka lyginti skirtingų kategorijų dydžius (pvz., kiek mokinių lanko krepšinį, o kiek futbolą)."
        },
        {
          "type": "method",
          "text": "Braižant stulpelinę diagramą:\n- Horizantalioje ašyje žymimos kategorijos.\n- Vertikalioje ašyje žymimas dažnis arba procentinė dalis.\n- Stulpelių plotis turi būti vienodas, o tarpai tarp jų – taip pat vienodi."
        }
      ]
    },
    {
      "id": "vizualizacija-skritulines-diagramos",
      "title": "Skritulinės diagramos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Skritulinė diagrama parodo, kaip visuma dalijama į dalis (proporcijas). Visas skritulys atitinka $100\\%$ arba $360^\\circ$."
        },
        {
          "type": "formula",
          "formulaId": "skritulines-diagramos-kampo-formule",
          "latex": "\\alpha = \\frac{f}{n} \\cdot 360^\\circ"
        },
        {
          "type": "paragraph",
          "text": "Čia $\\alpha$ – skritulio išpjovos kampas laipsniais, $f$ – konkrečios reikšmės dažnis, $n$ – bendras duomenų kiekis."
        }
      ]
    },
    {
      "id": "duomenu-patikimumas",
      "title": "Ar duomenys nemeluoja?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Svarbu kritiškai vertinti statistiką. Kartais diagramos braižomos taip, kad sudarytų klaidingą įspūdį (pvz., vertikali ašis pradedama ne nuo nulio, todėl maži skirtumai atrodo didžiuliai)."
        },
        {
          "type": "warning",
          "text": "Visada patikrinkite ašių mastelį ir imties dydį prieš darydami išvadas."
        }
      ]
    },
    {
      "id": "sprendimo-strategija-statistika",
      "title": "Kaip analizuoti duomenis?",
      "blocks": [
        {
          "type": "method",
          "text": "1. **Surikiuokite**: Pirmas žingsnis visada turėtų būti duomenų surikiavimas didėjimo tvarka.\n2. **Suskaičiuokite**: Raskite bendrą kiekį $n$ ir dažnius.\n3. **Pasirinkite įrankį**: Jei reikia lyginti kiekius – braižykite stulpelius, jei reikia rodyti dalis nuo visumos – skritulį."
        }
      ]
    }
  ],
