      "conceptIds": [
        "vidurkis"
      ],
      "steps": [
        {
          "text": "Randame pirmų keturių skaičių sumą.",
          "latex": "S_4 = 4 \\cdot 7 = 28"
        },
        {
          "text": "Pridedame penktą skaičių.",
          "latex": "S_5 = 28 + 12 = 40"
        },
        {
          "text": "Skaičiuojame naują vidurkį.",
          "latex": "\\bar{x}_5 = 40 / 5 = 8"
        }
      ],
      "answer": "8"
    },
