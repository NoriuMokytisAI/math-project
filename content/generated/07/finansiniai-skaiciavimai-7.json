  "workedExamples": [
    {
      "id": "fin-exmp-1",
      "title": "Paprastųjų palūkanų skaičiavimas",
      "level": "easy",
      "problem": "Vilius į banką padėjo $500$ Eur indėlį. Metinė palūkanų norma yra $4\\%$. Kiek palūkanų jis uždirbs po $1$ metų?",
      "conceptIds": [
        "palukanos",
        "palukanu-norma"
      ],
      "formulaIds": [
        "paprastuju-palukanu-formule"
      ],
      "steps": [
        {
          "text": "Nustatome kintamuosius: $P = 500$, $i = 0,04$, $t = 1$.",
          "latex": "I = 500 \\cdot 0,04 \\cdot 1"
        },
        {
          "text": "Apskaičiuojame.",
          "latex": "I = 20 \\text{ Eur}"
        }
      ],
      "answer": "20 Eur"
    },
    {
      "id": "fin-exmp-2",
      "title": "Galutinė suma po kelerių metų",
      "level": "easy",
      "problem": "Marija pasiskolino $2000$ Eur iš banko su $10\\%$ metinėmis paprastosiomis palūkanomis. Kiek iš viso pinigų ji turės grąžinti bankui po $3$ metų?",
      "conceptIds": [
        "palukanos",
        "paskola"
      ],
      "steps": [
        {
          "text": "Apskaičiuojame uždirbtas palūkanas.",
          "latex": "I = 2000 \\cdot 0,10 \\cdot 3 = 600 \\text{ Eur}"
        },
        {
          "text": "Pridedame palūkanas prie pradinės sumos.",
          "latex": "S = 2000 + 600 = 2600 \\text{ Eur}"
        }
      ],
      "answer": "2600 Eur"
    },
    {
      "id": "fin-exmp-3",
      "title": "Palūkanos už kelis mėnesius",
      "level": "medium",
      "problem": "Indėlis yra $1200$ Eur, metinė palūkanų norma $6\\%$. Kiek palūkanų bus sukaupta per $4$ mėnesius?",
      "conceptIds": [
        "palukanos"
      ],
      "steps": [
        {
          "text": "Paverčiame mėnesius metais.",
          "latex": "t = 4/12 = 1/3 \\text{ metų}"
        },
        {
          "text": "Skaičiuojame palūkanas.",
          "latex": "I = 1200 \\cdot 0,06 \\cdot \\frac{1}{3} = 1200 \\cdot 0,02 = 24 \\text{ Eur}"
        }
      ],
      "answer": "24 Eur"
    },
    {
      "id": "fin-exmp-4",
      "title": "Biudžeto planavimas",
      "level": "easy",
      "problem": "Simo pajamos per mėnesį yra $40$ Eur. Jis išleidžia $12$ Eur pramogoms ir $15$ Eur skanėstams. Kiek procentų savo pajamų jis sutaupo?",
      "conceptIds": [
        "biudzetas",
        "santaupos"
      ],
      "steps": [
        {
          "text": "Randame bendras išlaidas.",
          "latex": "12 + 15 = 27 \\text{ Eur}"
        },
        {
          "text": "Randame sutaupytą sumą.",
          "latex": "40 - 27 = 13 \\text{ Eur}"
        },
        {
          "text": "Apskaičiuojame procentinę dalį.",
          "latex": "\\frac{13}{40} \\cdot 100\\% = 32,5\\%"
        }
      ],
      "answer": "32,5%"
    },
    {
      "id": "fin-exmp-5",
      "title": "Pradinės sumos radimas",
      "level": "hard",
      "problem": "Po metų bankas klientui išmokėjo $15$ Eur palūkanų. Žinoma, kad metinė norma buvo $2,5\\%$. Kokio dydžio indėlį buvo padėjęs klientas?",
      "conceptIds": [
        "palukanos",
        "indelis"
      ],
      "steps": [
        {
          "text": "Naudojame formulę $I = P \\cdot i \\cdot t$ ir išreiškiame $P$.",
          "latex": "15 = P \\cdot 0,025 \\cdot 1"
        },
        {
          "text": "Padaliname iš koeficiento.",
          "latex": "P = \\frac{15}{0,025} = 600 \\text{ Eur}"
        }
      ],
      "answer": "600 Eur"
    },
    {
      "id": "fin-exmp-6",
      "title": "Palūkanų normos nustatymas",
      "level": "hard",
      "problem": "Klientas pasiskolino $1000$ Eur, o po $2$ metų grąžino $1160$ Eur. Kokia buvo metinė paprastųjų palūkanų norma?",
      "conceptIds": [
        "palukanu-norma"
      ],
      "steps": [
        {
          "text": "Randame sumokėtas palūkanas.",
          "latex": "I = 1160 - 1000 = 160 \\text{ Eur}"
        },
        {
          "text": "Įstatome į formulę $160 = 1000 \\cdot i \\cdot 2$.",
          "latex": "160 = 2000 \\cdot i"
        },
        {
          "text": "Randame $i$.",
          "latex": "i = \\frac{160}{2000} = 0,08"
        },
        {
          "text": "Paverčiame procentais.",
          "latex": "0,08 = 8\\%"
        }
      ],
      "answer": "8%"
    },
    {
      "id": "fin-exmp-7",
      "title": "Pirkimo išsimokėtinai palyginimas",
      "level": "hard",
      "problem": "Telefonas kainuoja $600$ Eur. Galima pirkti iškart arba išsimokėtinai: pradinė įmoka $100$ Eur ir $12$ mėnesių po $45$ Eur. Kiek procentų pabrangsta telefonas perkant išsimokėtinai?",
      "conceptIds": [
        "paskola"
      ],
      "steps": [
        {
          "text": "Apskaičiuojame bendrą kainą perkant išsimokėtinai.",
          "latex": "100 + 12 \\cdot 45 = 100 + 540 = 640 \\text{ Eur}"
        },
        {
          "text": "Randame pabrangimą eurais.",
          "latex": "640 - 600 = 40 \\text{ Eur}"
        },
        {
          "text": "Apskaičiuojame pabrangimą procentais nuo pradinės kainos.",
          "latex": "\\frac{40}{600} \\cdot 100\\% \\approx 6,67\\%"
        }
      ],
      "answer": "6,67%"
    },
    {
      "id": "fin-exmp-8",
      "title": "Tikslas ir taupymas",
      "level": "medium",
      "problem": "Eglė nori sutaupyti $480$ Eur kompiuteriui per $2$ metus. Kiek vidutiniškai ji turi atidėti kas mėnesį į taupyklę?",
      "conceptIds": [
        "biudzetas",
        "santaupos"
      ],
      "steps": [
        {
          "text": "Randame bendrą mėnesių skaičių.",
          "latex": "2 \\cdot 12 = 24 \\text{ mėn.}"
        },
        {
          "text": "Padaliname sumą iš mėnesių skaičiaus.",
          "latex": "480 / 24 = 20 \\text{ Eur/mėn.}"
        }
      ],
      "answer": "20 Eur"
    }
  ],
