  "theory": [
    {
      "id": "finansinis-rastingumas-ivadas",
      "title": "Kodėl svarbu mokėti skaičiuoti pinigus?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Finansinis raštingumas nėra tik gebėjimas suskaičiuoti grąžą parduotuvėje. Tai menas valdyti savo išteklius taip, kad pasiektumėte savo tikslus – nesvarbu, ar tai būtų naujas dviratis, studijos universitete, ar kelionė aplink pasaulį. 7-oje klasėje mes žengiame žingsnį toliau nuo paprastų nuolaidų skaičiavimo ir pradedame nagrinėti, kaip pinigai „dirba“ laike."
        },
        {
          "type": "note",
          "text": "Pinigai turi laiko vertę: euras šiandien yra vertas daugiau nei euras po metų, nes šiandien turimą eurą galite investuoti ir uždirbti palūkanų."
        }
      ]
    },
    {
      "id": "asmeninis-biudzetas",
      "title": "Asmeninis biudžetas: pajamos ir išlaidos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Kiekvieno finansinio plano pagrindas yra biudžetas. Tai paprastas sąrašas, kuriame matome, iš kur pinigai ateina ir kur jie išeina."
        },
        {
          "type": "definition",
          "conceptId": "biudzetas",
          "text": "[[biudzetas|Biudžetas]] – tai pajamų ir išlaidų planas tam tikram laikotarpiui (pavyzdžiui, mėnesiui ar metams)."
        },
        {
          "type": "paragraph",
          "text": "[[pajamos|Pajamos]] gali būti kišenpinigiai, uždarbis už smulkius darbus ar dovanos. [[islaidos|Išlaidos]] skirstomos į būtinasias (maistas, transportas) ir nebūtinasias (laisvalaikis, skanėstai)."
        },
        {
          "type": "method",
          "text": "Subalansuoto biudžeto taisyklė: Pajamos - Išlaidos = Santaupos. Jei šis skaičius teigiamas, jūs sėkmingai taupote. Jei neigiamas – išleidžiate daugiau nei uždirbate."
        }
      ]
    },
    {
      "id": "palukanu-samprata",
      "title": "Kas yra palūkanos?",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Įsivaizduokite, kad palūkanos yra „nuoma“, kurią mokate už pasiskolintus pinigus, arba „atlygis“, kurį gaunate už tai, kad leidžiate bankui naudotis jūsų santaupomis."
        },
        {
          "type": "definition",
          "conceptId": "palukanos",
          "text": "[[palukanos|Palūkanos]] – tai mokestis už naudojimąsi svetimais pinigais, paprastai skaičiuojamas procentais nuo pradinės sumos."
        },
        {
          "type": "paragraph",
          "text": "[[palukanu-norma|Palūkanų norma]] nurodo, kiek procentų nuo sumos reikės sumokėti ar bus uždirbta per metus."
        }
      ]
    },
    {
      "id": "paprastosios-palukanos",
      "title": "Paprastosios palūkanos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "7-oje klasėje mokomės skaičiuoti paprastąsias palūkanas. Jos vadinamos paprastosiomis, nes skaičiuojamos tik nuo pradinės padėtos ar pasiskolintos sumos."
        },
        {
          "type": "formula",
          "formulaId": "paprastuju-palukanu-formule",
          "latex": "I = P \\cdot i \\cdot t"
        },
        {
          "type": "paragraph",
          "text": "Čia:\n- $I$ – sukauptos palūkanos (eurais),\n- $P$ – pradinė suma (indėlis ar paskola),\n- $i$ – metinė palūkanų norma (paversta dešimtaine trupmena, pavyzdžiui, $5\\% = 0,05$),\n- $t$ – laikas metais."
        },
        {
          "type": "warning",
          "text": "Svarbu: jei laikas duotas mėnesiais, jį būtina paversti metais dalinant iš 12. Pavyzdžiui, 3 mėnesiai yra $3/12 = 0,25$ metų."
        }
      ]
    },
    {
      "id": "galutine-suma",
      "title": "Galutinė sukaupta suma",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Dažnai mums rūpi ne tik uždirbtos palūkanos, bet ir tai, kiek pinigų iš viso turėsime laikotarpio pabaigoje."
        },
        {
          "type": "formula",
          "formulaId": "galutines-sumos-formule",
          "latex": "S = P + I = P(1 + i \\cdot t)"
        },
        {
          "type": "paragraph",
          "text": "Ši formulė leidžia vienu žingsniu apskaičiuoti bendrą sumą $S$, kurią atsiimsite iš banko po $t$ metų."
        }
      ]
    },
    {
      "id": "banko-paslaugos-indelis-paskola",
      "title": "Indėliai ir paskolos: praktinis skirtumas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Bankas veikia kaip tarpininkas. Žmonės, turintys atliekamų pinigų, padeda juos kaip indėlius ir gauna nedideles palūkanas. Žmonės, kuriems reikia pinigų pirkiniams (pavyzdžiui, būstui ar automobiliui), skolinasi iš banko ir moka didesnes palūkanas."
        },
        {
          "type": "definition",
          "conceptId": "indelis",
          "text": "[[indelis|Indėlis]] – į banką padėti pinigai saugojimui ir palūkanoms uždirbti."
        },
        {
          "type": "definition",
          "conceptId": "paskola",
          "text": "[[paskola|Paskola]] – iš banko pasiskolinti pinigai, kuriuos reikės grąžinti su palūkanomis."
        },
        {
          "type": "method",
          "text": "Palygindami bankų pasiūlymus, visada žiūrėkite ne tik į palūkanų normą, bet ir į papildomus mokesčius (sutarties sudarymo, sąskaitos tvarkymo)."
        }
      ]
    },
    {
      "id": "infliacija-ir-pirkamoji-galia",
      "title": "Trumpai apie infliaciją",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Galbūt girdėjote tėvus skundžiantis, kad „anksčiau už 10 eurų galėjai nusipirkti pilną krepšį“. Tai infliacijos pasekmė. Infliacija – tai bendras kainų lygio kilimas, dėl kurio už tą patį pinigų kiekį galime nusipirkti vis mažiau."
        },
        {
          "type": "note",
          "text": "Kad jūsų santaupos nenuvertėtų, jų palūkanų norma turėtų būti didesnė už infliacijos lygį."
        }
      ]
    },
    {
      "id": "finansinio-skaiciavimo-strategija",
      "title": "Kaip spręsti finansinius uždavinius?",
      "blocks": [
        {
          "type": "method",
          "text": "1. **Identifikuokite kintamuosius**: Kas yra $P$, $i$ ir $t$?\n2. **Suvienodinkite vienetus**: Ar palūkanos ir laikas yra „metiniai“?\n3. **Paverskite procentus trupmena**: Visada naudokite $0,05$, o ne $5$ skaičiavimuose.\n4. **Įvertinkite logiškumą**: Ar palūkanos negavo didesnės už pradinę sumą per vieną mėnesį? Jei taip – patikrinkite kablelius."
        }
      ]
    }
  ],
