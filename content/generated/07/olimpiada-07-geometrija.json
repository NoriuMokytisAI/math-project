  "workedExamples": [
    {
      "id": "we-olimpiada-07-geo-01",
      "title": "Kampų radimas lygiašoniame trikampyje",
      "level": "easy",
      "problem": "Lygiašonio trikampio viršūnės kampas lygus $40^\\circ$. Raskite kampus prie pagrindo.",
      "conceptIds": [
        "olimpiada-07-concept-triangle-sum"
      ],
      "steps": [
        {
          "text": "Visų kampų suma lygi $180^\\circ$."
        },
        {
          "text": "Kampų prie pagrindo suma: $180 - 40 = 140$."
        },
        {
          "text": "Kadangi kampai prie pagrindo lygūs: $140 / 2 = 70$."
        }
      ],
      "answer": "70"
    },
    {
      "id": "we-olimpiada-07-geo-02",
      "title": "Trikampio priekampio taikymas",
      "level": "medium",
      "problem": "Trikampio du vidiniai kampai lygūs $30^\\circ$ ir $80^\\circ$. Raskite priekampį prie trečiosios viršūnės.",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Priekampis lygus jam neprišlietų vidinių kampų sumai."
        },
        {
          "text": "$30 + 80 = 110$."
        }
      ],
      "answer": "110"
    },
    {
      "id": "we-olimpiada-07-geo-03",
      "title": "Pitagoro teorema koordinačių plokštumoje",
      "level": "medium",
      "problem": "Raskite atstumą tarp taškų (0,0) ir (6,8).",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Naudokite atstumo formulę: $\\sqrt{(6-0)^2 + (8-0)^2}$."
        },
        {
          "text": "$\\sqrt{36 + 64} = \\sqrt{100} = 10$."
        }
      ],
      "answer": "10"
    },
    {
      "id": "we-olimpiada-07-geo-04",
      "title": "Daugiakampio kampų suma",
      "level": "medium",
      "problem": "Kokia yra šešiakampio vidinių kampų suma?",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Formulė: $(n-2) \\cdot 180$."
        },
        {
          "text": "$(6-2) \\cdot 180 = 4 \\cdot 180 = 720$."
        }
      ],
      "answer": "720"
    },
    {
      "id": "we-olimpiada-07-geo-05",
      "title": "Apskritimo kampai",
      "level": "medium",
      "problem": "Centrinis kampas lygus $100^\\circ$. Raskite įbrėžtinį kampą, besiremiantį į tą patį lanką.",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Įbrėžtinis kampas yra pusė centrinio kampo."
        },
        {
          "text": "$100 / 2 = 50$."
        }
      ],
      "answer": "50"
    }
  ],
