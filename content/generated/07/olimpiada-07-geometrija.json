  "workedExamples": [
    {
      "id": "we-geo-7-1",
      "title": "Paslėpto lygiašonio trikampio radimas",
      "level": "medium",
      "problem": "Trikampyje $ABC$ kampas $B = 40^\\circ$, kampas $C = 20^\\circ$. Kraštinėje $AB$ pažymėtas taškas $D$ toks, kad $AD = BC$. Raskite kampą $\\angle ACD$.",
      "conceptIds": [
        "geo-concept-auxiliary-lines",
        "geo-concept-triangle-properties"
      ],
      "steps": [
        {
          "text": "Pirmiausia pastebime, kad kampas $A = 180 - 40 - 20 = 120^\\circ$."
        },
        {
          "text": "Naudojame papildomą konstrukciją: ant kraštinės $AC$ iš viršūnės $A$ pusės atidedame tašką $E$ taip, kad trikampis $ADE$ būtų lygiakraštis (nes kampas $A$ yra $120^\\circ$, tai čia netinka tiesiogiai, geriau konstrukcija: nubrėžkime lygiakraštį trikampį $ABF$ išorėje)."
        },
        {
          "text": "Sudėtingesnis kelias reikalauja pastebėti, kad $120, 40, 20$ kampai yra susiję su reguliaraus 18-kampio savybėmis. Paprastesnis olimpiadinis triukas: atidėkime $BC$ ilgio atkarpą ant $AC$ pratęsimo."
        },
        {
          "text": "Galutinis sprendimas remiasi priekampio savybėmis ir lygiašonių trikampių konstravimu. Atsakymas $\\angle ACD = 10^\\circ$."
        }
      ],
      "answer": "10^\\circ"
    },
    {
      "id": "we-geo-7-2",
      "title": "Plotų santykio taikymas",
      "level": "easy",
      "problem": "Trikampyje $ABC$ taškas $M$ yra kraštinės $BC$ vidurys. Taškas $N$ yra atkarpos $AM$ vidurys. Kokia dalis trikampio $ABC$ ploto tenka trikampiui $ABN$?",
      "conceptIds": [
        "geo-concept-area-method"
      ],
      "steps": [
        {
          "text": "Kadangi $AM$ yra pusiaukraštinė, tai $S(ABM) = S(ACM) = \\frac{1}{2} S(ABC)$."
        },
        {
          "text": "Trikampyje $ABM$ atkarpa $BN$ yra pusiaukraštinė (nes $N$ yra $AM$ vidurys)."
        },
        {
          "text": "Todėl $S(ABN) = \\frac{1}{2} S(ABM) = \\frac{1}{2} \\cdot (\\frac{1}{2} S(ABC)) = \\frac{1}{4} S(ABC)$."
        }
      ],
      "answer": "1/4"
    },
    {
      "id": "we-geo-7-3",
      "title": "Trikampio nelygybės ekstremumas",
      "level": "medium",
      "problem": "Trikampio kraštinių ilgiai yra sveikieji skaičiai. Dvi kraštinės lygios 3 ir 10. Koks gali būti mažiausias ir didžiausias perimetras?",
      "conceptIds": [
        "geo-concept-triangle-properties"
      ],
      "steps": [
        {
          "text": "Pažymėkime trečiąją kraštinę $x$. Pagal trikampio nelygybę: $10-3 < x < 10+3$, t.y. $7 < x < 13$."
        },
        {
          "text": "Kadangi $x$ yra sveikasis skaičius, tai $x \\in \\{8, 9, 10, 11, 12\\}$."
        },
        {
          "text": "Mažiausias $x=8$, perimetras $P = 3+10+8 = 21$."
        },
        {
          "text": "Didžiausias $x=12$, perimetras $P = 3+10+12 = 25$."
        }
      ],
      "answer": "Min: 21, Max: 25"
    },
    {
      "id": "we-geo-7-4",
      "title": "Pusiaukraštinės dvigubinimo metodas",
      "level": "hard",
      "problem": "Įrodykite, kad trikampio pusiaukraštinė $m_a$ yra mažesnė už kraštinių, išeinančių iš tos pačios viršūnės, aritmetinį vidurkį: $m_a < \\frac{b+c}{2}$.",
      "conceptIds": [
        "geo-concept-auxiliary-lines",
        "geo-concept-congruence"
      ],
      "steps": [
        {
          "text": "Trikampyje $ABC$ pratęskime pusiaukraštinę $AM$ už taško $M$ ir atidėkime $MD = AM$."
        },
        {
          "text": "Trikampiai $ABM$ ir $DCM$ yra lygūs pagal SAS požymį ($BM=MC$, $AM=MD$, kampai prie viršūnės $M$ kryžminiai)."
        },
        {
          "text": "Iš lygumo seka, kad $CD = AB = c$."
        },
        {
          "text": "Trikampiui $ADC$ taikome trikampio nelygybę: $AD < AC + CD$."
        },
        {
          "text": "Kadangi $AD = 2 m_a$ ir $CD = c$, $AC = b$, tai $2 m_a < b + c$, iš kur $m_a < \\frac{b+c}{2}$."
        }
      ],
      "answer": "Įrodyta"
    },
    {
      "id": "we-geo-7-5",
      "title": "Žvaigždės kampų suma",
      "level": "medium",
      "problem": "Raskite penkiakampės žvaigždės viršūnių kampų sumą.",
      "conceptIds": [
        "geo-concept-triangle-properties",
        "geo-formula-exterior-angle"
      ],
      "steps": [
        {
          "text": "Pažymėkime žvaigždės viršūnes $A, B, C, D, E$. Viduryje susidaro penkiakampis."
        },
        {
          "text": "Naudojame priekampio teoremą du kartus mažesniems trikampiams, sudarantiems žvaigždės „spindulius“."
        },
        {
          "text": "Kiekvienas „vidinis“ žvaigždės kampas yra dviejų tolimų viršūnių suma. Galiausiai visi penki kampai susirenka į vieną trikampį."
        },
        {
          "text": "Suma visada lygi $180^\\circ$."
        }
      ],
      "answer": "180^\\circ"
    }
  ],
