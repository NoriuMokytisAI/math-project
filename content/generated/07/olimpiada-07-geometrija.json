  "theory": [
    {
      "id": "olimpiada-07-geo-theory-1",
      "title": "Trikampio nelygybė",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Trikampį galima sudaryti tik tada, kai bet kurių dviejų kraštinių suma yra didesnė už trečiąją kraštinę."
        },
        {
          "type": "theorem",
          "text": "Jei kraštinės yra a, b ir c, tai: $a+b > c$, $a+c > b$, $b+c > a$."
        }
      ]
    }
  ],
