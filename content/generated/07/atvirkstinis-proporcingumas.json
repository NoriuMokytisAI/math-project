  "theory": [
    {
      "id": "atvirkstinis-proporcingumas-ivadas",
      "title": "Įvadas",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Atvirkštinis proporcingumas ir jo grafikas yra tema, kurioje mokomasi atpažinti pagrindinius atvirkštinis proporcingumas modelius ir juos taikyti skaičiavimuose, tekste bei brėžiniuose."
        },
        {
          "type": "paragraph",
          "text": "Šioje temoje svarbiausia nuolat matyti ryšį tarp sąvokų [[funkcija|Funkcija]], [[argumentas|Argumentas]], [[apibrezimo-sritis|Apibrėžimo sritis]] ir uždavinių sprendimo."
        }
      ]
    },
    {
      "id": "atvirkstinis-proporcingumas-svarbiausios-savokos",
      "title": "Svarbiausios sąvokos",
      "blocks": [
        {
          "type": "definition",
          "conceptId": "funkcija",
          "text": "Taisyklė, kuri kiekvienam argumentui priskiria vieną reikšmę."
        },
        {
          "type": "definition",
          "conceptId": "argumentas",
          "text": "Nepriklausomas kintamasis."
        },
        {
          "type": "definition",
          "conceptId": "apibrezimo-sritis",
          "text": "Visų leistinų argumentų aibė."
        },
        {
          "type": "note",
          "text": "Jei sprendžiant kyla abejonė, pirmiausia tikrink, ar aiškiai supranti [[funkcija|Funkcija]] ir [[reiksmiu-sritis|Reikšmių sritis]]."
        }
      ]
    },
    {
      "id": "atvirkstinis-proporcingumas-taisyklės",
      "title": "Svarbiausios taisyklės",
      "blocks": [
        {
          "type": "theorem",
          "text": "Atvirkštinis proporcingumas ir jo grafikas sprendimuose visada pirmiausia atskirk duomenis nuo ieškomo dydžio, o tada pasirink tinkamą modelį."
        },
        {
          "type": "property",
          "text": "Jei užduotyje pasirodo [[apibrezimo-sritis|Apibrėžimo sritis]] ar [[reiksmiu-sritis|Reikšmių sritis]], dažnai verta rašyti ryšį simboliais prieš skaičiuojant."
        },
        {
          "type": "formula",
          "formulaId": "funkcijos-zymejimas",
          "latex": "y=f(x)"
        }
      ]
    },
    {
      "id": "atvirkstinis-proporcingumas-strategija",
      "title": "Sprendimo strategija",
      "blocks": [
        {
          "type": "method",
          "text": "1. Perskaityk užduotį ir pažymėk, kokie dydžiai žinomi. 2. Nustatyk, kuri sąvoka čia svarbiausia. 3. Užrašyk veiksmus arba ryšį. 4. Patikrink rezultatą kitaip arba atgaliniu skaičiavimu."
        },
        {
          "type": "warning",
          "text": "Dažna klaida yra imti skaičiuoti per anksti ir neįvardyti, ką reiškia gauta reikšmė."
        }
      ]
    },
    {
      "id": "atvirkstinis-proporcingumas-rysys",
      "title": "Ryšys su kitomis temomis",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Ši tema remiasi ankstesnėmis žiniomis iš kitų metų: skaičiavimu, reiškinių pertvarkymu, figūrų savybėmis ar duomenų skaitymu. Ji ruošia kelią tolimesnėms temoms, kuriose reikia daugiau bendro modelio ir tikslesnio argumentavimo."
        }
      ]
    }
  ],
