    {
      "id": "atvirkstinis-proporcingumas-exmp-3",
      "title": "Apibrėžimo sritis",
      "level": "medium",
      "problem": "Kokia yra f(x)=1/(x-2) apibrėžimo sritis?",
      "conceptIds": [
        "apibrezimo-sritis"
      ],
      "formulaIds": [],
      "steps": [
        {
          "text": "Vardiklis negali būti 0.",
          "latex": "x-2\\neq 0"
