  "workedExamples": [
    {
      "id": "atv-exmp-1",
      "title": "Koeficiento k radimas",
      "level": "easy",
      "problem": "Atvirkštinio proporcingumo grafikas eina per tašką $A(3; 4)$. Raskite proporcingumo koeficientą $k$ ir užrašykite funkcijos formulę.",
      "conceptIds": [
        "proporcingumo-koeficientas",
        "atvirkstinis-proporcingumas"
      ],
      "formulaIds": [
        "atvirkstinio-proporcingumo-formule"
      ],
      "steps": [
        {
          "text": "Naudojame savybę $k = x \\cdot y$.",
          "latex": "k = 3 \\cdot 4 = 12"
        },
        {
          "text": "Įrašome gautą $k$ į bendrąją formulę.",
          "latex": "y = \\frac{12}{x}"
        }
      ],
      "answer": "$y = 12/x$"
    },
    {
      "id": "atv-exmp-2",
      "title": "Reikšmės apskaičiavimas",
      "level": "easy",
      "problem": "Duota funkcija $y = \\frac{10}{x}$. Apskaičiuokite $y$ reikšmę, kai $x = 5$ ir kai $x = -2$.",
      "conceptIds": [
        "atvirkstinis-proporcingumas"
      ],
      "steps": [
        {
          "text": "Įstatome $x = 5$.",
          "latex": "y = \\frac{10}{5} = 2"
        },
        {
          "text": "Įstatome $x = -2$.",
          "latex": "y = \\frac{10}{-2} = -5"
        }
      ],
      "answer": "Kai $x=5, y=2$; kai $x=-2, y=-5$."
    },
    {
      "id": "atv-exmp-3",
      "title": "Argumento radimas",
      "level": "medium",
      "problem": "Žinoma, kad $y = \\frac{18}{x}$. Su kuria $x$ reikšme funkcijos reikšmė lygi $-6$?",
      "conceptIds": [
        "atvirkstinis-proporcingumas"
      ],
      "steps": [
        {
          "text": "Vietoj $y$ įrašome $-6$ ir sudarome lygtį.",
          "latex": "-6 = \\frac{18}{x}"
        },
        {
          "text": "Išsprendžiame lygtį rasdami $x$.",
          "latex": "x = \\frac{18}{-6} = -3"
        }
      ],
      "answer": "-3"
    },
    {
      "id": "atv-exmp-4",
      "title": "Lentelės pildymas",
      "level": "medium",
      "problem": "Užpildykite atvirkštinio proporcingumo lentelę, jei žinoma, kad kai $x=2$, tai $y=9$.",
      "conceptIds": [
        "proporcingumo-koeficientas"
      ],
      "steps": [
        {
          "text": "Pirmiausia randame koeficientą $k$.",
          "latex": "k = 2 \\cdot 9 = 18"
        },
        {
          "text": "Dabar bet kuriai $x$ reikšmei galime rasti $y$ pagal $y = 18/x$. Pavyzdžiui, jei $x=3$, $y=6$; jei $x=6$, $y=3$.",
          "latex": "x=3 \\implies y=6; \\quad x=6 \\implies y=3"
        }
      ],
      "answer": "k=18, taškai (3;6), (6;3)"
    },
    {
      "id": "atv-exmp-5",
      "title": "Tekstinis uždavinys: Greitis ir laikas",
      "level": "medium",
      "problem": "Atstumą tarp dviejų miestų automobilis nuvažiuoja per $3$ valandas važiuodamas $80$ km/h greičiu. Per kiek laiko šį atstumą nuvažiuotų motociklas, kurio greitis $60$ km/h?",
      "conceptIds": [
        "atvirkstinis-proporcingumas"
      ],
      "steps": [
        {
          "text": "Apskaičiuojame bendrą atstumą (tai bus mūsų $k$).",
          "latex": "S = v \\cdot t = 80 \\cdot 3 = 240 \\text{ km}"
        },
        {
          "text": "Naudojame atvirkštinio proporcingumo ryšį laikui rasti.",
          "latex": "t = S / v = 240 / 60 = 4 \\text{ val.}"
        }
      ],
      "answer": "4 valandos"
    },
    {
      "id": "atv-exmp-6",
      "title": "Grafiko priklausomybė",
      "level": "hard",
      "problem": "Ar taškas $M(-0,5; 40)$ priklauso funkcijos $y = -\\frac{20}{x}$ grafikui?",
      "conceptIds": [
        "grafikas",
        "hiperbole"
      ],
      "steps": [
        {
          "text": "Įstatome taško koordinates į formulę.",
          "latex": "y = -\\frac{20}{-0,5}"
        },
        {
          "text": "Apskaičiuojame dešinę pusę.",
          "latex": "y = \\frac{20}{0,5} = 40"
        },
        {
          "text": "Palyginame gautą rezultatą su taško $y$ koordinate.",
          "latex": "40 = 40"
        }
      ],
      "answer": "Taip, priklauso."
    },
    {
      "id": "atv-exmp-7",
      "title": "Geometrinis taikymas",
      "level": "hard",
      "problem": "Stačiakampio plotas lygus $24 \\text{ cm}^2$. Užrašykite stačiakampio aukštinės $h$ priklausomybę nuo jo pagrindo $a$. Kokia bus aukštinė, jei pagrindas lygus $12$ cm?",
      "conceptIds": [
        "atvirkstinis-proporcingumas"
      ],
      "steps": [
        {
          "text": "Stačiakampio ploto formulė yra $S = a \\cdot h$. Iš čia išreiškiame $h$.",
          "latex": "h = \\frac{S}{a} = \\frac{24}{a}"
        },
        {
          "text": "Įstatome $a = 12$.",
          "latex": "h = \\frac{24}{12} = 2 \\text{ cm}"
        }
      ],
      "answer": "$h = 24/a$; h = 2 cm"
    },
    {
      "id": "atv-exmp-8",
      "title": "Sudėtingesnis koeficientas",
      "level": "hard",
      "problem": "Funkcijos $y = \\frac{k}{x}$ grafikas eina per tašką, kurio koordinatės yra lygios. Žinoma, kad šiame taške $y = 5$. Raskite $k$ ir kitą grafikui priklausantį tašką, kurio $x$ koordinatė yra $-2,5$.",
      "conceptIds": [
        "proporcingumo-koeficientas"
      ],
      "steps": [
        {
          "text": "Jei koordinatės lygios, tai $x = y = 5$.",
          "latex": "k = x \\cdot y = 5 \\cdot 5 = 25"
        },
        {
          "text": "Užrašome funkciją $y = 25/x$ ir randame ieškomą reikšmę.",
          "latex": "y = \\frac{25}{-2,5} = -10"
        }
      ],
      "answer": "k = 25; taškas (-2,5; -10)"
    }
