      "id": "we-ol-7-alg-1",
      "title": "Gudrus skaičiavimas su formulėmis",
      "problem": "Apskaičiuokite reikšmę be skaičiuotuvo: $999^2 + 1999$.",
      "steps": [
        {
          "text": "Pastebėkime, kad $1999 = 2000 - 1 = 2 \\cdot 1000 - 1$."
        },
        {
          "text": "Tačiau yra dar geresnis būdas: $1999 = 1000 + 999$."
        },
        {
          "text": "O dar geriau: $999^2 + 1999 = 999^2 + 2 \\cdot 999 + 1$."
        },
        {
          "text": "Matome sumos kvadrato formulę: $a^2 + 2ab + b^2$, kur $a=999, b=1$."
        },
        {
          "text": "Rezultatas: $(999+1)^2 = 1000^2 = 1\\ 000\\ 000$."
        }
      ],
      "answer": "1 000 000"
    },
    {
      "id": "we-ol-7-alg-2",
      "title": "Lygčių sistemos transformacija",
      "problem": "Išspręskite sistemą: $x + xy + y = 11$, $x^2y + xy^2 = 30$.",
      "steps": [
        {
          "text": "Pertvarkome pirmą lygtį: $x+y + xy = 11$."
        },
        {
          "text": "Iškeliame bendrą daugiklį antroje lygtyje: $xy(x+y) = 30$."
        },
        {
          "text": "Pažymime $S = x+y$ ir $P = xy$."
        },
        {
          "text": "Gauname paprastą sistemą: $S+P=11$ ir $S \\cdot P = 30$."
        },
        {
          "text": "Skaičiai, kurių suma 11, o sandauga 30, yra 5 ir 6."
        },
        {
          "text": "Atvejis 1: $x+y=5, xy=6 \\to$ sprendiniai $(2, 3)$ ir $(3, 2)$."
        },
        {
          "text": "Atvejis 2: $x+y=6, xy=5 \\to$ sprendiniai $(1, 5)$ ir $(5, 1)$."
        }
      ],
      "answer": "(1, 5), (5, 1), (2, 3), (3, 2)"
    },
    {
      "id": "we-ol-7-alg-3",
      "title": "Nelygybės įrodymas",
      "problem": "Įrodykite, kad bet kokiems $a$ ir $b$ galioja: $a^2 + b^2 \\ge 2ab$.",
      "steps": [
        {
          "text": "Perkeliame viską į vieną pusę: $a^2 - 2ab + b^2 \\ge 0$."
        },
        {
          "text": "Atpažįstame skirtumo kvadrato formulę: $(a-b)^2 \\ge 0$."
        },
        {
          "text": "Kadangi bet kurio realiojo skaičiaus kvadratas visada yra neneigiamas, nelygybė įrodyta."
        }
      ],
      "answer": "Įrodyta"
    },
    {
      "id": "we-ol-7-alg-4",
      "title": "Diofantinė lygtis",
      "problem": "Raskite visus sveikuosius skaičius $x$ ir $y$, kad $xy = x + y + 3$.",
      "steps": [
        {
          "text": "Perkeliame kintamuosius: $xy - x - y = 3$."
        },
        {
          "text": "Pridedame 1 prie abiejų pusių, kad galėtume sugrupuoti: $xy - x - y + 1 = 4$."
        },
        {
          "text": "Skaidome: $x(y-1) - (y-1) = 4 \\to (x-1)(y-1) = 4$."
        },
        {
          "text": "Išnagrinėjame skaičiaus 4 daliklius: $(1, 4), (2, 2), (4, 1), (-1, -4), (-2, -2), (-4, -1)$."
        },
        {
          "text": "Iš kiekvienos poros randame $x$ ir $y$. Pvz., iš $(1, 4)$ turime $x-1=1, y-1=4 \\to (2, 5)$."
        }
      ],
      "answer": "(2, 5), (3, 3), (5, 2), (0, -3), (-1, -1), (-3, 0)"
    },
    {
      "id": "we-ol-7-alg-5",
      "title": "Reiškinio suprastinimas",
      "problem": "Suprastinkite: $\\frac{a^3 - b^3}{a-b} - 3ab$.",
      "steps": [
        {
          "text": "Pritaikome kubų skirtumo formulę: $a^3 - b^3 = (a-b)(a^2 + ab + b^2)$."
        },
        {
          "text": "Suprastiname trupmeną padalindami iš $(a-b)$: lieka $a^2 + ab + b^2$."
        },
        {
          "text": "Atimame likusį narį: $a^2 + ab + b^2 - 3ab = a^2 - 2ab + b^2$."
        },
        {
          "text": "Atpažįstame skirtumo kvadratą: $(a-b)^2$."
        }
      ],
      "answer": "(a-b)^2"
    }
