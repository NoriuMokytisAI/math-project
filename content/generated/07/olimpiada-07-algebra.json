  "theory": [
    {
      "id": "olimpiada-07-alg-theory-1",
      "title": "Euklido algoritmas ir tarpusavyje pirminiai skaičiai",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Didžiausio bendrojo daliklio (DBD) radimas yra vienas iš pamatinių skaičių teorijos uždavinių. Euklido algoritmas remiasi pastebėjimu, kad dviejų skaičių $a$ ir $b$ ($a > b$) DBD yra toks pat kaip skaičių $b$ ir $a - b$ (arba liekanos $a \\pmod b$)."
        },
        {
          "type": "method",
          "text": "Kartotinai dalindami su liekana, greitai randame bet kokių dviejų skaičių DBD. Jei dviejų skaičių DBD yra lygus 1, jie vadinami tarpusavyje pirminiais."
        }
      ]
    },
    {
      "id": "olimpiada-07-alg-theory-2",
      "title": "Algebrinės transformacijos",
      "blocks": [
        {
          "type": "paragraph",
          "text": "Olimpiadinėje algebroje svarbu ne tik spręsti lygtis, bet ir sumaniai keisti jų pavidalą naudojant sutrumpintos daugybos formules."
        }
      ]
    }
  ],
