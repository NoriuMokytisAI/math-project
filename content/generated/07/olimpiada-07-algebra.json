  "workedExamples": [
    {
      "id": "we-olimpiada-07-alg-01",
      "title": "Lygčių sistemos sudėjimo metodas",
      "level": "medium",
      "problem": "Išspręskite sistemą: $x + y = 10, x - y = 4$.",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Sudėjus lygtis: $2x = 14 \\implies x = 7$.",
          "latex": "2x=14"
        },
        {
          "text": "Įstačius $x=7$ į $x+y=10$: $y = 3$.",
          "latex": "7+y=10"
        }
      ],
      "answer": "x=7, y=3"
    },
    {
      "id": "we-olimpiada-07-alg-02",
      "title": "Skaitmenų sukeitimas",
      "level": "hard",
      "problem": "Dviženklio skaičiaus skaitmenų suma 12. Sukeitus juos, skaičius padidėja 18. Raskite skaičių.",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Lygtys: $x+y=12$ ir $(10y+x) - (10x+y) = 18 \\implies 9(y-x) = 18 \\implies y-x=2$.",
          "latex": "y-x=2"
        },
        {
          "text": "Iš $y+x=12$ ir $y-x=2$ gauname $y=7, x=5$.",
          "latex": "x=5, y=7"
        }
      ],
      "answer": "57"
    },
    {
      "id": "we-olimpiada-07-alg-03",
      "title": "Procentų taikymas",
      "level": "easy",
      "problem": "Prekė kainavo 100 eurų. Kaina padidėjo 10%, o tada sumažėjo 10%. Kokia galutinė kaina?",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Po padidėjimo: $100 \\cdot 1.1 = 110$.",
          "latex": "100 \\cdot 1.1 = 110"
        },
        {
          "text": "Po sumažėjimo: $110 \\cdot 0.9 = 99$.",
          "latex": "110 \\cdot 0.9 = 99"
        }
      ],
      "answer": "99"
    },
    {
      "id": "we-olimpiada-07-alg-04",
      "title": "Daugianarių skaidymas",
      "level": "medium",
      "problem": "Išskaidykite $a^2 - b^2 + a - b$.",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Sugrupuokite: $(a^2 - b^2) + (a - b)$.",
          "latex": "(a-b)(a+b) + (a-b)"
        },
        {
          "text": "Iškelkite $(a-b)$ prieš skliaustus: $(a-b)(a+b+1)$.",
          "latex": "(a-b)(a+b+1)"
        }
      ],
      "answer": "(a-b)(a+b+1)"
    },
    {
      "id": "we-olimpiada-07-alg-05",
      "title": "Aritmetinė seka",
      "level": "medium",
      "problem": "Raskite dešimtąjį sekos 2, 5, 8, ... narį.",
      "conceptIds": [
        "olimpiada-07-concept-logic"
      ],
      "steps": [
        {
          "text": "Skirtumas $d = 3, a_1 = 2$.",
          "latex": "d=3"
        },
        {
          "text": "$a_{10} = 2 + 9 \\cdot 3 = 29$.",
          "latex": "a_{10} = 2 + 27 = 29"
        }
      ],
      "answer": "29"
    }
  ],
